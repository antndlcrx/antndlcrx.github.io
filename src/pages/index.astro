---
import Base from '../layouts/Base.astro';
import Partners from '../components/Partners.astro';
import LogoMark from '../components/LogoMark.astro';
---

<Base title="Oxford LLMs">

  <!-- HERO: on plain white -->
  <section class="hero">
    <div class="container">
      <LogoMark size={52} className="hero__logo" />
      <p class="hero__tagline">
        Research, teaching, and community for social scientists working with language models.
      </p>
      <hr class="hero__rule" />
    </div>
  </section>

  <!-- Blend: white → tint -->
  <div class="blend-to-tint"></div>

  <!-- THREE PILLARS: on tinted background -->
  <section class="section-tinted" style="padding: var(--sp-6) 0;">
    <div class="container">
      <div class="grid-3">
        <a href="/research/" class="card card--accent-1 card--pillar">
          <h3 class="card__title">Research</h3>
          <p class="card__text">
            New methods for LLMs in social science: synthetic data, opinion prediction, and model evaluation.
            Some work is ongoing; other projects are completed and are being peer-reviewed.
          </p>
          <span class="card__link">View papers →</span>
        </a>

        <a href="/summer-school/" class="card card--accent-3 card--pillar">
          <h3 class="card__title">Summer School</h3>
          <p class="card__text">
            Annual 5-day intensive at Nuffield College, Oxford.
            Third year running. ~200 applications per cohort, 30 selected.
          </p>
          <span class="card__link">See programme →</span>
        </a>

        <a href="/course/" class="card card--accent-5 card--pillar">
          <h3 class="card__title">Teaching</h3>
          <p class="card__text">
            Courses at Oxford, Sciences Po Paris, and the European University Institute.
            All materials open-source on GitHub.
          </p>
          <span class="card__link">Course details →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Blend: tint → white -->
  <div class="blend-to-white"></div>

  <!-- UPCOMING: on plain white -->
  <section class="section-plain" style="padding: var(--sp-6) 0;">
    <div class="container">
      <p class="section-label">Upcoming</p>
      <div class="grid-2">
        <a href="/course/" class="card card--accent-2 card--pillar">
          <span class="tag tag--2">Course</span>
          <h3 class="card__title" style="margin-top: var(--sp-3);">ESSCA, Early April 2026</h3>
          <p class="card__text">One day intensive on LLMs for social science, hosted at ESSCA.</p>
        </a>
        <div class="card card--accent-4">
          <span class="tag tag--4">Apply</span>
          <h3 class="card__title" style="margin-top: var(--sp-3);">Summer School: Applications open Apr 10</h3>
          <p class="card__text">Five days at Nuffield College. Join the third cohort of early-career researchers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Blend: white → tint -->
  <div class="blend-to-tint"></div>

  <!-- STATS: on tinted background -->
  <section class="section-tinted" style="padding: var(--sp-6) 0;">
    <div class="container">
      <div class="stats card--accent-2">
        <div class="stat">
          <div class="stat__number stat__number--1">3</div>
          <div class="stat__label">Years running</div>
        </div>
        <div class="stat">
          <div class="stat__number stat__number--2">~200</div>
          <div class="stat__label">Applications / year</div>
        </div>
        <div class="stat">
          <div class="stat__number stat__number--3">60+</div>
          <div class="stat__label">Alumni researchers</div>
        </div>
        <div class="stat">
          <div class="stat__number stat__number--4">2</div>
          <div class="stat__label">Running research projects</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blend: tint → white -->
  <div class="blend-to-white"></div>

  <!-- PARTNERS: on plain white -->
  <section class="section-plain" style="padding: var(--sp-5) 0 var(--sp-4);">
    <div class="container">
      <Partners />
    </div>
  </section>

  <hr class="footer-rule" aria-hidden="true" />
  <footer class="footer footer--home">
    <div class="container footer__inner">
      <div class="footer__left">
        <img src="/img/logo/logo_mark_silver.png" alt="" class="footer__logo" />
        <span class="footer__copy">&copy; 2026 Oxford LLMs</span>
      </div>
      <ul class="footer__links">
        <li>
          <a
            href="https://github.com/Oxford-LLMs-Research"
            class="footer__link footer__link--icon"
            target="_blank"
            rel="noopener"
            aria-label="Oxford LLMs on GitHub"
          >
            <img src="/img/icons/github-mark.svg" alt="GitHub" class="footer__icon-image footer__icon-image--github" />
          </a>
        </li>
        <li>
          <a
            href="https://huggingface.co/oxford-llms"
            class="footer__link footer__link--icon"
            target="_blank"
            rel="noopener"
            aria-label="Oxford LLMs on Hugging Face"
          >
            <img src="/img/icons/hf-logo.svg" alt="Hugging Face" class="footer__icon-image footer__icon-image--hf" />
          </a>
        </li>
        <li>
          <a
            href="mailto:maksim.zubok@nuffield.ox.ac.uk"
            class="footer__link footer__link--icon"
            aria-label="Email Oxford LLMs"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect
                x="4"
                y="7"
                width="16"
                height="10"
                rx="2"
                ry="2"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
              />
              <path
                d="M5 8.5L12 13l7-4.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </footer>

</Base>

<style>
  .card--pillar {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .card--pillar:hover {
    border-color: var(--border-lt);
    transform: translateY(-2px);
  }
  .card--pillar .card__text {
    flex: 1;
  }
</style>
