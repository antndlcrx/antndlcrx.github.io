---
import Base from '../layouts/Base.astro';
import Partners from '../components/Partners.astro';
---

<Base title="Oxford LLMs">

  <!-- ═══════════════════════════════════════════════════════════
       HERO — aurora
       ═══════════════════════════════════════════════════════════ -->
  <div class="hero-aurora-wrap">
    <div class="hero-rule-top"></div>

    <div class="hero-dateline">
      <span>Nuffield College</span>
      <span class="sep"></span>
      <span>Est. 2023</span>
    </div>

    <!-- aurora blobs — colours driven by palette.css -->
    <div class="hero-aurora" aria-hidden="true">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
    </div>

    <div class="shell hero-inner">
      <div class="eyebrow-v3" style="margin-bottom:24px">
        Oxford LLMs · Research · Teaching · Community
      </div>

      <h1 class="hero-title">
        <span class="word">Large</span>
        <span class="word">Language</span>
        <span class="word">Models</span>
        <span class="word">for</span>
        <span class="word accent">Social Science.</span>
      </h1>

      <p class="lede-v3 hero-lede-v3" style="margin-top:24px; max-width:600px;">
        We run an annual summer school at Nuffield College, develop an open-source
        course on the fundamentals of LLMs for social scientists, and work on
        methods research. Our faculty spans academic research and the ML industry.
        Everything is open.
      </p>

      <div class="hero-actions" style="margin-top:32px; display:flex; gap:12px; flex-wrap:wrap;">
        <a class="btn-primary" href="/summer-school/2026/">
          Summer school 2026 <span class="arrow">→</span>
        </a>
        <a class="btn-ghost" href="/research/">
          Research <span class="arrow">→</span>
        </a>
      </div>

      <div class="hero-meta">
        <span>13–17 July 2026</span>
        <span class="sep"></span>
        <span>Nuffield College, Oxford</span>
        <span class="sep"></span>
        <span>Applications closed</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       § 01 RESEARCH
       ═══════════════════════════════════════════════════════════ -->
  <section class="section-v3 section-v3--marker">
    <span class="section-number">§ 01 · Research</span>

    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Research</div>
          <h2 class="h-section">Methods for LLMs in social science.</h2>
        </div>
        <p class="lede-v3">
          We develop methods for applying language models to social science research.
          Code and datasets are open source on GitHub and Hugging Face.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 20px;"
           class="reveal-stagger">

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Synthetic data</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            Can LLMs generate respondent panels that pass standard quality checks?
            When they do not, where do they fail, and can we measure it before we use them?
          </p>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Opinion prediction</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            How well do open-weights models recover real survey responses across languages,
            age cohorts, and political contexts, and what drives the gaps?
          </p>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Evaluation</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            Building eval sets that survive contamination, treating annotator disagreement
            as a measurement signal rather than noise.
          </p>
        </article>

      </div>

      <div class="reveal" style="margin-top:28px; display:flex; gap:14px; flex-wrap:wrap; align-items:center;">
        <a class="btn-ghost" href="/research/">
          Research <span class="arrow">→</span>
        </a>
        <a class="btn-link-v3" href="https://github.com/Oxford-LLMs-Research"
           target="_blank" rel="noopener">
          Oxford-LLMs-Research on GitHub <span class="arrow">→</span>
        </a>
        <a class="btn-link-v3" href="https://huggingface.co/oxford-llms"
           target="_blank" rel="noopener">
          Models on Hugging Face <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       § 02 SUMMER SCHOOL
       ═══════════════════════════════════════════════════════════ -->
  <section class="section-v3 section-v3--marker section-tinted-v3">
    <span class="section-number">§ 02 · Summer School</span>

    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Annual intensive</div>
          <h2 class="h-section">Five days at Nuffield.</h2>
        </div>
        <p class="lede-v3">
          Early-career researchers. Lectures, labs, collaborative research.
          Now entering its fourth year.
        </p>
      </div>

      <!-- 2026 teaser -->
      <div class="apply-teaser reveal">
        <div>
          <p class="at-title">Oxford LLMs 2026</p>
          <p class="at-row" style="margin-bottom:0">13–17 July · Nuffield College, Oxford</p>
        </div>
        <div class="at-cta">
          <a class="btn-primary" href="/summer-school/2026/">
            Programme &amp; speakers <span class="arrow">→</span>
          </a>
        </div>
      </div>

      <!-- Cohort photo + materials -->
      <div class="ss-pair reveal-stagger">
        <article class="cohort-card">
          <img
            src="/img/posts/report_2025/group_photo_2025.jpg"
            alt="Oxford LLMs 2025 cohort group photo at Nuffield College"
          />
          <div class="cc-body">
            <span class="cc-tag">2025 Cohort</span>
            <h3 class="cc-title">30 researchers. 5 days. Nuffield College.</h3>
            <p class="cc-desc">
              Lectures on LLM fundamentals, evaluation, fine-tuning, and AI safety.
              A Kaggle-style competition ran alongside a collaborative research project.
            </p>
            <div class="cc-foot">
              <a class="btn-link-v3" href="/summer-school/2025/">
                See the highlights <span class="arrow">→</span>
              </a>
            </div>
          </div>
        </article>

        <article class="materials-card">
          <div class="m-tag">Past schools</div>
          <h3 class="m-title">Three years of cohorts.</h3>
          <ul class="m-list">
            <li>
              <a href="/summer-school/2025/">
                <span>Oxford LLMs 2025</span>
                <span class="m-meta">Highlights →</span>
              </a>
            </li>
            <li>
              <a href="/summer-school/2024/">
                <span>Oxford LLMs 2024</span>
                <span class="m-meta">Highlights →</span>
              </a>
            </li>
            <li>
              <a href="/summer-school/2023/">
                <span>Oxford LLMs 2023</span>
                <span class="m-meta">Highlights →</span>
              </a>
            </li>
            <li>
              <a href="https://github.com/antndlcrx/oxford-llms-workshop"
                 target="_blank" rel="noopener">
                <span>Workshop materials</span>
                <span class="m-meta">GitHub →</span>
              </a>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       § 03 COURSE
       ═══════════════════════════════════════════════════════════ -->
  <section class="section-v3 section-v3--marker">
    <span class="section-number">§ 03 · Course</span>

    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Open courseware</div>
          <h2 class="h-section">Language models for social science.</h2>
        </div>
        <p class="lede-v3">
          A five-module course mirroring the summer-school syllabus.
          Taught by invitation at Oxford, ESSCA Paris, and the EUI. All materials on GitHub.
        </p>
      </div>

      <div class="reveal">
        <div class="module-preview">
          <a class="mp-row" href="/course/day-1/">
            <span class="mp-num">Module 1</span>
            <span class="mp-title">Foundations</span>
            <span class="mp-meta">Embeddings · transformers</span>
          </a>
          <a class="mp-row" href="/course/day-2/">
            <span class="mp-num">Module 2</span>
            <span class="mp-title">From Models to Tools</span>
            <span class="mp-meta">Prompting · alignment</span>
          </a>
          <a class="mp-row" href="/course/day-3/">
            <span class="mp-num">Module 3</span>
            <span class="mp-title">Deploying for Research</span>
            <span class="mp-meta">Fine-tuning · inference</span>
          </a>
          <a class="mp-row" href="/course/day-4/">
            <span class="mp-num">Module 4</span>
            <span class="mp-title">Extraction &amp; RAG</span>
            <span class="mp-meta">Retrieval · grounding</span>
          </a>
          <a class="mp-row" href="/course/day-5/">
            <span class="mp-num">Module 5</span>
            <span class="mp-title">Agentic Workflows</span>
            <span class="mp-meta">Tool use · ReAct</span>
          </a>
        </div>

        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top:22px;">
          <div class="inst-logo-card">
            <img src="/img/partners/dpir_spring_school.png" alt="DPIR Spring School, University of Oxford"
                 style="height:36px; width:auto; max-width:180px; object-fit:contain; object-position:left center; margin-bottom:12px;" />
            <p style="margin:0; font-family:var(--font-mono); font-size:10.5px; text-transform:uppercase; letter-spacing:.12em; color:var(--text-muted);">Oxford · DPIR</p>
          </div>
          <div class="inst-logo-card">
            <img src="/img/partners/essca.png" alt="ESSCA Paris"
                 style="height:44px; width:auto; max-width:120px; object-fit:contain; object-position:left center; margin-bottom:12px;" />
            <p style="margin:0; font-family:var(--font-mono); font-size:10.5px; text-transform:uppercase; letter-spacing:.12em; color:var(--text-muted);">ESSCA · Paris</p>
          </div>
          <div class="inst-logo-card">
            <img src="/img/partners/eui.png" alt="European University Institute"
                 style="height:36px; width:auto; max-width:160px; object-fit:contain; object-position:left center; margin-bottom:12px;" />
            <p style="margin:0; font-family:var(--font-mono); font-size:10.5px; text-transform:uppercase; letter-spacing:.12em; color:var(--text-muted);">EUI · Florence</p>
          </div>
        </div>

        <div style="margin-top:22px; display:flex; gap:12px; flex-wrap:wrap;">
          <a class="btn-ghost" href="/course/">Course details <span class="arrow">→</span></a>
          <a class="btn-link-v3" href="https://github.com/antndlcrx/Intro-to-LLMs-DPIR"
             target="_blank" rel="noopener">Open on GitHub <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       PARTNERS
       ═══════════════════════════════════════════════════════════ -->
  <section class="section-v3 section-v3--marker" style="padding: clamp(36px,4vw,52px) 0;">
    <div class="shell">
      <Partners />
    </div>
  </section>


</Base>

<style>
  /* Module-preview rows are links — inherit colour, no underline */
  .mp-row {
    text-decoration: none;
    color: inherit;
  }
</style>
