---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Summer School Materials"
  description="Lecture slides, workshops, and practical guides from the Oxford LLMs summer school."
>

  <aside class="status-strip" aria-label="Page breadcrumb">
    <div class="status-strip-inner">
      <a href="/resources/" style="color:inherit; text-decoration:none;">Resources</a>
      <span class="sep"></span>
      <span>Summer School Materials</span>
    </div>
  </aside>

  <section class="section-v3" style="padding-top: clamp(72px, 8vw, 112px); padding-bottom: clamp(56px, 7vw, 88px);">
    <div class="shell">

      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Open access</div>
          <h1 class="h-section">Workshop Materials</h1>
        </div>
        <p class="lede-v3">
          Lecture slides, Jupyter notebooks, and workshop materials from the Oxford LLMs
          summer schools. All openly available — no registration required.
        </p>
      </div>

      <!-- 2024 -->
      <div class="reveal" style="margin-top:48px; padding-top:32px; border-top:1px solid var(--border);">
        <div class="eyebrow-v3" style="margin-bottom:20px">2024 · Second edition</div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

          <article class="fb">
            <span class="rule-soft"></span>
            <h3 class="h-sub" style="margin-bottom:16px">Lectures</h3>
            <ul class="mat-list">
              <li>
                <a href="https://docs.google.com/presentation/d/1avuQJE-Gf8t0an-sinXqkvKjzv1u4rLpO94ONOE_Vx4/edit#slide=id.p"
                   target="_blank" rel="noopener">Introduction to LLMs</a>
                <span class="mat-speaker">Grigory Sapunov</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/1n_wwOPwbK9FPkVMKGA9Vneya4Jaf4lh13D9YO9byves/edit#slide=id.g303d6023e88_1_58"
                   target="_blank" rel="noopener">LLM Evaluation</a>
                <span class="mat-speaker">Tatiana Shavrina</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/10-6Erne_Fo62y2i4OOEaNkGTrcEEIk9sOObuSJlhR80/edit#slide=id.g303d938f784_1_58"
                   target="_blank" rel="noopener">LLM Agents</a>
                <span class="mat-speaker">Tatiana Shavrina</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/1Zlt3ARDbGBhVvmPaz7omaj6MlXIlIOFs7wm6P8GGrpc/edit#slide=id.p"
                   target="_blank" rel="noopener">LLM Agents (continued)</a>
                <span class="mat-speaker">Grigory Sapunov</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/1-Kf059z24W65GgPNbjw6vOvABFOdxFf4BD_Hsenc-U8/edit"
                   target="_blank" rel="noopener">Fine-Tuning and Alignment</a>
                <span class="mat-speaker">Ilya Boytsov</span>
              </li>
            </ul>
          </article>

          <article class="fb">
            <span class="rule-soft"></span>
            <h3 class="h-sub" style="margin-bottom:16px">Seminars</h3>
            <ul class="mat-list">
              <li>
                <a href="https://docs.google.com/presentation/d/1ngAVq0Ks3_rgDw5Qnif_A483G6M6RoL2shVklabrYDI/edit#slide=id.g1ff45be8172_1_0"
                   target="_blank" rel="noopener">Navigating RAG for Social Science</a>
                <span class="mat-speaker">Atita Arora</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/1wCGSwBqo4iNx_MQXwQLHRyVW__t8UlMU9K6HPLmq4hM/edit#slide=id.g2f39ad35ae4_0_641"
                   target="_blank" rel="noopener">LLM Observability and Evaluation</a>
                <span class="mat-speaker">John Githuly</span>
              </li>
              <li>
                <a href="https://github.com/Jgilhuly/Llama-Researcher"
                   target="_blank" rel="noopener">Tutorial: Creating Llama-Researcher</a>
                <span class="mat-speaker">John Githuly</span>
              </li>
              <li>
                <a href="https://docs.google.com/presentation/d/1-_vJmcpJjDAY5zh60DR834yUwYyR-XlSZ5amC0sLfZg/edit?usp=sharing"
                   target="_blank" rel="noopener">Gemini Model Deep Dive</a>
                <span class="mat-speaker">Christian Silva</span>
              </li>
              <li>
                <a href="/assets/presentations/oxford_llm_lecture_fowler.pdf"
                   target="_blank" rel="noopener">ORI's Guide to Self-Hosting LLMs</a>
                <span class="mat-speaker">Ciera Fowler</span>
              </li>
            </ul>
          </article>

        </div>
      </div>

      <!-- 2023 -->
      <div class="reveal" style="margin-top:40px; padding-top:32px; border-top:1px solid var(--border);">
        <div class="eyebrow-v3" style="margin-bottom:20px">2023 · Inaugural edition</div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

          <article class="fb">
            <span class="rule-soft"></span>
            <h3 class="h-sub" style="margin-bottom:16px">Lectures</h3>
            <p class="copy" style="font-size:13px; color:var(--text-dim); margin:0 0 12px;">
              All lectures by <a href="https://lena-voita.github.io/" target="_blank" rel="noopener">Elena Voita</a>.
            </p>
            <ul class="mat-list">
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/lectures/day_1/The%20Evolutionary%20Journey%20in%20NLP.pdf"
                   target="_blank" rel="noopener">The Evolutionary Journey of NLP</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/lectures/day_2/Bias%20in%20LLMs%20and%20interpretability.pdf"
                   target="_blank" rel="noopener">Bias in LLMs and Interpretability</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/lectures/day_3/Prompt%20engineering%2C%20RHLF%2C%20ChatGPT.pdf"
                   target="_blank" rel="noopener">LLMs and Alignment</a>
              </li>
            </ul>
          </article>

          <article class="fb">
            <span class="rule-soft"></span>
            <h3 class="h-sub" style="margin-bottom:16px">Seminars</h3>
            <p class="copy" style="font-size:13px; color:var(--text-dim); margin:0 0 12px;">
              All workshops by <a href="https://www.linkedin.com/in/ieboytsov/" target="_blank" rel="noopener">Ilya Boytsov</a>.
            </p>
            <ul class="mat-list">
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_1/0_Env%20setup%20and%20intro.ipynb"
                   target="_blank" rel="noopener">Environment setup and intro</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_1/1_Intro%20to%20transformers.ipynb"
                   target="_blank" rel="noopener">Introduction to Hugging Face transformers</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_1/2_Topic%20modelling%20with%20transformers.ipynb"
                   target="_blank" rel="noopener">Topic modelling with BERTopic</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_1/3_Fine%20tune%20pretrained%20model.ipynb"
                   target="_blank" rel="noopener">Fine-tuning for classification</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_2/4_Parameter%20efficient%20fine%20tuning.ipynb"
                   target="_blank" rel="noopener">Parameter Efficient Fine Tuning (PEFT)</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_2/5_Transformers%20interpretability.ipynb"
                   target="_blank" rel="noopener">Transformers interpretability</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_2/6_Sentiment%20analysis%20with%20classic%20NLP.ipynb"
                   target="_blank" rel="noopener">Model analysis with spaCy</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_3/7_Prompts%20and%20instructions%20with%20Llama%202.ipynb"
                   target="_blank" rel="noopener">Prompts and instructions with Llama 2</a>
              </li>
              <li>
                <a href="https://github.com/antndlcrx/oxford-llms-workshop/blob/main/materials/seminars/day_3/8_LLMs%20alignment%20with%20RLHF.ipynb"
                   target="_blank" rel="noopener">Detoxifying summarisation with RLHF</a>
              </li>
            </ul>
          </article>

        </div>
      </div>

      <!-- GitHub archive -->
      <div class="reveal" style="margin-top:40px; padding-top:32px; border-top:1px solid var(--border);">
        <a class="btn-link-v3" href="https://github.com/antndlcrx/oxford-llms-workshop"
           target="_blank" rel="noopener">
          All materials on GitHub <span class="arrow">→</span>
        </a>
      </div>

    </div>
  </section>

</Base>

<style>
  .mat-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mat-list li {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 9px 0;
    border-bottom: 1px solid var(--border-lt);
  }
  .mat-list li:last-child { border-bottom: none; }
  .mat-list a {
    font-size: 13.5px;
    color: var(--text);
    text-decoration: none;
    transition: color .18s ease;
  }
  .mat-list a:hover { color: var(--accent); }
  .mat-speaker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
</style>
