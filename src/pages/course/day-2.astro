<!-- 3. TEMPERATURE VISUALIZER -->
<script is:inline>
(function () {
  var root = document.getElementById("temperature-viz-root");
  if (!root) return;

  var tokens = [
    { label: " oppose",  logit: 3.5 },
    { label: " support", logit: 2.4 },
    { label: " Opp",     logit: 1.6 },
    { label: " Sup",     logit: 0.9 },
    { label: " against", logit: 0.3 },
    { label: " neither", logit: -0.4 },
    { label: " The",     logit: -0.9 },
    { label: " I",       logit: -1.5 }
  ];

  function softmax(logits, temp) {
    var t = Math.max(temp, 0.01);
    var scaled = logits.map(function(l) { return l / t; });
    var mx = Math.max.apply(null, scaled);
    var exps = scaled.map(function(s) { return Math.exp(s - mx); });
    var sum = exps.reduce(function(a, b) { return a + b; }, 0);
    return exps.map(function(e) { return e / sum; });
  }

  var barColors = ["var(--accent,#2D8ABF)","#4A78BF","#8CAAD6","#8CAAD6","#C5D5EA","#C5D5EA","#D8D8D0","#D8D8D0"];

  var annotations = [
    { cls: "tv-det", text: '<strong>Deterministic.</strong> The model always picks the highest-probability token. Same input, same output, every time. This is what you want for classification.' },
    { cls: "tv-cal", text: '<strong>Calibrated.</strong> The top token still dominates, but alternatives have some chance. On ambiguous inputs, the model may produce different labels across runs.' },
    { cls: "tv-cre", text: '<strong>Creative.</strong> The distribution is substantially flattened. Useful for brainstorming or diverse paraphrases, but classification results will be noisy and unreproducible.' },
    { cls: "tv-cha", text: '<strong>Approaching random.</strong> The distribution is nearly uniform. The model is almost equally likely to output any token, including nonsense. Useless for research.' }
  ];

  function getRegime(t) { return t <= 0.15 ? 0 : t <= 0.8 ? 1 : t <= 1.4 ? 2 : 3; }

  function buildAndUpdate() {
    // Build shell
    var html = '<div class="widget-wrap">' +
      '<div class="widget-eyebrow">Interactive visualisation</div>' +
      '<div class="widget-title">How Temperature Shapes Output</div>' +
      '<p class="widget-intro">Temperature controls how the model picks its next token. Drag the slider and watch the distribution change.</p>' +
      '<div style="background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);border-radius:8px;padding:0.9rem 1.1rem;margin-bottom:1.5rem;font-family:var(--font-mono,monospace);font-size:0.78rem;line-height:1.7;color:var(--text-sec,#3D4455);">' +
        '<div style="font-size:0.62rem;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted,#6B7280);margin-bottom:0.4rem;font-family:var(--font-body,sans-serif);">The model has processed this prompt and is about to generate the next token:</div>' +
        '<div style="margin-top:0.4rem;"><span style="color:var(--accent,#2D8ABF);font-weight:500;">System:</span> You are a political text analyst.<br><span style="color:var(--accent,#2D8ABF);font-weight:500;">User:</span> Classify this tweet as support or oppose.<br>Answer with one word.<br><br>Tweet: "Great job marching today everyone, really changed the world. \uD83D\uDE44"<br>Answer:<span style="display:inline-block;width:2px;height:1em;background:var(--accent,#2D8ABF);margin-left:2px;vertical-align:text-bottom;animation:blink 1s step-end infinite;"></span></div>' +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.4rem;">' +
        '<div style="font-size:0.82rem;font-weight:600;color:var(--text,#1A1D27);white-space:nowrap;min-width:7rem;">Temperature: <span id="tv-val" style="font-family:var(--font-mono,monospace);color:var(--accent,#2D8ABF);">1.00</span></div>' +
        '<input type="range" id="tv-slider" min="0" max="200" value="100" step="1" style="flex:1;-webkit-appearance:none;height:5px;border-radius:3px;background:var(--border,#E2E6EE);outline:none;cursor:pointer;">' +
      '</div>' +
      '<div id="tv-regimes" style="display:flex;margin-bottom:1.5rem;padding-left:8rem;"></div>' +
      '<div id="tv-chart"></div>' +
      '<div id="tv-ann" style="padding:0.85rem 1rem;border-radius:0 8px 8px 0;font-size:0.85rem;color:var(--text-sec,#3D4455);line-height:1.6;border-left:3px solid var(--border,#E2E6EE);background:var(--surface-alt,#F5F5F0);margin-bottom:1.5rem;min-height:3.5rem;transition:all 0.35s ease;"></div>' +
      '<div style="background:var(--surface,#FFF);border:1.5px solid var(--accent,#2D8ABF);border-radius:12px;padding:1.25rem;">' +
        '<div style="font-family:var(--font-display,serif);font-size:1rem;font-weight:700;color:var(--accent,#2D8ABF);margin-bottom:0.5rem;">For your research</div>' +
        '<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Classification and annotation:</strong> use <code style="font-family:var(--font-mono,monospace);font-size:0.82em;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);border-radius:3px;padding:0.1em 0.35em;">temperature=0</code>. You want the same input to always produce the same label.</p>' +
        '<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Creative generation:</strong> use <code style="font-family:var(--font-mono,monospace);font-size:0.82em;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);border-radius:3px;padding:0.1em 0.35em;">temperature=0.5\u20131.0</code>. You want diversity but not incoherence.</p>' +
        '<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;"><strong style="color:var(--text,#1A1D27);">Always report your temperature setting.</strong> A study at temperature 0 and the same study at 0.7 can produce different results on ambiguous cases.</p>' +
      '</div>' +
    '</div>';
    root.innerHTML = html;

    // Build chart rows
    var chartEl = root.querySelector("#tv-chart");
    var barsHtml = "";
    for (var i = 0; i < tokens.length; i++) {
      barsHtml += '<div style="display:flex;align-items:center;margin-bottom:0.55rem;height:1.8rem;">' +
        '<div id="tv-tok-' + i + '" style="font-family:var(--font-mono,monospace);font-size:0.78rem;font-weight:500;color:var(--text-sec,#3D4455);width:5.5rem;text-align:right;padding-right:0.75rem;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + tokens[i].label + '</div>' +
        '<div style="flex:1;height:1.5rem;border-radius:4px;position:relative;overflow:hidden;">' +
          '<div id="tv-fill-' + i + '" style="position:absolute;left:0;top:0;height:100%;border-radius:4px;transition:width 0.3s ease;min-width:1px;"></div>' +
        '</div>' +
        '<div id="tv-pct-' + i + '" style="font-family:var(--font-mono,monospace);font-size:0.72rem;color:var(--text-muted,#6B7280);width:3.5rem;text-align:right;padding-left:0.5rem;flex-shrink:0;"></div>' +
      '</div>';
    }
    chartEl.innerHTML = barsHtml;

    // Build regimes
    var regNames = ["Deterministic","Calibrated","Creative","Chaotic"];
    var regFlex = [0.15, 0.35, 0.30, 0.20];
    var regColors = ["#2D7D46","#2E5090","#8B6914","#9E3A38"];
    var regEl = root.querySelector("#tv-regimes");
    var regHtml = "";
    for (var r = 0; r < 4; r++) {
      regHtml += '<div id="tv-reg-' + r + '" style="flex:' + regFlex[r] + ';font-size:0.68rem;font-weight:500;text-align:center;padding:0.25rem 0;border-radius:3px;color:' + regColors[r] + ';opacity:0.35;transition:opacity 0.25s ease;">' + regNames[r] + '</div>';
    }
    regEl.innerHTML = regHtml;

    var slider = root.querySelector("#tv-slider");
    function update() {
      var temp = parseInt(slider.value, 10) / 100;
      root.querySelector("#tv-val").textContent = temp.toFixed(2);
      var logits = tokens.map(function(t) { return t.logit; });
      var probs = softmax(logits, temp);
      var maxP = Math.max.apply(null, probs);
      var indices = tokens.map(function(_, i) { return i; });
      indices.sort(function(a, b) { return probs[b] - probs[a]; });
      var ranks = new Array(tokens.length);
      for (var r = 0; r < indices.length; r++) ranks[indices[r]] = r;

      for (var i = 0; i < tokens.length; i++) {
        var fill = root.querySelector("#tv-fill-" + i);
        var pct = root.querySelector("#tv-pct-" + i);
        var tok = root.querySelector("#tv-tok-" + i);
        fill.style.width = (probs[i] / maxP * 100) + "%";
        fill.style.background = barColors[Math.min(ranks[i], barColors.length - 1)];
        var pctVal = probs[i] * 100;
        pct.textContent = pctVal < 0.1 ? "<0.1%" : pctVal.toFixed(1) + "%";
        tok.style.fontWeight = ranks[i] === 0 ? "700" : "500";
        tok.style.color = ranks[i] === 0 ? "var(--text,#1A1D27)" : "var(--text-sec,#3D4455)";
        pct.style.color = ranks[i] === 0 ? "var(--accent,#2D8ABF)" : "var(--text-muted,#6B7280)";
        pct.style.fontWeight = ranks[i] === 0 ? "600" : "400";
      }

      var regime = getRegime(temp);
      for (var s = 0; s < 4; s++) {
        root.querySelector("#tv-reg-" + s).style.opacity = s === regime ? "1" : "0.35";
      }
      var ann = root.querySelector("#tv-ann");
      var a = annotations[regime];
      var borderColors = ["#2D7D46","#2E5090","#8B6914","#9E3A38"];
      var bgColors = ["#EDF7F0","#EDF2FA","#FDF8EC","#FDF0F0"];
      ann.style.borderLeftColor = borderColors[regime];
      ann.style.background = bgColors[regime];
      ann.innerHTML = a.text;
    }

    slider.addEventListener("input", update);
    update();
  }

  buildAndUpdate();
})();
</script>

<style is:inline>
@keyframes blink { 50% { opacity: 0; } }
</style>

<!-- 4. PROMPT SENSITIVITY HEATMAP -->
<script is:inline>
(function () {
  var root = document.getElementById("prompt-sensitivity-root");
  if (!root) return;

  var variants = [
    { short: "V1", desc: "support/oppose" },
    { short: "V2", desc: "favor/against" },
    { short: "V3", desc: "pro/anti" },
    { short: "V4", desc: "favorable/unfav." },
    { short: "V5", desc: "reordered" }
  ];

  var tweets = [
    { text: "Great job marching today everyone, really changed the world. \uD83D\uDE44", truth: "o", preds: ["s","o","o","s","s"], note: "Sarcasm. Three of five variants miss it." },
    { text: "I support the cause but the march itself was poorly organised and counterproductive.", truth: "o", preds: ["s","s","o","o","s"], note: "Mixed signal: supports the cause but opposes the march itself." },
    { text: "The march was a nice gesture but real change requires more than walking around with signs.", truth: "o", preds: ["o","s","o","s","o"], note: "Backhanded compliment. Two variants take the praise at face value." },
    { text: "Whether you agree or not, you have to respect the right to peaceful protest.", truth: "s", preds: ["s","o","o","s","s"], note: "Principled support framed as neutral. Two variants misread the hedging." },
    { text: "Interesting to see how many people turned out. The movement clearly has energy.", truth: "s", preds: ["s","s","s","s","o"], note: "Observational tone. V5 (reordered prompt) misreads it." },
    { text: "My daughter asked why people were marching. I told her: because some people have too much free time.", truth: "o", preds: ["o","o","s","o","o"], note: "Dismissive narrative framing. V3 misreads mention of marching." },
    { text: "Marching won't fix anything. Vote. Organise. Run for office.", truth: "o", preds: ["o","o","o","o","s"], note: "Tactical critique. V5 focuses on constructive suggestions." },
    { text: "These people don't represent me or any woman I know.", truth: "o", preds: ["o","o","o","o","o"], note: "Clear opposition. Stable." },
    { text: "So proud of everyone who showed up today! #WomensMarch #Resist", truth: "s", preds: ["s","s","s","s","s"], note: "Clear support. Stable." },
    { text: "Standing with my sisters. This is what democracy looks like.", truth: "s", preds: ["s","s","s","s","s"], note: "Clear support. Stable." },
    { text: "LOL at all these signs. Do they think this actually accomplishes anything?", truth: "o", preds: ["o","o","o","o","o"], note: "Clear opposition. Stable." },
    { text: "\uD83D\uDE4C\uD83D\uDE4C\uD83D\uDE4C #WomensMarch", truth: "s", preds: ["s","s","s","s","s"], note: "Emoji-only support. Stable." }
  ];

  tweets.forEach(function(t) {
    var sc = t.preds.filter(function(p){return p==="s";}).length;
    var maj = sc >= 3 ? "s" : "o";
    t.instability = t.preds.filter(function(p){return p!==maj;}).length;
  });
  tweets.sort(function(a,b){return b.instability - a.instability;});

  var selectedIdx = null;
  var stableCount = tweets.filter(function(t){return t.instability===0;}).length;
  var unstableCount = tweets.length - stableCount;
  var totalFlips = tweets.reduce(function(s,t){return s+t.instability;},0);
  var flipRate = Math.round(totalFlips / (tweets.length * 5) * 100);

  function esc(s){return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");}
  function getMaj(preds){var sc=preds.filter(function(p){return p==="s";}).length;return sc>=3?"s":"o";}

  function render() {
    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive visualisation</div>';
    html += '<div class="widget-title">Prompt Sensitivity</div>';
    html += '<p class="widget-intro">Twelve tweets, five prompt variants, same model. Click any row to inspect where predictions diverge.</p>';

    // Stats
    html += '<div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">';
    html += '<div style="flex:1;min-width:140px;padding:0.75rem 1rem;border-radius:8px;border:1px solid #B8DBBD;background:#EDF7F0;"><div style="font-family:var(--font-mono,monospace);font-size:1.4rem;font-weight:700;">' + stableCount + '/' + tweets.length + '</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);">Stable across all variants</div></div>';
    html += '<div style="flex:1;min-width:140px;padding:0.75rem 1rem;border-radius:8px;border:1px solid #F0B8B8;background:#FDF0F0;"><div style="font-family:var(--font-mono,monospace);font-size:1.4rem;font-weight:700;">' + unstableCount + '/' + tweets.length + '</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);">At least one prediction flips</div></div>';
    html += '<div style="flex:1;min-width:140px;padding:0.75rem 1rem;border-radius:8px;border:1px solid var(--border,#E2E6EE);background:var(--surface-alt,#F5F5F0);"><div style="font-family:var(--font-mono,monospace);font-size:1.4rem;font-weight:700;">' + flipRate + '%</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);">Overall disagreement rate</div></div>';
    html += '</div>';

    // Grid
    html += '<div style="overflow-x:auto;-webkit-overflow-scrolling:touch;"><div style="display:grid;grid-template-columns:minmax(180px,1.2fr) repeat(5,minmax(72px,1fr));gap:0;min-width:580px;">';
    // Header
    html += '<div style="font-family:var(--font-body,sans-serif);font-size:0.75rem;font-weight:600;color:var(--text-muted,#6B7280);padding:0.5rem 0.6rem;border-bottom:2px solid var(--border,#E2E6EE);text-align:left;">Tweet</div>';
    for (var v = 0; v < variants.length; v++) {
      html += '<div style="font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:600;color:var(--text-muted,#6B7280);padding:0.5rem 0.4rem;border-bottom:2px solid var(--border,#E2E6EE);text-align:center;line-height:1.35;">' + variants[v].short + '<br><span style="font-weight:400;opacity:0.7;">' + variants[v].desc + '</span></div>';
    }
    // Rows
    for (var i = 0; i < tweets.length; i++) {
      var t = tweets[i];
      var isSel = selectedIdx === i;
      var rowBg = isSel ? "background:var(--accent-light,#E8EEF6);" : "";
      var maj = getMaj(t.preds);
      // Tweet cell
      html += '<div class="ps-click" data-i="' + i + '" style="font-size:0.78rem;color:var(--text-sec,#3D4455);padding:0.65rem 0.6rem;border-bottom:1px solid var(--border,#E2E6EE);cursor:pointer;display:flex;align-items:center;line-height:1.4;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;' + rowBg + '">';
      html += '<span style="font-family:var(--font-mono,monospace);font-size:0.68rem;color:var(--text-muted,#6B7280);width:1.5rem;flex-shrink:0;">' + (i+1) + '</span>';
      html += '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">' + esc(t.text) + '</span>';
      // Pips
      html += '<span style="flex-shrink:0;margin-left:0.5rem;display:flex;gap:2px;">';
      for (var p = 0; p < 5; p++) html += '<span style="width:5px;height:5px;border-radius:50%;background:' + (p < t.instability ? '#D44' : 'var(--border,#E2E6EE)') + ';"></span>';
      html += '</span></div>';
      // Pred cells
      for (var vi = 0; vi < 5; vi++) {
        var pred = t.preds[vi];
        var isFlip = t.instability > 0 && pred !== maj;
        var tagBg = pred === "s" ? "#E0EAFA" : "#FAEAD8";
        var tagCol = pred === "s" ? "#2E5090" : "#9E5C28";
        var ring = isFlip ? "box-shadow:0 0 0 2px #D44;" : "";
        html += '<div class="ps-click" data-i="' + i + '" style="padding:0.65rem 0.4rem;border-bottom:1px solid var(--border,#E2E6EE);display:flex;align-items:center;justify-content:center;cursor:pointer;' + rowBg + '">';
        html += '<span style="font-family:var(--font-mono,monospace);font-size:0.7rem;font-weight:600;padding:0.2rem 0.55rem;border-radius:3px;background:' + tagBg + ';color:' + tagCol + ';' + ring + '">' + (pred === "s" ? "support" : "oppose") + '</span>';
        html += '</div>';
      }
    }
    html += '</div></div>';

    // Detail panel
    if (selectedIdx !== null) {
      var t = tweets[selectedIdx];
      html += '<div class="widget-fade" style="margin-top:1.25rem;background:var(--surface,#FFF);border:1.5px solid var(--border,#E2E6EE);border-radius:12px;padding:1.25rem;">';
      html += '<div style="font-family:var(--font-mono,monospace);font-size:0.65rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-muted,#6B7280);margin-bottom:0.3rem;">Tweet ' + (selectedIdx+1) + '</div>';
      html += '<div style="font-size:0.92rem;color:var(--text,#1A1D27);line-height:1.6;margin-bottom:0.75rem;font-style:italic;">\u201C' + esc(t.text) + '\u201D</div>';
      html += '<div style="font-size:0.82rem;color:var(--text-sec,#3D4455);margin-bottom:0.75rem;">Ground truth: <strong>' + (t.truth==="s"?"support":"oppose") + '</strong></div>';
      html += '<div style="font-size:0.82rem;color:var(--text-sec,#3D4455);margin-bottom:0.75rem;line-height:1.55;">' + t.note + '</div>';
      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">';
      for (var v = 0; v < 5; v++) {
        var pred = t.preds[v];
        var isWrong = pred !== t.truth;
        var bg = isWrong ? "border-color:#E8A0A0;background:#FDF0F0;" : "";
        html += '<div style="padding:0.5rem 0.7rem;border-radius:8px;border:1px solid var(--border,#E2E6EE);background:var(--surface-alt,#F5F5F0);font-size:0.78rem;line-height:1.5;' + bg + '">';
        html += '<div style="font-weight:600;color:var(--text,#1A1D27);font-size:0.72rem;">' + variants[v].short + ': ' + variants[v].desc + '</div>';
        html += '<div>' + (pred==="s"?"support":"oppose") + (isWrong?" \u2717":" \u2713") + '</div>';
        html += '</div>';
      }
      html += '</div></div>';
    }

    // Takeaway
    html += '<div style="margin-top:1.5rem;padding:0.85rem 1rem;border-left:3px solid var(--accent,#2D8ABF);background:var(--accent-light,#E8EEF6);border-radius:0 8px 8px 0;font-size:0.85rem;color:var(--text-sec,#3D4455);line-height:1.6;"><strong style="color:var(--text,#1A1D27);">The prompt is your measurement instrument.</strong> If rewording the question changes the answer, your measurement is fragile. Test multiple variants, report the range, and select your final prompt based on validation against a gold standard.</div>';

    html += '</div>';
    root.innerHTML = html;

    root.querySelectorAll(".ps-click").forEach(function(el) {
      el.addEventListener("click", function() {
        var idx = parseInt(el.getAttribute("data-i"), 10);
        selectedIdx = selectedIdx === idx ? null : idx;
        render();
      });
    });
  }

  render();
})();
</script>

<!-- 5. TEST-TIME COMPUTE TRADEOFF -->
<script is:inline>
(function () {
  var root = document.getElementById("test-time-compute-root");
  if (!root) return;

  var sizes = [500,1000,5000,10000,50000];
  var labels = ["500","1,000","5,000","10,000","50,000"];
  var hardFrac = 0.15;

  var strats = [
    { name:"Standard prompting", desc:"Direct classification. No reasoning.", cpt:0.000095, tpt:0.3, ae:0.94, ah:0.62 },
    { name:"Chain-of-thought", desc:"\"Think step by step\" on every tweet.", cpt:0.00025, tpt:0.8, ae:0.95, ah:0.74 },
    { name:"Reasoning model", desc:"Dedicated reasoning model on every tweet.", cpt:0.0032, tpt:3.0, ae:0.96, ah:0.85 },
    { name:"Hybrid", desc:"Standard first, reasoning only on uncertain ~15%.", hybrid:true, ae:0.94, ah:0.83 }
  ];

  function getCost(si,n){if(strats[si].hybrid)return n*(1-hardFrac)*0.000095+n*hardFrac*0.0032;return strats[si].cpt*n;}
  function getTime(si,n){if(strats[si].hybrid)return n*(1-hardFrac)*0.3+n*hardFrac*3.0;return strats[si].tpt*n;}
  function getAcc(si){return strats[si].ae*(1-hardFrac)+strats[si].ah*hardFrac;}
  function fmtCost(c){if(c<0.01)return"<$0.01";if(c<10)return"$"+c.toFixed(2);return"$"+Math.round(c);}
  function fmtTime(s){if(s<60)return Math.round(s)+"s";if(s<3600)return Math.round(s/60)+" min";return(s/3600).toFixed(1)+" hr";}

  function render() {
    var sliderVal = root.querySelector("#ttc-slider") ? parseInt(root.querySelector("#ttc-slider").value,10) : 2;
    var n = sizes[sliderVal];

    var costs=[],times=[],accs=[];
    for(var i=0;i<4;i++){costs.push(getCost(i,n));times.push(getTime(i,n));accs.push(getAcc(i));}
    var maxC=Math.max.apply(null,costs),maxT=Math.max.apply(null,times);

    var html='<div class="widget-wrap">';
    html+='<div class="widget-eyebrow">Interactive visualisation</div>';
    html+='<div class="widget-title">The Cost of Thinking</div>';
    html+='<p class="widget-intro">Reasoning improves accuracy on hard cases but costs more. Drag the slider to change corpus size and compare four strategies.</p>';

    // Scenario
    html+='<div style="background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);border-radius:12px;padding:1.25rem;margin-bottom:1.75rem;">';
    html+='<div style="font-size:0.82rem;font-weight:600;color:var(--text,#1A1D27);margin-bottom:0.35rem;">Scenario: stance classification on political tweets</div>';
    html+='<div style="font-size:0.82rem;color:var(--text-muted,#6B7280);margin-bottom:1rem;">Binary classification. ~15% of tweets are ambiguous. The rest are clear-cut.</div>';
    html+='<div style="display:flex;align-items:center;gap:1rem;">';
    html+='<div style="font-size:0.82rem;font-weight:600;color:var(--text,#1A1D27);white-space:nowrap;min-width:6.5rem;">Corpus: <span style="font-family:var(--font-mono,monospace);color:var(--accent,#2D8ABF);">'+labels[sliderVal]+'</span></div>';
    html+='<input type="range" id="ttc-slider" min="0" max="4" value="'+sliderVal+'" step="1" style="flex:1;-webkit-appearance:none;height:5px;border-radius:3px;background:var(--border,#E2E6EE);outline:none;cursor:pointer;">';
    html+='</div>';
    html+='<div style="display:flex;justify-content:space-between;padding-left:7.5rem;margin-top:0.3rem;">';
    for(var m=0;m<labels.length;m++)html+='<span style="font-family:var(--font-mono,monospace);font-size:0.65rem;color:var(--text-muted,#6B7280);">'+labels[m]+'</span>';
    html+='</div></div>';

    // Cards
    html+='<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">';
    for(var s=0;s<4;s++){
      var isBest=s===3;
      html+='<div style="background:var(--surface,#FFF);border:1.5px solid '+(isBest?'#2D7D46':'var(--border,#E2E6EE)')+';border-radius:12px;padding:1.1rem 1.15rem;position:relative;'+(isBest?'box-shadow:0 0 0 1px #B8DBBD;':'')+'">';
      if(isBest)html+='<div style="position:absolute;top:-0.55rem;right:0.75rem;font-family:var(--font-mono,monospace);font-size:0.6rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#2D7D46;background:#EDF7F0;border:1px solid #B8DBBD;padding:0.1rem 0.5rem;border-radius:3px;">Best tradeoff</div>';
      html+='<div style="font-size:0.9rem;font-weight:700;color:var(--text,#1A1D27);margin-bottom:0.15rem;">'+strats[s].name+'</div>';
      html+='<div style="font-size:0.75rem;color:var(--text-muted,#6B7280);margin-bottom:0.9rem;line-height:1.45;">'+strats[s].desc+'</div>';

      // Metrics
      var metrics=[
        {icon:"$",label:"Cost",val:fmtCost(costs[s]),pct:maxC>0?costs[s]/maxC*100:0,color:"#9E3A38"},
        {icon:"\u23F1",label:"Time",val:fmtTime(times[s]),pct:maxT>0?times[s]/maxT*100:0,color:"#8B6914"},
        {icon:"\u2713",label:"Accuracy",val:(accs[s]*100).toFixed(1)+"%",pct:Math.max(0,Math.min(100,(accs[s]-0.80)/0.20*100)),color:"#2D7D46"}
      ];
      for(var mi=0;mi<metrics.length;mi++){
        var mt=metrics[mi];
        html+='<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">';
        html+='<div style="width:1rem;text-align:center;font-size:0.75rem;">'+mt.icon+'</div>';
        html+='<div style="font-size:0.75rem;color:var(--text-muted,#6B7280);width:4rem;flex-shrink:0;">'+mt.label+'</div>';
        html+='<div style="flex:1;height:6px;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);border-radius:3px;overflow:hidden;"><div style="height:100%;border-radius:3px;background:'+mt.color+';width:'+mt.pct+'%;transition:width 0.5s ease;"></div></div>';
        html+='<div style="font-family:var(--font-mono,monospace);font-size:0.75rem;font-weight:600;min-width:3.5rem;text-align:right;color:'+mt.color+';">'+mt.val+'</div>';
        html+='</div>';
      }
      html+='</div>';
    }
    html+='</div>';

    // Insight
    var rc=costs[2],hc=costs[3],sc=costs[0],mult=Math.round(rc/sc);
    var insightText="";
    if(n<=500)insightText='<strong>At small scale, cost differences are negligible.</strong> Even the reasoning model costs under $2. Use whatever gives the best accuracy.';
    else if(n<=1000)insightText='<strong>Still affordable across all strategies.</strong> The reasoning model costs ~'+fmtCost(rc)+', roughly '+mult+'x standard. Focus on accuracy.';
    else if(n<=5000)insightText='<strong>The tradeoffs start to bite.</strong> Reasoning costs '+fmtCost(rc)+' while standard costs '+fmtCost(sc)+'. The hybrid gets most of the accuracy gain for '+fmtCost(hc)+'.';
    else if(n<=10000)insightText='<strong>Cost matters at this scale.</strong> Reasoning on all 10,000 tweets costs '+fmtCost(rc)+' and takes '+fmtTime(times[2])+'. The hybrid saves '+fmtCost(rc-hc)+' while sacrificing only 2 points on hard cases.';
    else insightText='<strong>At 50,000 tweets, strategy choice is a budget decision.</strong> Reasoning costs '+fmtCost(rc)+' and takes '+fmtTime(times[2])+'. That is '+mult+'x standard for a '+((accs[2]-accs[0])*100).toFixed(1)+'-point gain. The hybrid captures most of that for '+fmtCost(hc)+'.';
    html+='<div style="padding:0.85rem 1rem;border-left:3px solid var(--accent,#2D8ABF);background:var(--accent-light,#E8EEF6);border-radius:0 8px 8px 0;font-size:0.85rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:1.5rem;">'+insightText+'</div>';

    // When to use what
    html+='<div style="background:var(--surface,#FFF);border:1.5px solid var(--accent,#2D8ABF);border-radius:12px;padding:1.25rem;">';
    html+='<div style="font-family:var(--font-display,serif);font-size:1rem;font-weight:700;color:var(--accent,#2D8ABF);margin-bottom:0.5rem;">When to use each strategy</div>';
    html+='<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Standard prompting:</strong> right default for clear-cut tasks.</p>';
    html+='<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Chain-of-thought:</strong> worth testing during development. Use it if it improves validation accuracy.</p>';
    html+='<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Reasoning models:</strong> reserve for genuine analytical complexity (legal language, qualitative coding, domain expertise).</p>';
    html+='<p style="font-size:0.88rem;color:var(--text-sec,#3D4455);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text,#1A1D27);">Hybrid:</strong> the practical optimum. Standard model first, reasoning only on uncertain cases.</p>';
    html+='</div>';

    // Assumptions
    html+='<details style="margin-top:1rem;"><summary style="font-family:var(--font-mono,monospace);font-size:0.75rem;font-weight:500;color:var(--text-muted,#6B7280);cursor:pointer;padding:0.5rem 0;list-style:none;display:flex;align-items:center;gap:0.4rem;"><span style="font-size:0.7rem;transition:transform 0.25s ease;">&#9656;</span>Assumptions behind these estimates</summary>';
    html+='<div style="padding:0.75rem 0 0.25rem 0;font-size:0.78rem;color:var(--text-muted,#6B7280);line-height:1.6;">';
    html+='<p style="margin-bottom:0.5rem;">These numbers are <strong style="color:var(--text-sec,#3D4455);">illustrative, not authoritative</strong>. Based on typical mid-2025 API pricing. Standard models ~$0.50\u20131.50/M tokens; reasoning models ~$3\u201312/M tokens. Accuracy estimates based on published classification benchmarks. The 15% hard-case fraction is approximate for political text tasks with sarcasm and implicit stance.</p>';
    html+='<p>Check <a href="https://artificialanalysis.ai" target="_blank" rel="noopener" style="color:var(--accent,#2D8ABF);">Artificial Analysis</a> for current pricing before budgeting a project.</p>';
    html+='</div></details>';

    html+='</div>';
    root.innerHTML=html;

    root.querySelector("#ttc-slider").addEventListener("input", render);
  }

  render();
})();
</script>

<!-- 6. MODEL LANDSCAPE CHART -->
<script is:inline>
(function() {
  var svg = document.getElementById("model-landscape-svg");
  var insight = document.getElementById("model-landscape-insight");
  var explorer = document.getElementById("model-explorer");
  if (!svg || !explorer) return;

  var models = [
    { name: "Claude Opus 4.6", cap: 0.95, cost: 0.55, type: "closed" },
    { name: "Claude Sonnet 4.6", cap: 0.89, cost: 0.32, type: "closed" },
    { name: "GPT-5.4", cap: 0.94, cost: 0.38, type: "closed" },
    { name: "GPT-5.2", cap: 0.90, cost: 0.28, type: "closed" },
    { name: "Gemini 3.1 Pro", cap: 0.96, cost: 0.42, type: "closed" },
    { name: "Gemini 2.5 Flash", cap: 0.78, cost: 0.05, type: "closed" },
    { name: "DeepSeek V3.2", cap: 0.85, cost: 0.03, type: "open" },
    { name: "DeepSeek R1", cap: 0.88, cost: 0.16, type: "open" },
    { name: "Qwen 3.5", cap: 0.84, cost: 0.12, type: "open" },
    { name: "Llama 4 Maverick", cap: 0.80, cost: 0.06, type: "open" },
    { name: "Mistral Large", cap: 0.82, cost: 0.20, type: "open" },
    { name: "GLM-5", cap: 0.86, cost: 0.14, type: "open" }
  ];

  var filter = "all";

  /* Normalized axis ranges for plotting only (model cap/cost values unchanged). */
  var AXIS_COST_MIN = 0;
  var AXIS_COST_MAX = 0.62;
  var AXIS_CAP_MIN = 0.74;
  var AXIS_CAP_MAX = 1.0;

  function draw() {
    var pad = 60;
    var w = 520, h = 380;
    var plotL = pad + 10, plotR = w - 30;
    var plotT = 30, plotB = h - pad;
    var plotW = plotR - plotL, plotH = plotB - plotT;
    var costSpan = AXIS_COST_MAX - AXIS_COST_MIN;
    var capSpan = AXIS_CAP_MAX - AXIS_CAP_MIN;
    function xCost(c) {
      return plotL + (c - AXIS_COST_MIN) / costSpan * plotW;
    }
    function yCap(cap) {
      return plotB - (cap - AXIS_CAP_MIN) / capSpan * plotH;
    }
    var costMid = (AXIS_COST_MIN + AXIS_COST_MAX) / 2;
    var s = "";

    s += '<rect x="' + plotL + '" y="' + plotT + '" width="' + plotW + '" height="' + plotH + '" rx="4" style="fill:var(--surface,#F2F4F8);stroke:var(--border,#E2E6EE);"/>';

    for (var g = 0.2; g <= 0.8; g += 0.2) {
      var gy = plotB - g * plotH;
      s += '<line x1="' + plotL + '" y1="' + gy + '" x2="' + plotR + '" y2="' + gy + '" style="stroke:var(--border-lt,#EAEEF4);" stroke-width="0.5"/>';
      var gx = plotL + g * plotW;
      s += '<line x1="' + gx + '" y1="' + plotT + '" x2="' + gx + '" y2="' + plotB + '" style="stroke:var(--border-lt,#EAEEF4);" stroke-width="0.5"/>';
    }

    s += '<text x="' + (plotL + plotW / 2) + '" y="' + (h - 8) + '" text-anchor="middle" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="11" font-weight="600">Relative Cost (low \u2192 high)</text>';
    s += '<text x="14" y="' + (plotT + plotH / 2) + '" text-anchor="middle" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="11" font-weight="600" transform="rotate(-90,14,' + (plotT + plotH / 2) + ')">Approximate Capability \u2192</text>';
    s += '<text x="' + plotL + '" y="' + (plotB + 16) + '" text-anchor="middle" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="9">Low</text>';
    s += '<text x="' + plotR + '" y="' + (plotB + 16) + '" text-anchor="middle" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="9">High</text>';

    s += '<circle cx="' + (plotR - 95) + '" cy="' + (plotT - 24) + '" r="5" style="fill:var(--accent,#2D8ABF);" opacity="0.85"/>';
    s += '<text x="' + (plotR - 85) + '" y="' + (plotT - 20) + '" style="fill:var(--text-sec,#3D4455);font-family:var(--font-body);" font-size="9">Closed-weight</text>';
    s += '<circle cx="' + (plotR - 95) + '" cy="' + (plotT - 12) + '" r="5" style="fill:var(--accent-dark,#1E5A8A);" opacity="0.85"/>';
    s += '<text x="' + (plotR - 85) + '" y="' + (plotT - 8) + '" style="fill:var(--text-sec,#3D4455);font-family:var(--font-body);" font-size="9">Open-weight</text>';

    var filtered = models.filter(function(m) {
      if (filter === "all") return true;
      return m.type === filter;
    });

    var frontier = filtered.slice().sort(function(a, b) { return a.cost - b.cost; });
    var paretoPoints = [];
    var bestCap = -1;
    for (var fi = 0; fi < frontier.length; fi++) {
      if (frontier[fi].cap > bestCap) {
        bestCap = frontier[fi].cap;
        paretoPoints.push(frontier[fi]);
      }
    }
    if (paretoPoints.length > 1) {
      var fp = "";
      for (var pi = 0; pi < paretoPoints.length; pi++) {
        var fpx = xCost(paretoPoints[pi].cost);
        var fpy = yCap(paretoPoints[pi].cap);
        fp += (pi === 0 ? "M" : "L") + fpx + "," + fpy;
      }
      s += '<path d="' + fp + '" fill="none" style="stroke:var(--accent,#2D8ABF);" stroke-width="1.5" stroke-dasharray="6,4" opacity="0.5"/>';
      s += '<text x="' + (xCost(paretoPoints[0].cost) + 4) + '" y="' + (yCap(paretoPoints[0].cap) + 16) + '" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="8" font-style="italic">cost-capability frontier</text>';
    }

    var labels = [];
    for (var i = 0; i < filtered.length; i++) {
      var m = filtered[i];
      var px = xCost(m.cost);
      var py = yCap(m.cap);
      var color = m.type === "closed" ? "var(--accent,#2D8ABF)" : "var(--accent-dark,#1E5A8A)";
      s += '<circle cx="' + px + '" cy="' + py + '" r="5.5" style="fill:' + color + ';" opacity="0.85"/>';
      var anchor = m.cost > costMid ? "end" : "start";
      var lx = anchor === "start" ? px + 9 : px - 9;
      var ly = py - 8;
      labels.push({ x: lx, y: ly, a: anchor, t: m.name });
    }

    for (var k = 0; k < labels.length; k++) {
      for (var j = 0; j < k; j++) {
        if (Math.abs(labels[k].x - labels[j].x) < 60 && Math.abs(labels[k].y - labels[j].y) < 12) {
          labels[k].y = labels[k].y > labels[j].y ? labels[j].y + 13 : labels[j].y - 13;
        }
      }
    }

    for (var q = 0; q < labels.length; q++) {
      var lb = labels[q];
      s += '<text x="' + lb.x + '" y="' + lb.y + '" text-anchor="' + lb.a + '" style="fill:var(--text-sec,#3D4455);font-family:var(--font-body);" font-size="9">' + lb.t + '</text>';
    }

    svg.innerHTML = s;
  }

  var filterMap = ["all", "open", "closed"];
  var btns = explorer.querySelectorAll(".attention-explorer__sentence-btn");
  btns.forEach(function(btn, i) {
    btn.addEventListener("click", function() {
      btns.forEach(function(b, j) {
        b.classList.toggle("attention-explorer__sentence-btn--active", j === i);
      });
      filter = filterMap[i];
      draw();
      var msgs = [
        "Approximate positions based on public benchmarks and API pricing as of early 2026. Capability reflects a composite of Chatbot Arena, MMLU, and coding benchmarks. The dashed line marks the cost-capability frontier. Note the cluster of open-weight models in the low-cost, high-capability region. Verify current data before making decisions.",
        "Open-weight models: weights are publicly available. You can run them locally, inspect them, and guarantee reproducibility. DeepSeek V3.2 and Llama 4 Maverick offer strong capability at very low API cost. Self-hosting makes costs even lower at scale.",
        "Closed-weight models: accessible only via API. The frontier models lead on the hardest tasks, but open models have closed much of the gap. Costs per token and model versions can change without notice."
      ];
      insight.textContent = msgs[i];
    });
  });

  draw();
})();
</script>

