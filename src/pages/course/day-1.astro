        <!-- Arrow -->
        <line x1="213" y1="35" x2="231" y2="35" style="stroke: var(--text-dim, #9CA3AF);" stroke-width="1.5" marker-end="url(#arrUE)"/>
        <!-- Box 3: W_U -->
        <rect x="232" y="18" width="82" height="34" rx="5" style="fill: var(--surface, #F2F4F8); stroke: var(--border, #E2E6EE);" stroke-width="1.5"/>
        <text x="273" y="33" text-anchor="middle" style="fill: var(--text-sec, #3D4455);" font-weight="600" font-size="10"><tspan font-style="italic">W</tspan><tspan font-size="8" dy="3">U</tspan></text>
        <text x="273" y="47" text-anchor="middle" style="fill: var(--text-muted, #6B7280);" font-size="9">unembedding</text>
