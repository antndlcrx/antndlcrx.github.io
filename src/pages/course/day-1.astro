<script is:inline>
(function() {
  var root = document.getElementById("attn-stepper");
  if (!root) return;

  var TOKENS = ["I", "sat", "by", "the", "river", "bank"];
  var N = TOKENS.length;
  var D = 4;
  var EMB = [
    [ 1.5,  0.2, -0.6,  0.1],
    [ 0.3,  1.5, -0.2,  0.1],
    [-0.3,  0.1,  0.2,  1.3],
    [-0.1, -0.2,  0.3,  1.4],
    [-0.5,  0.4,  1.5, -0.1],
    [ 0.2,  0.5,  0.6,  0.7]
  ];
  var WQ = [[0.6,1.8,-0.4,0.2],[1.6,0.2,0.6,-0.6],[0.3,0.6,1.2,0.8],[0.2,-0.6,1.8,0.4]];
  var WK = [[1.8,-0.2,0.4,0.0],[-0.2,1.6,0.2,0.4],[0.2,0.4,1.8,0.0],[0.0,0.6,-0.2,1.6]];
  var WV = [[0.5,0.3,0.0,-0.2],[0.2,0.6,-0.1,0.3],[-0.3,0.1,0.7,0.2],[0.4,-0.2,0.2,0.5]];

  function matVec(M,v) {
    return M.map(function(r){var s=0;for(var i=0;i<r.length;i++)s+=r[i]*v[i];return s});
  }
  function dot(a,b){var s=0;for(var i=0;i<a.length;i++)s+=a[i]*b[i];return s}
  function softmax(a) {
    var mx=-Infinity;for(var i=0;i<a.length;i++)if(a[i]>mx)mx=a[i];
    var ex=a.map(function(x){return Math.exp(x-mx)});var sm=0;
    for(var i=0;i<ex.length;i++)sm+=ex[i];return ex.map(function(e){return e/sm});
  }

  var QV=EMB.map(function(e){return matVec(WQ,e)});
  var KV=EMB.map(function(e){return matVec(WK,e)});
  var VV=EMB.map(function(e){return matVec(WV,e)});

  /* Brand-aligned diverging color scale:
     v=0 → #F2F4F8 (--surface), v>0 → #1E5A8A (--blue-1), v<0 → #D4854A (amber) */
  function hc(v) {
    var t=Math.min(Math.abs(v)/1.6,1);
    var r0=242,g0=244,b0=248;
    var r1,g1,b1;
    if(v>=0){r1=30;g1=90;b1=138;}
    else    {r1=212;g1=133;b1=74;}
    return 'rgb('+Math.round(r0+(r1-r0)*t)+','+Math.round(g0+(g1-g0)*t)+','+Math.round(b0+(b1-b0)*t)+')';
  }
  function strip(vec, cls) {
    var s='<span class="attn-hstrip'+(cls?' '+cls:'')+'">';
    for(var i=0;i<vec.length;i++)
      s+='<span class="attn-hcell" style="background:'+hc(vec[i])+'" title="'+vec[i].toFixed(2)+'"></span>';
    return s+'</span>';
  }

  var curStep=0, selToken=5, TOTAL=3;

  var stepLabel=document.getElementById("attn-step-label");
  var formulaEl=document.getElementById("attn-step-formula");
  var tokensEl =document.getElementById("attn-step-tokens");
  var vizEl    =document.getElementById("attn-step-viz");
  var infoEl   =document.getElementById("attn-step-info");
  var prevBtn  =document.getElementById("attn-prev");
  var nextBtn  =document.getElementById("attn-next");
  var counterEl=document.getElementById("attn-counter");

  var STEPS=[
    {
      label:"Embedding vectors",
      formula:'<var>x</var><sub><var>i</var></sub> &isin; \u211D<sup><var>d</var></sup>',
      info:'Each token is mapped to a learned embedding vector (<var>d</var>\u00a0=\u00a04 here). Colors encode value\u00a0\u2014 blue\u00a0=\u00a0positive, amber\u00a0=\u00a0negative. Hover a cell to see the exact number.'
    },
    {
      label:"Q, K, V projections",
      formula:'<var class="fc-q">q</var><sub><var>i</var></sub> = <var>x</var><sub><var>i</var></sub><var>W</var><sub>Q</sub> &nbsp;&nbsp; <var class="fc-k">k</var><sub><var>i</var></sub> = <var>x</var><sub><var>i</var></sub><var>W</var><sub>K</sub> &nbsp;&nbsp; <var class="fc-v">v</var><sub><var>i</var></sub> = <var>x</var><sub><var>i</var></sub><var>W</var><sub>V</sub>',
      info:'Three learned projection matrices transform each embedding into a <span class="fc-q">Query</span>, <span class="fc-k">Key</span>, and <span class="fc-v">Value</span>. The same blue\u2013amber color scale applies.'
    },
    {
      label:"Attention scores",
      formula:'&alpha;<sub><var>i,j</var></sub> = softmax<sub><var>j\u2264i</var></sub>\u2009(\u2009<var class="fc-q">q</var><sub><var>i</var></sub> \u00b7 <var class="fc-k">k</var><sub><var>j</var></sub> / &radic;<var>d<sub>k</sub></var>\u2009)',
      info:'Click any row in the matrix to select a <span class="fc-q">query</span> token. The trace shows how each accessible <span class="fc-k">K</span> vector is scored against that query\u2019s <span class="fc-q">Q</span>. Future positions (\u2715) are masked \u2014 causal attention only reads the past.'
    },
    {
      label:"Contextual output",
      formula:'output<sub><var>i</var></sub> = &Sigma;<sub><var>j\u2264i</var></sub> &alpha;<sub><var>i,j</var></sub> \u00b7 <var class="fc-v">v</var><sub><var>j</var></sub>',
      info:'The output is a weighted sum of accessible <span class="fc-v">V</span> vectors. High-weight rows contribute more. The original embedding shifts toward the context the model focused on.'
    }
  ];

  var insights=[
    "\u201cI\u201d attends only to itself (100\u202f%)\u2009\u2014\u2009the first token has no past context yet.",
    "\u201csat\u201d attends almost entirely to \u201cI\u201d (93\u202f%)\u2009\u2014\u2009the verb finds its subject with the limited context available.",
    "\u201cby\u201d attends most to itself (54\u202f%) and back to \u201cI\u201d (31\u202f%)\u2009\u2014\u2009a preposition anchoring to the start of the clause.",
    "\u201cthe\u201d attends most to itself (46\u202f%) and \u201cby\u201d (38\u202f%)\u2009\u2014\u2009it has not yet seen \u201criver,\u201d showing how articles remain ambiguous mid-sequence.",
    "\u201criver\u201d attends most to \u201cby\u201d (34\u202f%) and \u201cthe\u201d (32\u202f%)\u2009\u2014\u2009the noun integrates its article and preposition as context accumulates.",
    "\u201cbank\u201d attends most to \u201criver\u201d (46\u202f%)\u2009\u2014\u2009seeing the full sequence, context resolves the meaning as a river bank."
  ];

  /* Pre-compute all row weights (causal masked) */
  var allWeights=[];
  for(var qi=0;qi<N;qi++){
    var sc=[];
    for(var j=0;j<N;j++){
      if(j>qi) sc.push(-1/0);
      else sc.push(dot(QV[qi],KV[j])/Math.sqrt(D));
    }
    allWeights.push(softmax(sc));
  }

  /* Build the 6×6 attention heatmap SVG */
  function buildSingleHeatmap(selRow){
    var cs=22,gap=2,pad=40;
    var gw=N*(cs+gap)-gap;
    var svgW=gw+pad+4, svgH=gw+pad+4;
    var s='<svg viewBox="0 0 '+svgW+' '+svgH+'" width="'+svgW+'" height="'+svgH+'" xmlns="http://www.w3.org/2000/svg" style="font-family:\'JetBrains Mono\',monospace;font-size:9px;display:block;margin:0 auto;cursor:pointer">';
    s+='<g transform="translate('+pad+','+pad+')">';
    s+='<text x="-4" y="-8" text-anchor="end" fill="#6B7280" font-size="7">Query \u2193</text>';
    s+='<text x="'+(gw/2)+'" y="-18" text-anchor="middle" fill="#6B7280" font-size="7">Key \u2192</text>';
    for(var j=0;j<N;j++){
      s+='<text x="'+(j*(cs+gap)+cs/2)+'" y="-4" text-anchor="middle" fill="#9CA3AF">'+TOKENS[j]+'</text>';
    }
    for(var i=0;i<N;i++){
      s+='<text x="-4" y="'+(i*(cs+gap)+cs/2+4)+'" text-anchor="end" fill="#9CA3AF">'+TOKENS[i]+'</text>';
    }
    for(var i=0;i<N;i++){
      for(var j=0;j<N;j++){
        var x=j*(cs+gap), y=i*(cs+gap);
        var sk=(i===selRow)?' stroke="#1E5A8A" stroke-width="1.5"':'';
        if(j>i){
          s+='<rect x="'+x+'" y="'+y+'" width="'+cs+'" height="'+cs+'" rx="2" fill="#F2F4F8"'+sk+' data-row="'+i+'"/>';
          s+='<line x1="'+(x+4)+'" y1="'+(y+4)+'" x2="'+(x+cs-4)+'" y2="'+(y+cs-4)+'" stroke="#CBD5E0" stroke-width="1"/>';
          s+='<line x1="'+(x+cs-4)+'" y1="'+(y+4)+'" x2="'+(x+4)+'" y2="'+(y+cs-4)+'" stroke="#CBD5E0" stroke-width="1"/>';
        } else {
          var w=allWeights[i][j];
          var op=(0.07+w*0.93).toFixed(2);
          s+='<rect class="attn-hcell-svg" x="'+x+'" y="'+y+'" width="'+cs+'" height="'+cs+'" rx="2" fill="#2D8ABF" opacity="'+op+'"'+sk+' data-row="'+i+'" data-col="'+j+'" data-val="'+(w*100).toFixed(1)+'"/>';
        }
      }
    }
    s+='</g></svg>';
    return s;
  }

  /* Build the QK computation trace panel */
  function buildTrace(qi){
    var w=allWeights[qi];
    var maxW=0; for(var j=0;j<=qi;j++) if(w[j]>maxW) maxW=w[j];
    var h='<div class="attn-trace">';
    h+='<div class="attn-trace__query-row">';
    h+='<span class="attn-trace__query-label">Query: \u201c'+TOKENS[qi]+'\u201d</span>';
    h+=strip(QV[qi],'attn-hstrip--q');
    h+='</div>';
    for(var j=0;j<N;j++){
      if(j>qi){
        h+='<div class="attn-trace__row attn-trace__row--masked">';
        h+='<span class="attn-trace__tok">'+TOKENS[j]+'</span>';
        h+='<span class="attn-trace__mask-label">\u2715\u00a0masked</span>';
        h+='</div>';
      } else {
        var isMax=(Math.abs(w[j]-maxW)<1e-9);
        var raw=(dot(QV[qi],KV[j])/Math.sqrt(D)).toFixed(2);
        h+='<div class="attn-trace__row'+(isMax?' attn-trace__row--max':'')+'">';
        h+='<span class="attn-trace__tok">'+TOKENS[j]+'</span>';
        h+=strip(KV[j],'attn-hstrip--k');
        h+='<span class="attn-trace__score">= '+raw+'</span>';
        h+='<span class="attn-trace__arrow">\u2192</span>';
        h+='<span class="attn-trace__weight'+(isMax?' attn-trace__weight--max':'')+'">'+Math.round(w[j]*100)+'%</span>';
        h+='</div>';
      }
    }
    h+='</div>';
    return h;
  }

  /* Build the weighted V sum display for Step 4 */
  function buildVSum(qi){
    var w=allWeights[qi];
    var maxW=0; for(var j=0;j<=qi;j++) if(w[j]>maxW) maxW=w[j];
    var out=[0,0,0,0];
    for(var j=0;j<=qi;j++) for(var d=0;d<D;d++) out[d]+=w[j]*VV[j][d];

    var h='<div class="attn-vsum">';
    for(var j=0;j<=qi;j++){
      var isMax=(Math.abs(w[j]-maxW)<1e-9);
      h+='<div class="attn-vsum__row'+(isMax?' attn-vsum__row--max':'')+'">';
      h+='<span class="attn-vsum__pct">'+Math.round(w[j]*100)+'%</span>';
      h+='<span class="attn-vsum__x">\u00d7</span>';
      h+=strip(VV[j],'attn-hstrip--v');
      h+='<span class="attn-vsum__tok">'+TOKENS[j]+'</span>';
      h+='</div>';
    }
    h+='<hr class="attn-vsum__divider">';
    h+='<div class="attn-vsum__output-row">';
    h+='<span class="attn-vsum__output-label">output<sub>\u201c'+TOKENS[qi]+'\u201d</sub></span>';
    h+='<span class="attn-vsum__eq">=</span>';
    h+=strip(out);
    h+='</div>';
    h+='</div>';

    h+='<div class="attn-compare">';
    h+='<div class="attn-compare__side">';
    h+='<span class="attn-compare__label">Original embedding</span>';
    h+=strip(EMB[qi]);
    h+='</div>';
    h+='<span class="attn-compare__arrow">\u2192</span>';
    h+='<div class="attn-compare__side">';
    h+='<span class="attn-compare__label">Contextual output</span>';
    h+=strip(out);
    h+='</div>';
    h+='</div>';
    return h;
  }

  function render(){
    var s=STEPS[curStep];
    stepLabel.textContent=s.label;
    counterEl.textContent=(curStep+1)+' / '+(TOTAL+1);
    prevBtn.disabled=(curStep===0);
    nextBtn.disabled=(curStep>=TOTAL);
    nextBtn.textContent=(curStep>=TOTAL)?'Done \u2713':'Next step \u2192';
    formulaEl.innerHTML=s.formula;

    /* ── Token area ── */
    var th='';
    if(curStep<=1){
      /* Full chips with vector strips */
      for(var i=0;i<N;i++){
        th+='<span class="attn-chip" data-idx="'+i+'">';
        th+='<span class="attn-chip__word">'+TOKENS[i]+'</span>';
        th+=strip(EMB[i],'attn-hstrip--emb');
        if(curStep>=1){
          th+='<span class="attn-qkv-row"><span class="attn-qkv-tag fc-q">q</span>'+strip(QV[i],'attn-hstrip--q')+'</span>';
          th+='<span class="attn-qkv-row"><span class="attn-qkv-tag fc-k">k</span>'+strip(KV[i],'attn-hstrip--k')+'</span>';
          th+='<span class="attn-qkv-row"><span class="attn-qkv-tag fc-v">v</span>'+strip(VV[i],'attn-hstrip--v')+'</span>';
        }
        th+='</span>';
      }
    } else {
      /* Compact token selector row */
      th='<div class="attn-token-selector">';
      for(var i=0;i<N;i++){
        th+='<span class="attn-token-btn'+(i===selToken?' attn-token-btn--active':'')+'" data-idx="'+i+'">'+TOKENS[i]+'</span>';
      }
      th+='</div>';
    }
    tokensEl.innerHTML=th;

    if(curStep>=2){
      tokensEl.querySelectorAll('[data-idx]').forEach(function(el){
        el.addEventListener('click',function(){
          selToken=parseInt(this.getAttribute('data-idx'));
          render();
        });
      });
    }

    /* ── Viz area ── */
    var vh='';
    if(curStep===2){
      vh+='<div class="attn-matrix-wrap">';
      vh+='<div class="attn-heatmap-svg-wrap" id="attn-heatmap-svg">'+buildSingleHeatmap(selToken)+'</div>';
      vh+=buildTrace(selToken);
      vh+='</div>';
      vh+='<p class="attn-insight">'+insights[selToken]+'</p>';
    }
    if(curStep===3){
      vh+=buildVSum(selToken);
    }

    vizEl.innerHTML=vh;
    vizEl.style.display=vh?'':'none';
    infoEl.innerHTML=s.info;

    /* Attach SVG cell click/hover handlers for Step 3 */
    if(curStep===2){
      var svgWrap=document.getElementById('attn-heatmap-svg');
      if(svgWrap){
        svgWrap.querySelectorAll('rect[data-row]').forEach(function(cell){
          cell.addEventListener('click',function(){
            selToken=parseInt(this.getAttribute('data-row'));
            render();
          });
        });
        svgWrap.querySelectorAll('.attn-hcell-svg').forEach(function(cell){
          cell.addEventListener('mouseenter',function(e){
            var val=this.getAttribute('data-val');
            var row=parseInt(this.getAttribute('data-row'));
            var col=parseInt(this.getAttribute('data-col'));
            var tip=document.createElement('div');
            tip.className='mh-tooltip';
            tip.textContent=TOKENS[row]+' \u2192 '+TOKENS[col]+': '+val+'%';
            var rect=this.getBoundingClientRect();
            var pRect=vizEl.getBoundingClientRect();
            tip.style.left=(rect.left-pRect.left+rect.width/2)+'px';
            tip.style.top=(rect.top-pRect.top-28)+'px';
            tip.style.transform='translateX(-50%)';
            tip.id='attn-tip';
            vizEl.appendChild(tip);
          });
          cell.addEventListener('mouseleave',function(){
            var t=document.getElementById('attn-tip');
            if(t) t.remove();
          });
        });
      }
    }
  }

  prevBtn.addEventListener('click',function(){if(curStep>0){curStep--;render()}});
  nextBtn.addEventListener('click',function(){if(curStep<TOTAL){curStep++;render()}});
  render();
})();
</script>

<!-- Multi-head attention interactive heatmaps (same embeddings + math as single-head widget) -->
<script is:inline>
(function() {
  var vizRoot = document.getElementById("mh-viz");
  if (!vizRoot) return;

  var TOKENS = ["I", "sat", "by", "the", "river", "bank"];
  var N = TOKENS.length;
  var D = 4;

  var EMB = [
    [ 1.5,  0.2, -0.6,  0.1],
    [ 0.3,  1.5, -0.2,  0.1],
    [-0.3,  0.1,  0.2,  1.3],
    [-0.1, -0.2,  0.3,  1.4],
    [-0.5,  0.4,  1.5, -0.1],
    [ 0.2,  0.5,  0.6,  0.7]
  ];

  /* Heatstrip colors — matches single-head attn-stepper hc() */
  function hc(v) {
    var t=Math.min(Math.abs(v)/1.6,1);
    var r0=242,g0=244,b0=248;
    var r1,g1,b1;
    if(v>=0){r1=30;g1=90;b1=138;}
    else    {r1=212;g1=133;b1=74;}
    return 'rgb('+Math.round(r0+(r1-r0)*t)+','+Math.round(g0+(g1-g0)*t)+','+Math.round(b0+(b1-b0)*t)+')';
  }
  function vecStrip(vec, outlineColor) {
    var s = '<span class="attn-hstrip mh-concat-vec-strip"';
    if (outlineColor) s += ' style="outline:1.5px solid ' + outlineColor + ';outline-offset:0"';
    s += ">";
    for (var i = 0; i < vec.length; i++) {
      s += '<span class="attn-hcell" style="background:' + hc(vec[i]) + '" title="' + vec[i].toFixed(2) + '"></span>';
    }
    return s + "</span>";
  }

  var HEADS = [
    {
      color: "#5B8DEF",
      WQ: [[0.4,2.0,-0.2,0.1],[2.0,0.3,0.1,-0.2],[0.1,-0.3,0.5,1.8],[0.2,-0.4,1.0,1.5]],
      WK: [[2.0,0.2,-0.1,0.0],[0.1,1.8,0.0,0.3],[0.0,0.2,1.0,0.3],[0.1,0.4,0.2,1.8]],
      WV: [[0.5,0.3,0.0,-0.2],[0.2,0.6,-0.1,0.3],[-0.3,0.1,0.7,0.2],[0.4,-0.2,0.2,0.5]]
    },
    {
      color: "#E88D4F",
      WQ: [[0.6,1.8,-0.4,0.2],[1.6,0.2,0.6,-0.6],[0.3,0.6,1.2,0.8],[0.2,-0.6,1.8,0.4]],
      WK: [[1.8,-0.2,0.4,0.0],[-0.2,1.6,0.2,0.4],[0.2,0.4,1.8,0.0],[0.0,0.6,-0.2,1.6]],
      WV: [[0.5,0.3,0.0,-0.2],[0.2,0.6,-0.1,0.3],[-0.3,0.1,0.7,0.2],[0.4,-0.2,0.2,0.5]]
    },
    {
      color: "#58B589",
      WQ: [[0.3,0.2,1.0,1.2],[0.2,0.3,1.2,1.0],[1.2,1.0,0.3,0.2],[1.0,1.2,0.2,0.3]],
      WK: [[1.0,1.2,0.3,0.2],[1.2,1.0,0.2,0.3],[0.3,0.2,1.0,1.2],[0.2,0.3,1.2,1.0]],
      WV: [[0.4,0.2,0.3,-0.1],[0.1,0.5,0.0,0.2],[-0.2,0.0,0.6,0.3],[0.3,-0.1,0.1,0.5]]
    }
  ];

  function matVec(M, v) {
    return M.map(function(row) {
      var s = 0; for (var i = 0; i < row.length; i++) s += row[i] * v[i]; return s;
    });
  }
  function dot(a, b) { var s = 0; for (var i = 0; i < a.length; i++) s += a[i] * b[i]; return s; }
  function softmax(arr) {
    var mx = -Infinity; for (var i = 0; i < arr.length; i++) if (arr[i] > mx) mx = arr[i];
    var exps = arr.map(function(x) { return Math.exp(x - mx); });
    var sm = 0; for (var i = 0; i < exps.length; i++) sm += exps[i];
    return exps.map(function(e) { return e / sm; });
  }

  var headData = HEADS.map(function(hd) {
    var Qs = EMB.map(function(e) { return matVec(hd.WQ, e); });
    var Ks = EMB.map(function(e) { return matVec(hd.WK, e); });
    var Vs = EMB.map(function(e) { return matVec(hd.WV, e); });
    var weights = [];
    for (var i = 0; i < N; i++) {
      var sc = [];
      for (var j = 0; j < N; j++) {
        if (j > i) sc.push(-1/0);
        else sc.push(dot(Qs[i], Ks[j]) / Math.sqrt(D));
      }
      weights.push(softmax(sc));
    }
    var outputs = [];
    for (var i = 0; i < N; i++) {
      var out = [0,0,0,0];
      for (var j = 0; j < N; j++) for (var d = 0; d < D; d++) out[d] += weights[i][j] * Vs[j][d];
      outputs.push(out);
    }
    return { weights: weights, outputs: outputs, color: hd.color };
  });

  var activeRow = null;

  var HEAD_TITLES = [
    "Head 1: Syntactic",
    "Head 2: Semantic",
    "Head 3: Broad Context"
  ];

  function toyWoOutput(row) {
    var out = [0, 0, 0, 0];
    for (var d = 0; d < D; d++) {
      for (var h = 0; h < headData.length; h++) out[d] += headData[h].outputs[row][d];
      out[d] /= headData.length;
    }
    return out;
  }

  function buildHeatmap(headIdx) {
    var hd = headData[headIdx];
    var cellSize = 22, gap = 2, pad = 40;
    var gridW = N * (cellSize + gap) - gap;
    var svgW = gridW + pad + 4;
    var svgH = gridW + pad + 4;

    var svg = '<svg viewBox="0 0 ' + svgW + " " + svgH + '" width="' + svgW + '" height="' + svgH + '" xmlns="http://www.w3.org/2000/svg" style="font-family:\'JetBrains Mono\',monospace;font-size:9px;display:block;margin:0 auto">';
    svg += '<g transform="translate(' + pad + "," + pad + ')">';
    svg += '<text x="-4" y="-8" text-anchor="end" fill="#6B7280" font-size="7">Query &#x2193;</text>';
    svg += '<text x="' + (gridW / 2) + '" y="-18" text-anchor="middle" fill="#6B7280" font-size="7">Key &#x2192;</text>';

    for (var j = 0; j < N; j++) {
      var cx = j * (cellSize + gap) + cellSize / 2;
      svg += '<text x="' + cx + '" y="-4" text-anchor="middle" fill="#9CA3AF">' + TOKENS[j] + "</text>";
    }
    for (var i = 0; i < N; i++) {
      var cy = i * (cellSize + gap) + cellSize / 2 + 4;
      svg += '<text x="-4" y="' + cy + '" text-anchor="end" fill="#9CA3AF">' + TOKENS[i] + "</text>";
    }

    for (var i = 0; i < N; i++) {
      for (var j = 0; j < N; j++) {
        var w = hd.weights[i][j];
        var x = j * (cellSize + gap);
        var y = i * (cellSize + gap);
        var op = (0.08 + w * 0.92).toFixed(2);
        var strokeAttr = (activeRow === i) ? ' stroke="' + hd.color + '" stroke-width="1.5"' : "";
        svg += '<rect class="mh-heatmap__cell" x="' + x + '" y="' + y + '" width="' + cellSize + '" height="' + cellSize + '" rx="2" fill="' + hd.color + '" opacity="' + op + '"' + strokeAttr + ' data-head="' + headIdx + '" data-row="' + i + '" data-col="' + j + '" data-val="' + (w * 100).toFixed(1) + '"/>';
      }
    }
    svg += "</g></svg>";
    return svg;
  }

  function renderAll() {
    for (var h = 0; h < 3; h++) {
      document.getElementById("mh-svg-" + h).innerHTML = buildHeatmap(h);
    }
    attachEvents();
    renderConcat();
  }

  function renderConcat() {
    var panel = document.getElementById("mh-concat");
    if (!panel) return;
    if (activeRow === null) {
      panel.innerHTML =
        '<p class="mh-concat-panel__title">Select a query token</p>' +
        '<p class="mh-concat-panel__empty">Click any heatmap cell to pin that <strong>query row</strong> across all three heads. ' +
        "Below, each head&rsquo;s contextual output is shown as a <strong>heatmap strip</strong> (same encoding as the single-head stepper above; causal masking means earlier query rows have fewer non-zero bars), " +
        "followed by a toy merge back to 4-D.</p>";
      return;
    }
    var tk = TOKENS[activeRow];
    var merged = toyWoOutput(activeRow);

    var h = '<p class="mh-concat-panel__title">Contextual outputs for query &ldquo;' + tk + "&rdquo;</p>";
    h += '<div class="mh-concat-panel__heads">';
    for (var hi = 0; hi < 3; hi++) {
      var out = headData[hi].outputs[activeRow];
      h += '<div class="mh-concat-panel__head-row">';
      h += '<span class="mh-concat-panel__head-label" style="color:' + headData[hi].color + '">' + HEAD_TITLES[hi] + "</span>";
      h += vecStrip(out, headData[hi].color);
      h += "</div>";
    }
    h += "</div>";

    h += '<div class="mh-concat-panel__wo-row">';
    h += '<span class="mh-concat-panel__head-label" style="color:var(--text-sec)">12-D concat</span>';
    h += '<span class="mh-concat-panel__plus">&rarr;</span>';
    h += '<span class="mh-concat-panel__head-label" style="color:var(--text-sec)">W<sub>O</sub> (toy)</span>';
    h += '<span class="mh-concat-panel__plus">&rarr;</span>';
    h += vecStrip(merged, "var(--accent)");
    h += "</div>";

    h +=
      "<p class=\"mh-concat-panel__wo-note\">" +
      "Each head produces a 4-D output vector (weighted sum of <span class=\"fc-v\">v</span> vectors, as in the single-head walkthrough). " +
      "Those are concatenated into 12 dimensions; a full layer learns a 4&times;12 matrix <var>W</var><sub>O</sub>. " +
      "Here we use an <strong>equal mix</strong> across the three heads per dimension as a readable stand-in so you still see one merged strip.</p>";

    panel.innerHTML = h;
  }

  function attachEvents() {
    vizRoot.querySelectorAll(".mh-heatmap__cell").forEach(function(cell) {
      cell.addEventListener("mouseenter", function(e) {
        var r = parseInt(this.getAttribute("data-row"));
        var c = parseInt(this.getAttribute("data-col"));
        var val = this.getAttribute("data-val");
        var tip = document.createElement("div");
        tip.className = "mh-tooltip";
        tip.textContent = TOKENS[r] + " \u2192 " + TOKENS[c] + ": " + val + "%";
        var rect = this.getBoundingClientRect();
        var pRect = vizRoot.getBoundingClientRect();
        tip.style.left = (rect.left - pRect.left + rect.width / 2) + "px";
        tip.style.top = (rect.top - pRect.top - 28) + "px";
        tip.style.transform = "translateX(-50%)";
        tip.id = "mh-tip";
        vizRoot.appendChild(tip);
      });
      cell.addEventListener("mouseleave", function() {
        var t = document.getElementById("mh-tip");
        if (t) t.remove();
      });
      cell.addEventListener("click", function() {
        var r = parseInt(this.getAttribute("data-row"));
        activeRow = (activeRow === r) ? null : r;
        renderAll();
      });
    });
  }

  renderAll();
})();
</script>

<!-- Cosine similarity interactive -->
<script is:inline>
(function() {
  var svg = document.getElementById("cosine-svg");
  if (!svg) return;
  var handle = document.getElementById("cos-handle");
  var vecB = document.getElementById("cos-vec-b");
  var labelB = document.getElementById("cos-label-b");
  var cosValue = document.getElementById("cos-value");
  var cosAngle = document.getElementById("cos-angle");
  var arc = document.getElementById("cos-arc");
  var cx = 240, cy = 200, r = 150;
  var angleA = -18 * Math.PI / 180;
  var angleB = -55 * Math.PI / 180;

  function update() {
    var bx = cx + r * Math.cos(angleB);
    var by = cy + r * Math.sin(angleB);
    vecB.setAttribute("x2", bx);
    vecB.setAttribute("y2", by);
    labelB.setAttribute("x", bx + 5);
    labelB.setAttribute("y", by - 3);
    handle.setAttribute("cx", bx);
    handle.setAttribute("cy", by);
    var diff = angleB - angleA;
    var deg = Math.abs(diff * 180 / Math.PI);
    if (deg > 180) deg = 360 - deg;
    var cos = Math.cos(diff);
    cosValue.textContent = "cos \u03B8 = " + cos.toFixed(2);
    cosAngle.textContent = "\u03B8 = " + Math.round(deg) + "\u00B0";
    var ar = 40;
    var startA = angleA, endA = angleB;
    if (endA < startA) { var tmp = startA; startA = endA; endA = tmp; }
    if (endA - startA > Math.PI) { var tmp2 = startA; startA = endA; endA = tmp2 + 2 * Math.PI; }
    var sx = cx + ar * Math.cos(startA), sy = cy + ar * Math.sin(startA);
    var ex = cx + ar * Math.cos(endA), ey = cy + ar * Math.sin(endA);
    var large = (endA - startA > Math.PI) ? 1 : 0;
    arc.setAttribute("d", "M" + sx + "," + sy + " A" + ar + "," + ar + " 0 " + large + ",1 " + ex + "," + ey);
  }

  var dragging = false;
  handle.addEventListener("mousedown", function(e) { dragging = true; e.preventDefault(); });
  handle.addEventListener("touchstart", function(e) { dragging = true; e.preventDefault(); }, { passive: false });
  function onMove(px, py) {
    if (!dragging) return;
    var rect = svg.getBoundingClientRect();
    var scaleX = 480 / rect.width;
    var scaleY = 400 / rect.height;
    var mx = (px - rect.left) * scaleX;
    var my = (py - rect.top) * scaleY;
    angleB = Math.atan2(my - cy, mx - cx);
    update();
  }
  document.addEventListener("mousemove", function(e) { onMove(e.clientX, e.clientY); });
  document.addEventListener("touchmove", function(e) { if (dragging) { e.preventDefault(); onMove(e.touches[0].clientX, e.touches[0].clientY); } }, { passive: false });
  document.addEventListener("mouseup", function() { dragging = false; });
  document.addEventListener("touchend", function() { dragging = false; });
  update();
})();
</script>

<!-- Semantic projection explorer -->
<script is:inline>
(function() {
  var svg = document.getElementById("proj-svg");
  var insight = document.getElementById("proj-insight");
  var explorer = document.getElementById("proj-explorer");
  if (!svg || !explorer) return;

  var words = [
    { w: "programmer",    g: -0.75, a: -0.25 },
    { w: "engineer",      g: -0.65, a:  0.10 },
    { w: "soldier",       g: -0.55, a: -0.35 },
    { w: "pilot",         g: -0.45, a:  0.30 },
    { w: "scientist",     g: -0.35, a:  0.35 },
    { w: "professor",     g: -0.20, a:  0.55 },
    { w: "doctor",        g: -0.15, a:  0.25 },
    { w: "therapist",     g:  0.15, a:  0.30 },
    { w: "librarian",     g:  0.25, a:  0.40 },
    { w: "teacher",       g:  0.30, a: -0.05 },
    { w: "dancer",        g:  0.40, a: -0.45 },
    { w: "secretary",     g:  0.55, a: -0.15 },
    { w: "nurse",         g:  0.65, a: -0.10 },
    { w: "receptionist",  g:  0.70, a: -0.20 }
  ];

  var insights = [
    "Occupations projected onto a gender axis derived from GloVe embeddings. The bias reflects patterns in the training corpus, not ground truth.",
    "The same occupations projected onto an age axis (young \u2194 old). Embeddings encode many cultural dimensions simultaneously.",
    "Two dimensions at once. Each dot is an occupation positioned by its gender and age associations in the embedding space."
  ];

  var panel = 0;

  function drawBars(dim, leftLabel, rightLabel) {
    var sorted = words.slice().sort(function(a, b) { return a[dim] - b[dim]; });
    var cx = 310, top = 30, rowH = 26;
    var maxW = 160;
    var h = top + sorted.length * rowH + 40;
    svg.setAttribute("viewBox", "0 0 520 " + h);
    var s = "";

    s += '<line x1="' + cx + '" y1="' + (top - 10) + '" x2="' + cx + '" y2="' + (top + sorted.length * rowH) + '" style="stroke: var(--border, #E2E6EE);" stroke-width="1"/>';
    var axisY = top + sorted.length * rowH + 18;
    s += '<line x1="' + (cx - maxW - 10) + '" y1="' + (axisY - 16) + '" x2="' + (cx + maxW + 10) + '" y2="' + (axisY - 16) + '" style="stroke: var(--border, #E2E6EE);" stroke-width="1"/>';
    s += '<text x="' + (cx - maxW - 10) + '" y="' + axisY + '" style="fill: var(--accent-dark, #1E5A8A);" font-weight="600" font-size="11">' + leftLabel + '</text>';
    s += '<text x="' + (cx + maxW + 10) + '" y="' + axisY + '" text-anchor="end" style="fill: var(--accent, #2D8ABF);" font-weight="600" font-size="11">' + rightLabel + '</text>';

    for (var i = 0; i < sorted.length; i++) {
      var v = sorted[i][dim];
      var y = top + i * rowH;
      var bw = Math.abs(v) * maxW;
      var bx = v < 0 ? cx - bw : cx;
      var op = 0.4 + Math.abs(v) * 0.5;
      var colorVar = v < 0 ? "var(--accent-dark, #1E5A8A)" : "var(--accent, #2D8ABF)";
      s += '<rect x="' + bx + '" y="' + y + '" width="' + bw + '" height="' + (rowH - 6) + '" rx="3" style="fill: ' + colorVar + ';" opacity="' + op.toFixed(2) + '"/>';
      var tx, ta;
      if (v < 0) { tx = bx - 6; ta = "end"; }
      else { tx = bx + bw + 6; ta = "start"; }
      s += '<text x="' + tx + '" y="' + (y + rowH / 2 + 1) + '" text-anchor="' + ta + '" style="fill: var(--text-sec, #3D4455);" font-size="11">' + sorted[i].w + '</text>';
    }
    svg.innerHTML = s;
  }

  function drawScatter() {
    var pad = 60, w = 520, h = 440;
    var plotL = pad + 20, plotR = w - pad;
    var plotT = pad - 10, plotB = h - pad;
    var plotW = plotR - plotL, plotH = plotB - plotT;
    var cx = plotL + plotW / 2, cy = plotT + plotH / 2;
    svg.setAttribute("viewBox", "0 0 " + w + " " + h);
    var s = "";

    s += '<rect x="' + plotL + '" y="' + plotT + '" width="' + plotW + '" height="' + plotH + '" rx="4" style="fill: var(--surface, #F2F4F8); stroke: var(--border, #E2E6EE);"/>';
    s += '<line x1="' + cx + '" y1="' + plotT + '" x2="' + cx + '" y2="' + plotB + '" style="stroke: var(--border-lt, #EAEEF4);" stroke-width="1" stroke-dasharray="4,3"/>';
    s += '<line x1="' + plotL + '" y1="' + cy + '" x2="' + plotR + '" y2="' + cy + '" style="stroke: var(--border-lt, #EAEEF4);" stroke-width="1" stroke-dasharray="4,3"/>';

    s += '<text x="' + cx + '" y="' + (plotB + 32) + '" text-anchor="middle" style="fill: var(--text-muted, #6B7280);" font-weight="600" font-size="10">Gender Scale</text>';
    s += '<text x="' + plotL + '" y="' + (plotB + 18) + '" style="fill: var(--accent-dark, #1E5A8A);" font-size="9">\u2190 male</text>';
    s += '<text x="' + plotR + '" y="' + (plotB + 18) + '" text-anchor="end" style="fill: var(--accent, #2D8ABF);" font-size="9">female \u2192</text>';

    s += '<text x="' + (plotL - 30) + '" y="' + cy + '" text-anchor="middle" style="fill: var(--text-muted, #6B7280);" font-weight="600" font-size="10" transform="rotate(-90,' + (plotL - 30) + ',' + cy + ')">Age Scale</text>';
    s += '<text x="' + (plotL - 14) + '" y="' + (plotT + 10) + '" style="fill: var(--accent, #2D8ABF);" font-size="9">old \u2191</text>';
    s += '<text x="' + (plotL - 14) + '" y="' + (plotB - 2) + '" style="fill: var(--accent-dark, #1E5A8A);" font-size="9">young \u2193</text>';

    var labels = [];
    for (var i = 0; i < words.length; i++) {
      var d = words[i];
      var px = cx + d.g * (plotW / 2) * 0.85;
      var py = cy - d.a * (plotH / 2) * 0.85;
      s += '<circle cx="' + px + '" cy="' + py + '" r="4" style="fill: var(--accent, #2D8ABF);" opacity="0.85"/>';
      var anchor = d.g > 0.3 ? "start" : d.g < -0.3 ? "end" : "middle";
      var lx = anchor === "start" ? px + 7 : anchor === "end" ? px - 7 : px;
      var ly = py - 8;
      labels.push({ x: lx, y: ly, a: anchor, t: d.w });
    }

    for (var k = 0; k < labels.length; k++) {
      for (var j = 0; j < k; j++) {
        if (Math.abs(labels[k].x - labels[j].x) < 45 && Math.abs(labels[k].y - labels[j].y) < 11) {
          labels[k].y = labels[k].y > labels[j].y ? labels[j].y + 12 : labels[j].y - 12;
        }
      }
    }

    for (var m = 0; m < labels.length; m++) {
      var lb = labels[m];
      s += '<text x="' + lb.x + '" y="' + lb.y + '" text-anchor="' + lb.a + '" style="fill: var(--text-sec, #3D4455);" font-size="9">' + lb.t + '</text>';
    }
    svg.innerHTML = s;
  }

  function render() {
    if (panel === 0) drawBars("g", "\u2190 male", "female \u2192");
    else if (panel === 1) drawBars("a", "\u2190 young", "old \u2192");
    else drawScatter();
    insight.textContent = insights[panel];
  }

  var btns = explorer.querySelectorAll(".attention-explorer__sentence-btn");
  btns.forEach(function(btn, i) {
    btn.addEventListener("click", function() {
      btns.forEach(function(b, j) {
        b.classList.toggle("attention-explorer__sentence-btn--active", j === i);
      });
      panel = i;
      render();
    });
  });

  render();
})();
</script>

<!-- BPE step-through interactive -->
<script is:inline>
(function() {
  var explorer = document.getElementById("bpe-explorer");
  if (!explorer) return;

  var tokensDiv = document.getElementById("bpe-tokens");
  var stepLabel = document.getElementById("bpe-step-label");
  var mergeInfo = document.getElementById("bpe-merge-info");
  var counterSpan = document.getElementById("bpe-counter");
  var tokenCountDiv = document.getElementById("bpe-token-count");
  var prevBtn = document.getElementById("bpe-prev");
  var nextBtn = document.getElementById("bpe-next");

  /*
   * Each word has a sequence of merge steps.
   * Each step: { merge: [idx_left, idx_right], note: "..." }
   * The merge indices refer to positions in the token array at that step.
   * These simulate realistic BPE merges based on typical GPT-style tokenizers.
   */
  var words = {
    "unhappiness": {
      chars: ["u","n","h","a","p","p","i","n","e","s","s"],
      merges: [
        { l: 3, r: 4, note: "\"ap\" is frequent in English (appear, apply, apart...)" },
        { l: 3, r: 4, note: "\"pp\" is common (happy, apply, apple...)" },
        { l: 3, r: 4, note: "\"app\" merges further, building a larger subword" },
        { l: 7, r: 8, note: "\"ss\" is frequent (miss, class, pass...)" },
        { l: 1, r: 2, note: "\"nh\" merges, but this is just frequency at work" },
        { l: 3, r: 4, note: "\"in\" is extremely common (in, into, ing...)" },
        { l: 0, r: 1, note: "\"un\" becomes a single token: a meaningful prefix" },
        { l: 2, r: 3, note: "\"appin\" merges into a larger unit" },
        { l: 1, r: 2, note: "\"happiness\" approximated as \"h\" + \"appin\" + \"ess\" merging" },
      ],
      /* Rather than simulate all ~50k merges, we show key intermediate states: */
      states: [
        ["u","n","h","a","p","p","i","n","e","s","s"],
        ["u","n","h","a","p","p","i","n","e","ss"],
        ["u","n","h","a","pp","i","n","e","ss"],
        ["u","n","h","app","i","n","e","ss"],
        ["u","n","h","app","in","e","ss"],
        ["u","n","h","app","ine","ss"],
        ["u","n","h","app","iness"],
        ["un","h","app","iness"],
        ["un","happiness"],
      ],
      mergeDescs: [
        "Merge \"e\" + \"s\" \u2192 \"ss\" (freq. pair: class, miss, pass...)",
        "Merge \"p\" + \"p\" \u2192 \"pp\" (freq. pair: happy, apple, apply...)",
        "Merge \"a\" + \"pp\" \u2192 \"app\" (building a larger subword)",
        "Merge \"i\" + \"n\" \u2192 \"in\" (extremely common in English)",
        "Merge \"app\" + \"ine\" \u2192 combines further",
        "Merge \"ine\" + \"ss\" \u2192 \"iness\" (suffix emerges)",
        "Merge \"u\" + \"n\" \u2192 \"un\" (meaningful prefix!)",
        "Merge \"h\" + \"app\" + \"iness\" \u2192 \"happiness\" (common word = single token)",
      ],
      /* Indices of the two tokens being highlighted at each step (0-indexed into the PREVIOUS state) */
      highlights: [
        [8, 9],
        [4, 5],
        [3, 4],
        [5, 6],
        [3, 4],
        [4, 5],
        [0, 1],
        [1, 2],
      ]
    },
    "strawberry": {
      chars: ["s","t","r","a","w","b","e","r","r","y"],
      states: [
        ["s","t","r","a","w","b","e","r","r","y"],
        ["st","r","a","w","b","e","r","r","y"],
        ["str","a","w","b","e","r","r","y"],
        ["str","aw","b","e","r","r","y"],
        ["straw","b","e","r","r","y"],
        ["straw","b","er","r","y"],
        ["straw","b","err","y"],
        ["straw","b","erry"],
        ["straw","berry"],
      ],
      mergeDescs: [
        "Merge \"s\" + \"t\" \u2192 \"st\" (very frequent pair)",
        "Merge \"st\" + \"r\" \u2192 \"str\" (common beginning: string, street, strong...)",
        "Merge \"a\" + \"w\" \u2192 \"aw\" (draw, law, saw...)",
        "Merge \"str\" + \"aw\" \u2192 \"straw\" (frequent subword)",
        "Merge \"e\" + \"r\" \u2192 \"er\" (extremely common: player, after, ever...)",
        "Merge \"er\" + \"r\" \u2192 \"err\" (less common, but frequent enough)",
        "Merge \"err\" + \"y\" \u2192 \"erry\" (berry, cherry, merry...)",
        "Merge \"b\" + \"erry\" \u2192 \"berry\" (common word = single token)",
      ],
      highlights: [
        [0, 1],
        [0, 1],
        [2, 3],
        [0, 1],
        [4, 5],
        [4, 5],
        [4, 5],
        [3, 4],
      ]
    },
    "tokenization": {
      chars: ["t","o","k","e","n","i","z","a","t","i","o","n"],
      states: [
        ["t","o","k","e","n","i","z","a","t","i","o","n"],
        ["to","k","e","n","i","z","a","t","i","o","n"],
        ["tok","e","n","i","z","a","t","i","on"],
        ["tok","en","i","z","a","t","i","on"],
        ["token","i","z","a","t","i","on"],
        ["token","iz","a","t","i","on"],
        ["token","iz","at","i","on"],
        ["token","iz","at","ion"],
        ["token","iz","ation"],
        ["token","ization"],
      ],
      mergeDescs: [
        "Merge \"t\" + \"o\" \u2192 \"to\" (extremely frequent word/prefix)",
        "Merge \"to\" + \"k\" \u2192 \"tok\" and \"o\" + \"n\" \u2192 \"on\"",
        "Merge \"e\" + \"n\" \u2192 \"en\" (common: then, when, often...)",
        "Merge \"tok\" + \"en\" \u2192 \"token\" (full word!)",
        "Merge \"i\" + \"z\" \u2192 \"iz\" (building toward \"-ize\")",
        "Merge \"a\" + \"t\" \u2192 \"at\" (common pair)",
        "Merge \"i\" + \"on\" \u2192 \"ion\" (very common suffix)",
        "Merge \"at\" + \"ion\" \u2192 \"ation\" (\"-ation\" suffix emerges!)",
        "Merge \"iz\" + \"ation\" \u2192 \"ization\" (productive morpheme)",
      ],
      highlights: [
        [0, 1],
        [0, 1],
        [2, 3],
        [0, 1],
        [3, 4],
        [4, 5],
        [5, 6],
        [4, 5],
        [3, 4],
      ]
    },
    "\u00dcbersetzung": {
      chars: ["\u00dc","b","e","r","s","e","t","z","u","n","g"],
      states: [
        ["\u00dc","b","e","r","s","e","t","z","u","n","g"],
        ["\u00dc","b","er","s","e","t","z","u","n","g"],
        ["\u00dc","b","er","se","t","z","u","ng"],
        ["\u00dc","b","er","set","z","u","ng"],
        ["\u00dc","b","er","setz","u","ng"],
        ["\u00dc","b","er","setz","ung"],
        ["\u00dc","ber","setz","ung"],
        ["\u00dcber","setz","ung"],
        ["\u00dcbersetzung"],
      ],
      mergeDescs: [
        "Merge \"e\" + \"r\" \u2192 \"er\" (common in both English and German)",
        "Merge \"s\" + \"e\" \u2192 \"se\" and \"n\" + \"g\" \u2192 \"ng\"",
        "Merge \"se\" + \"t\" \u2192 \"set\" (common subword)",
        "Merge \"set\" + \"z\" \u2192 \"setz\" (German-specific merge)",
        "Merge \"u\" + \"ng\" \u2192 \"ung\" (very common German suffix!)",
        "Merge \"b\" + \"er\" \u2192 \"ber\" (building \"\u00fcber\")",
        "Merge \"\u00dc\" + \"ber\" \u2192 \"\u00dcber\" (\"\u00fcber\" = common German prefix)",
        "Merge \"\u00dcber\" + \"setz\" + \"ung\" \u2192 if word is common enough in training data",
      ],
      highlights: [
        [2, 3],
        [3, 4],
        [3, 4],
        [3, 4],
        [5, 6],
        [1, 2],
        [0, 1],
        [0, 1],
      ]
    }
  };

  var currentWord = "unhappiness";
  var currentStep = 0;

  function getStates() { return words[currentWord].states; }
  function getMergeDescs() { return words[currentWord].mergeDescs; }
  function getHighlights() { return words[currentWord].highlights; }
  function totalSteps() { return getStates().length - 1; }

  function render() {
    var states = getStates();
    var mergeDescs = getMergeDescs();
    var highlights = getHighlights();
    var tokens = states[currentStep];
    var nextHighlight = (currentStep < totalSteps()) ? highlights[currentStep] : null;

    /* Step label */
    if (currentStep === 0) {
      stepLabel.textContent = "Step 0: Start with individual characters";
    } else {
      stepLabel.textContent = "Step " + currentStep + ": After merge";
    }

    /* Tokens */
    tokensDiv.innerHTML = "";
    for (var i = 0; i < tokens.length; i++) {
      var span = document.createElement("span");
      span.className = "bpe-explorer__tok";
      span.textContent = tokens[i];

      /* Highlight the pair that WILL be merged on the next step */
      if (nextHighlight && (i === nextHighlight[0] || i === nextHighlight[1])) {
        span.classList.add("bpe-explorer__tok--merging");
      }
      /* If this is the result of the merge that just happened, highlight it */
      if (currentStep > 0) {
        var prevHighlight = highlights[currentStep - 1];
        /* The merged token lands at the position of the left element */
        if (i === prevHighlight[0]) {
          span.classList.add("bpe-explorer__tok--merged");
        }
      }
      tokensDiv.appendChild(span);
    }

    /* Merge info */
    if (currentStep === 0 && totalSteps() > 0) {
      mergeInfo.innerHTML = "Next: " + mergeDescs[0];
    } else if (currentStep > 0 && currentStep <= mergeDescs.length) {
      mergeInfo.innerHTML = mergeDescs[currentStep - 1];
    } else {
      mergeInfo.innerHTML = "";
    }

    /* Counter */
    counterSpan.textContent = "Step " + currentStep + " / " + totalSteps();

    /* Buttons */
    prevBtn.disabled = (currentStep === 0);
    nextBtn.disabled = (currentStep >= totalSteps());
    nextBtn.textContent = (currentStep >= totalSteps()) ? "Done \u2713" : "Next merge \u2192";

    /* Token count summary */
    var startCount = states[0].length;
    var currentCount = tokens.length;
    tokenCountDiv.innerHTML =
      '<div class="bpe-explorer__count-item bpe-explorer__count-item--start">' +
        '<span class="bpe-explorer__count-num">' + startCount + '</span>' +
        '<span class="bpe-explorer__count-label">characters</span>' +
      '</div>' +
      '<div class="bpe-explorer__count-item">' +
        '<span class="bpe-explorer__count-num">' + currentCount + '</span>' +
        '<span class="bpe-explorer__count-label">token' + (currentCount !== 1 ? 's' : '') + ' now</span>' +
      '</div>';
  }

  nextBtn.addEventListener("click", function() {
    if (currentStep < totalSteps()) { currentStep++; render(); }
  });
  prevBtn.addEventListener("click", function() {
    if (currentStep > 0) { currentStep--; render(); }
  });

  var wordBtns = explorer.querySelectorAll(".bpe-explorer__word-btn");
  wordBtns.forEach(function(btn) {
    btn.addEventListener("click", function() {
      var w = this.getAttribute("data-word");
      wordBtns.forEach(function(b) { b.classList.remove("bpe-explorer__word-btn--active"); });
      this.classList.add("bpe-explorer__word-btn--active");
      currentWord = w;
      currentStep = 0;
      render();
    });
  });

  render();
})();
</script>

<!-- Context / KV cache cost calculator -->
<script is:inline>
(function() {
  var calc = document.getElementById("cost-calc");
  if (!calc) return;

  var seqSlider = document.getElementById("cost-seq-slider");
  var seqVal = document.getElementById("cost-seq-val");
  var resultsDiv = document.getElementById("cost-results");
  var barFill = document.getElementById("cost-bar-fill");
  var barWeights = document.getElementById("cost-bar-weights");
  var barLabel = document.getElementById("cost-bar-label");
  var gqaToggle = document.getElementById("cost-gqa-toggle");
  var gqaHint = document.getElementById("cost-gqa-hint");

  /* Model specs: layers, d_model, n_heads, kv_heads, params (billions) */
  var models = [
    { name: "Qwen2.5-0.5B", layers: 24, d: 896,  heads: 14, kvHeads: 2,  params: 0.5 },
    { name: "Llama-3-8B",   layers: 32, d: 4096, heads: 32, kvHeads: 8,  params: 8 },
    { name: "Llama-3-70B",  layers: 80, d: 8192, heads: 64, kvHeads: 8,  params: 70 },
    { name: "GPT-4 scale",  layers: 120, d: 12288, heads: 96, kvHeads: 96, params: 175 },
  ];

  var currentModel = 0;
  var GPU_MEM = 24; /* GB */
  var BYTES_PER_PARAM = 2; /* FP16 */

  function getSeqLen() {
    return Math.round(Math.pow(2, parseFloat(seqSlider.value)));
  }

  function fmtNum(n) {
    if (n >= 1e15) return (n / 1e15).toFixed(1) + "P";
    if (n >= 1e12) return (n / 1e12).toFixed(1) + "T";
    if (n >= 1e9) return (n / 1e9).toFixed(1) + "B";
    if (n >= 1e6) return (n / 1e6).toFixed(1) + "M";
    if (n >= 1e3) return (n / 1e3).toFixed(1) + "K";
    return n.toString();
  }

  function fmtTokens(n) {
    if (n >= 1048576) return (n / 1024).toFixed(0) + "K";
    if (n >= 1024) return (n / 1024).toFixed(n >= 8192 ? 0 : 1) + "K";
    return n.toLocaleString();
  }

  function fmtMem(gb) {
    if (gb < 0.01) return (gb * 1024).toFixed(1) + " MB";
    if (gb < 1) return (gb * 1024).toFixed(0) + " MB";
    return gb.toFixed(1) + " GB";
  }

  function compute() {
    var m = models[currentModel];
    var n = getSeqLen();
    var useGQA = gqaToggle.checked;

    /* KV cache: 2 * layers * d_kv * n_tokens * bytes */
    /* With GQA: d_kv = d_model * (kvHeads / heads) */
    var dKV = useGQA ? m.d * (m.kvHeads / m.heads) : m.d;
    var kvBytes = 2 * m.layers * dKV * n * BYTES_PER_PARAM;
    var kvGB = kvBytes / (1024 * 1024 * 1024);

    /* Attention FLOPs (attention layers only): 2 * n^2 * d * layers */
    var attnFlops = 2 * n * n * m.d * m.layers;

    /* Model weight memory */
    var weightGB = m.params * 1e9 * BYTES_PER_PARAM / (1024 * 1024 * 1024);

    return {
      kvGB: kvGB,
      weightGB: weightGB,
      totalGB: kvGB + weightGB,
      attnFlops: attnFlops,
      seqLen: n,
      model: m,
      useGQA: useGQA
    };
  }

  function render() {
    var r = compute();
    var n = r.seqLen;

    /* Seq length display */
    seqVal.textContent = fmtTokens(n);

    /* Result cards */
    var kvWarn = r.kvGB > GPU_MEM ? " cost-calc__result-value--warn" : "";
    resultsDiv.innerHTML =
      '<div class="cost-calc__result-card">' +
        '<div class="cost-calc__result-value">' + fmtNum(n * n) + '</div>' +
        '<div class="cost-calc__result-label">attention entries<br>(per head, per layer)</div>' +
      '</div>' +
      '<div class="cost-calc__result-card">' +
        '<div class="cost-calc__result-value' + kvWarn + '">' + fmtMem(r.kvGB) + '</div>' +
        '<div class="cost-calc__result-label">KV cache memory' + (r.useGQA ? ' (GQA)' : '') + '</div>' +
      '</div>' +
      '<div class="cost-calc__result-card">' +
        '<div class="cost-calc__result-value">' + fmtNum(r.attnFlops) + '</div>' +
        '<div class="cost-calc__result-label">attention FLOPs<br>(forward pass)</div>' +
      '</div>';

    /* GPU memory bar */
    var kvPct = Math.min(r.kvGB / GPU_MEM * 100, 100);
    var wPct = Math.min(r.weightGB / GPU_MEM * 100, 100 - kvPct);
    if (kvPct + wPct > 100) wPct = 100 - kvPct;
    if (wPct < 0) wPct = 0;
    barFill.style.width = kvPct + "%";
    barWeights.style.width = wPct + "%";
    barWeights.style.left = kvPct + "%";

    if (r.totalGB > GPU_MEM) {
      barLabel.textContent = "Exceeds " + GPU_MEM + " GB GPU! (" + r.totalGB.toFixed(1) + " GB needed)";
      barLabel.style.color = "#c05020";
    } else {
      barLabel.textContent = "GPU memory usage: " + r.totalGB.toFixed(1) + " / " + GPU_MEM + " GB";
      barLabel.style.color = "";
    }

    /* GQA hint */
    if (r.useGQA) {
      var ratio = r.model.heads / r.model.kvHeads;
      gqaHint.textContent = ratio.toFixed(0) + "\u00d7 KV cache reduction (" + r.model.kvHeads + " KV heads vs " + r.model.heads + " query heads)";
    } else {
      gqaHint.textContent = "";
    }
  }

  seqSlider.addEventListener("input", render);
  gqaToggle.addEventListener("change", render);

  var modelBtns = calc.querySelectorAll(".cost-calc__model-btn");
  modelBtns.forEach(function(btn) {
    btn.addEventListener("click", function() {
      modelBtns.forEach(function(b) { b.classList.remove("cost-calc__model-btn--active"); });
      this.classList.add("cost-calc__model-btn--active");
      currentModel = parseInt(this.getAttribute("data-model"));
      render();
    });
  });

  render();
})();
</script>
