<script is:inline>
(function() {
  var explorer = document.getElementById("cost-explorer");
  var svg = document.getElementById("cost-explorer-svg");
  var insight = document.getElementById("cost-explorer-insight");
  if (!explorer || !svg) return;

  var tiers = [
    {
      models: [
        { name: "GPT-4o mini", cost: 0.08, provider: "OpenAI" },
        { name: "Claude 3.5 Haiku", cost: 0.05, provider: "Anthropic" },
        { name: "Gemini 2.0 Flash", cost: 0.04, provider: "Google" },
        { name: "DeepSeek-V3 (API)", cost: 0.03, provider: "DeepSeek" },
        { name: "Llama 3.1 8B (hosted)", cost: 0.02, provider: "Together/Groq" }
      ],
      insight: "Budget models: best for straightforward classification where frontier capability is not needed. At these prices, 100,000 texts cost $2\u201310. Often sufficient for binary sentiment or topic classification."
    },
    {
      models: [
        { name: "Claude 3.5 Sonnet", cost: 1.50, provider: "Anthropic" },
        { name: "GPT-4o", cost: 1.25, provider: "OpenAI" },
        { name: "Gemini 1.5 Pro", cost: 0.65, provider: "Google" },
        { name: "Llama 3.1 70B (hosted)", cost: 0.40, provider: "Together" },
        { name: "Qwen 2.5 72B (hosted)", cost: 0.35, provider: "Together" }
      ],
      insight: "Mid-range models: better for nuanced tasks (stance detection, framing analysis, sarcasm). 100,000 texts cost $35\u2013150. The quality improvement over budget models is significant for complex annotation schemes."
    },
    {
      models: [
        { name: "o1 (reasoning)", cost: 8.00, provider: "OpenAI" },
        { name: "Claude 3 Opus", cost: 5.00, provider: "Anthropic" },
        { name: "o3-mini (reasoning)", cost: 3.50, provider: "OpenAI" },
        { name: "Claude Sonnet (thinking)", cost: 4.00, provider: "Anthropic" },
        { name: "Llama 3.1 405B (hosted)", cost: 2.00, provider: "Together" }
      ],
      insight: "Frontier/reasoning models: reserve for tasks requiring deep analysis \u2014 implicit stance, complex framing, multi-step inference. 100,000 texts cost $200\u2013800. Often overkill for standard classification; use selectively on hard subsets."
    }
  ];

  var currentTier = 0;

  function draw() {
    var t = tiers[currentTier];
    var models = t.models;
    var pad = { left: 145, right: 30, top: 15, bottom: 30 };
    var w = 520, barH = 28, gap = 12;
    var h = pad.top + models.length * (barH + gap) + pad.bottom;
    svg.setAttribute("viewBox", "0 0 " + w + " " + h);
    var plotW = w - pad.left - pad.right;
    var maxCost = 0;
    for (var i = 0; i < models.length; i++) {
      if (models[i].cost > maxCost) maxCost = models[i].cost;
    }
    maxCost = maxCost * 1.15;
    var s = "";
    s += '<rect x="' + pad.left + '" y="' + pad.top + '" width="' + plotW + '" height="' + (models.length * (barH + gap) - gap) + '" rx="4" style="fill:var(--surface,#F2F4F8);stroke:none;"/>';
    for (var j = 0; j < models.length; j++) {
      var m = models[j];
      var y = pad.top + j * (barH + gap);
      var barW = (m.cost / maxCost) * plotW;
      s += '<text x="' + (pad.left - 8) + '" y="' + (y + barH / 2 + 4) + '" text-anchor="end" style="fill:var(--text-sec,#3D4455);font-family:var(--font-body);" font-size="10">' + m.name + '</text>';
      s += '<rect x="' + pad.left + '" y="' + y + '" width="' + barW + '" height="' + barH + '" rx="4" style="fill:var(--accent,#2D8ABF);" opacity="' + (0.55 + 0.45 * (m.cost / maxCost)) + '"/>';
      var labelX = pad.left + barW + 6;
      s += '<text x="' + labelX + '" y="' + (y + barH / 2 + 4) + '" style="fill:var(--text-sec,#3D4455);font-family:var(--font-mono);" font-size="9.5" font-weight="600">$' + m.cost.toFixed(2) + '</text>';
    }
    s += '<text x="' + (pad.left + plotW / 2) + '" y="' + (pad.top + models.length * (barH + gap) + 12) + '" text-anchor="middle" style="fill:var(--text-muted,#6B7280);font-family:var(--font-body);" font-size="9">Estimated cost per 10,000 classifications (USD)</text>';
    svg.innerHTML = s;
    insight.textContent = t.insight;
  }

  var btns = explorer.querySelectorAll(".attention-explorer__sentence-btn");
  btns.forEach(function(btn, i) {
    btn.addEventListener("click", function() {
      btns.forEach(function(b, j) {
        b.classList.toggle("attention-explorer__sentence-btn--active", j === i);
      });
      currentTier = i;
      draw();
    });
  });

  draw();
})();
</script>
