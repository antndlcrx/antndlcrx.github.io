    {label:'27B',value:27e9,note:'Gemma 3 27B',hidden:4608,layers:62},
    {label:'32B',value:32e9,note:'Qwen 3 32B',hidden:5120,layers:64},
    {label:'70B',value:70e9,note:'Llama 3.3 70B',hidden:8192,layers:80}
