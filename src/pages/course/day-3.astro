  var rankSteps=[4,8,16,32,64,128,256,512];
  var hiddenSteps=[768,1024,2560,3840,4096,5120,8192];
  var layerOpts=[6,12,28,36,40,48,64,80];
  var presets=[
    {params:3,rank:2,qlora:true,insight:'<strong>Qwen 3 4B with QLoRA rank 16</strong> fits comfortably on a free Colab T4 (15 GB). You train ~0.3% of parameters. The adapter file is small enough to email. This is the setup used in the course notebook.'},
    {params:5,rank:2,qlora:true,insight:'<strong>Gemma 3 12B</strong> offers a strong jump in reasoning capability. With QLoRA it fits on an A100 or a high-end consumer GPU. Rank 16 is usually sufficient for classification tasks.'},
    {params:8,rank:2,qlora:true,insight:'<strong>Qwen 3 32B</strong> is a strong choice for complex annotation tasks. Requires a 40+ GB GPU even with QLoRA. Consider whether the quality gain justifies the hardware step-up.'},
    {params:9,rank:2,qlora:true,insight:'<strong>Llama 3.3 70B</strong> requires serious hardware even with 4-bit quantisation. For most social science classification, a 4\u201314B model with LoRA will be more practical.'},
    {params:1,rank:1,qlora:false,insight:'<strong>DeBERTaV3-base (184M params)</strong> uses standard full fine-tuning \u2014 no LoRA needed. All 184M parameters are trainable, yet the model fits in ~2 GB VRAM. For fixed-category classification, this is typically the best choice.'}
  ];
  var hardware=[{name:'Colab T4 (free)',vram:15},{name:'RTX 3090 / 4090',vram:24},{name:'Colab A100 (Pro)',vram:40},{name:'A100 80 GB (cloud)',vram:80},{name:'2\u00d7 A100 80 GB',vram:160}];
  var sl={params:$('lora-sl-params'),rank:$('lora-sl-rank')};
  var hidSl=$('lora-sl-hidden'),laySl=$('lora-sl-layers'),qlora=$('lora-qlora');
  function syncArch(pi){
    var m=paramSteps[pi];var bH=0,bL=0;
    hiddenSteps.forEach(function(h,i){if(Math.abs(h-m.hidden)<Math.abs(hiddenSteps[bH]-m.hidden))bH=i;});
