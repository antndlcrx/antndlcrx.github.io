    {label:'184M',value:0.184e9,note:'DeBERTaV3-base',hidden:768,layers:12},
    {label:'0.6B',value:0.6e9,note:'Qwen 3 0.6B',hidden:1024,layers:28},
    {label:'4B',value:4e9,note:'Qwen 3 4B',hidden:2560,layers:36},
