    else{$('lora-vram-desc').textContent='Base model ('+(q?'4-bit':'fp16')+'): '+bV.toFixed(1)+' GB \u00b7 Adapters + optimizer: '+aV.toFixed(1)+' GB \u00b7 Activations: ~'+actV.toFixed(1)+' GB';$('lora-vram-caveat').textContent='Assumes batch size 1, sequence length 512, gradient checkpointing enabled.';}
