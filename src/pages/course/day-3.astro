  }
  function fN(n){if(n>=1e9)return(n/1e9).toFixed(1)+'B';if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return n.toString();}
  function update(ins){
    var pi=parseInt(sl.params.value),ri=parseInt(sl.rank.value),hi=parseInt(hidSl.value),li=parseInt(laySl.value);
    var mod=paramSteps[pi],r=rankSteps[ri],h=hiddenSteps[hi],ly=layerOpts[li],q=qlora.checked,isEnc=mod.value<0.5e9;
    $('lora-disp-params').textContent=mod.label;$('lora-disp-rank').textContent=r;$('lora-disp-hidden').textContent=h;$('lora-disp-layers').textContent=ly;
    $('lora-hint-params').textContent=mod.note+' \u2014 total pre-trained weights'+(isEnc?'':' (frozen during LoRA)');
