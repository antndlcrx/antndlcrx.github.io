/* ── ReAct loop ── */
.rl__question { background: var(--surface-alt, #F5F5F0); border: 1px solid var(--border, #E2E6EE); border-radius: 8px; padding: 0.85rem 1.15rem; margin-bottom: 1.5rem; }
