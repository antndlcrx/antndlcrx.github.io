.fm__card-header { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.15rem; cursor: pointer; user-select: none; transition: background 0.25s ease; }
.fm__card-header:hover { background: var(--surface-alt, #F5F5F0); }
.fm__card-icon { width: 2rem; height: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; flex-shrink: 0; }
.fm__card-label { flex: 1; }
.fm__card-name { font-size: 0.9rem; font-weight: 700; color: var(--text, #1A1D27); line-height: 1.3; }
.fm__card-brief { font-size: 0.75rem; color: var(--text-muted, #6B7280); line-height: 1.4; margin-top: 0.1rem; }
.fm__card-chevron { font-size: 0.7rem; color: var(--text-muted, #6B7280); transition: transform 0.25s ease; flex-shrink: 0; }
.fm__card--active .fm__card-chevron { transform: rotate(90deg); }
.fm__card-detail { display: none; padding: 0 1.15rem 1.15rem 1.15rem; }
.fm__card--active .fm__card-detail { display: block; animation: fmFadeIn 0.3s ease-out; }
@keyframes fmFadeIn { from { opacity: 0; } to { opacity: 1; } }
.fm__example { border-radius: 8px; padding: 0.85rem; margin-bottom: 0.75rem; font-size: 0.82rem; line-height: 1.6; color: var(--text-sec, #3D4455); }
.fm__example-label { font-family: var(--font-mono, monospace); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem; }
.fm__trace-line { display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.3rem; font-size: 0.78rem; }
.fm__trace-label { font-family: var(--font-mono, monospace); font-size: 0.62rem; font-weight: 700; text-transform: uppercase; padding: 0.1rem 0.35rem; border-radius: 3px; flex-shrink: 0; margin-top: 0.15rem; white-space: nowrap; }
.fm__safeguard { background: #EDF7F0; border: 1px solid #B8DBBD; border-radius: 8px; padding: 0.7rem 0.85rem; font-size: 0.82rem; line-height: 1.55; color: var(--text-sec, #3D4455); }
.fm__safeguard-label { font-family: var(--font-mono, monospace); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #2D7D46; margin-bottom: 0.25rem; }
</style>

