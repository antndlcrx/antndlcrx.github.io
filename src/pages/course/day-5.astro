<!-- 1. REACT LOOP VISUALISER                                            -->
<!-- =================================================================== -->
<script is:inline>
(function () {
  var root = document.getElementById("react-loop-root");
  if (!root) return;

  var question = "What does recent political science research say about the relationship between social media and political polarization?";

  var steps = [
    { type: "thought", text: "I need to find what the political science literature says about social media and polarization. Let me start with a broad search.",
      annotation: "<strong>Step 1: Planning.</strong> The agent reasons about the goal before acting. This is the 'Rea' in ReAct. A direct answer without searching would risk hallucination." },
    { type: "action", text: '<code>search_literature("social media political polarization")</code>',
      annotation: "<strong>Step 1: Acting.</strong> The agent calls its search tool. Your code parses this line, extracts the function name and argument, and executes the function." },
    { type: "observation", text: '[1] "Kubin & von Sikorski (2024): Research shows mixed evidence on whether social media directly causes polarization. Some studies find echo chamber effects, while others emphasize that most users are exposed to cross-cutting content..." (score: 0.84)<br>[2] "Settle (2022): Political communication on social media differs from offline because of algorithmic curation, low barriers to expression, and the public nature of interactions..." (score: 0.79)<br>[3] "Barber\u00e1 (2023): Network analysis of Twitter suggests ideological sorting has increased over time, but the causal role of the platform versus broader societal trends remains debated..." (score: 0.72)',
      annotation: "<strong>Step 1: Observing.</strong> The tool returns results. These are real passages from the corpus, not model-generated text. The agent now has evidence to work with." },
    { type: "thought", text: "I found some relevant results about mixed evidence and echo chambers. But I should search for experimental evidence on algorithmic effects specifically.",
      annotation: "<strong>Step 2: Replanning.</strong> The agent evaluates the first results and decides it needs more targeted evidence. This is where agent reasoning adds value over a single RAG call." },
    { type: "action", text: '<code>search_literature("algorithmic curation filter bubbles echo chambers")</code>',
      annotation: "<strong>Step 2: Refined search.</strong> The agent uses a different query informed by terms it found in the first observation." },
    { type: "observation", text: '[1] "Guess et al. (2023): Experimental evidence from Facebook and Instagram suggests that removing algorithmic curation had minimal effects on political attitudes and polarization, challenging the echo chamber hypothesis..." (score: 0.81)<br>[2] "Levy (2021): A randomized experiment on Facebook news feed shows that exposure to counter-attitudinal content can reduce affective polarization, but effects are modest and short-lived..." (score: 0.74)',
      annotation: "<strong>Step 2: New evidence.</strong> This search found experimental studies that complicate the narrative. The agent now has both observational and experimental findings." },
    { type: "thought", text: "I now have evidence on both sides. Let me extract the key findings from the most important passage to make sure I represent it accurately.",
      annotation: "<strong>Step 3: Verification.</strong> Rather than jumping to a conclusion, the agent extracts structured claims from a specific passage. This is the faithfulness discipline from Day 4." },
    { type: "action", text: '<code>extract_findings("Guess et al. (2023): Experimental evidence from Facebook and Instagram suggests that removing algorithmic curation had minimal effects...")</code>',
      annotation: "<strong>Step 3: Extraction.</strong> The agent uses the extraction tool to pull structured, citable claims." },
    { type: "observation", text: "Findings:<br>\u2022 Removing algorithmic curation on Facebook/Instagram did not significantly change political attitudes<br>\u2022 Effect on affective polarization was minimal<br>\u2022 Authors conclude that algorithms are \"not the main driver\" of polarization<br>Source: Guess et al. (2023), experimental design",
      annotation: "<strong>Step 3: Structured evidence.</strong> The extraction provides specific, verifiable claims. The agent can now synthesize from structured findings rather than loose impressions." },
    { type: "thought", text: "I have enough evidence to answer the question. The literature shows a nuanced picture: concerns about echo chambers exist but experimental evidence suggests algorithmic curation is not the primary driver. I should present both sides with citations.",
      annotation: "<strong>Step 4: Deciding to stop.</strong> The agent judges it has sufficient evidence. Stopping too early produces thin answers; stopping too late wastes tokens." },
    { type: "answer", text: 'Recent political science research presents a <strong>nuanced and contested picture</strong> of social media\'s role in polarization. Observational studies document patterns consistent with echo chambers and ideological sorting on platforms like Twitter (Barber\u00e1 2023), and scholars have identified mechanisms including algorithmic curation, low barriers to expression, and the public visibility of political conflict (Settle 2022, Kubin & von Sikorski 2024).<br><br>However, experimental evidence complicates this narrative. Guess et al. (2023) found that removing algorithmic curation on Facebook and Instagram had minimal effects on political attitudes or affective polarization, suggesting algorithms are "not the main driver." Similarly, Levy (2021) found that exposure to counter-attitudinal content had only modest, short-lived effects.<br><br>The emerging consensus is that social media may <strong>reinforce and accelerate</strong> pre-existing polarization trends rather than causing them independently (Kubin & von Sikorski 2024).',
      annotation: "<strong>Final Answer.</strong> The agent synthesizes across three search results and one extraction, citing specific sources. Every claim is traceable to an observation from a tool call." }
  ];

  var visibleSteps = 0;
  var typeLabels = { thought: "Thought", action: "Action", observation: "Observation", answer: "Final Answer" };

  function render() {
    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive visualisation</div>';
    html += '<div class="widget-title">The ReAct Loop in Action</div>';
    html += '<p class="widget-intro">Watch an agent work through a research question step by step. Click to advance. Notice how each Thought leads to an Action, each Observation informs the next Thought, and the loop continues until the agent has enough evidence.</p>';

    html += '<div class="rl__question"><div class="rl__question-label">Research question</div><div class="rl__question-text">"' + question + '"</div></div>';
    html += '<div class="rl__trace">';
    for (var i = 0; i < visibleSteps; i++) {
      var s = steps[i];
      html += '<div class="rl__step"><div class="rl__step-dot rl__step-dot--' + s.type + '"></div>';
      html += '<div class="rl__step-card rl__step-card--' + s.type + '"><div class="rl__step-label rl__step-label--' + s.type + '">' + typeLabels[s.type] + '</div>' + s.text + '</div></div>';
    }
    if (visibleSteps === 0) html += '<div style="text-align:center;padding:3rem 1rem;color:var(--text-muted,#6B7280);font-size:0.88rem;font-style:italic;">Click "Start agent" to begin.</div>';
    html += '</div>';

    var isDone = visibleSteps >= steps.length;
    html += '<div class="rl__controls">';
    if (!isDone) html += '<button class="rl__btn rl__btn--primary" id="rl-next">' + (visibleSteps === 0 ? 'Start agent' : 'Next step') + '</button>';
    if (visibleSteps > 0) html += '<button class="rl__btn rl__btn--ghost" id="rl-reset">Reset</button>';
    html += '<span class="rl__step-counter">' + visibleSteps + ' / ' + steps.length + '</span></div>';

    html += '<div class="rl__legend">';
    html += '<span class="rl__legend-item"><span class="rl__legend-dot" style="background:#2E5090;"></span> Thought</span>';
    html += '<span class="rl__legend-item"><span class="rl__legend-dot" style="background:#8B6914;"></span> Action</span>';
    html += '<span class="rl__legend-item"><span class="rl__legend-dot" style="background:#2D7D46;"></span> Observation</span>';
    html += '<span class="rl__legend-item"><span class="rl__legend-dot" style="background:#6D28D9;"></span> Final Answer</span>';
    html += '</div>';

    if (visibleSteps > 0) {
      html += '<div class="rl__annotation">' + steps[visibleSteps - 1].annotation + '</div>';
    } else {
      html += '<div class="rl__annotation">The agent receives a research question and must decide how to answer it using only the tools available: search, extract, summarize, and calculate. It cannot browse the web or access information beyond its tool set.</div>';
    }
    html += '</div>';

    root.innerHTML = html;

    var nextBtn = document.getElementById('rl-next');
    if (nextBtn) nextBtn.addEventListener('click', function () { visibleSteps++; render(); });
    var resetBtn = document.getElementById('rl-reset');
    if (resetBtn) resetBtn.addEventListener('click', function () { visibleSteps = 0; render(); });
  }
  render();
})();
</script>

<!-- =================================================================== -->
<!-- 2. AGENT FAILURE MODES                                              -->
<!-- =================================================================== -->
<script is:inline>
(function () {
  var root = document.getElementById("failure-modes-root");
  if (!root) return;

  var modes = [
    {
      name: "Hallucination on Missing Data", brief: "The corpus lacks the answer, but the agent fabricates one anyway",
      icon: "\uD83D\uDC7B", color: "#9E3A38", bgColor: "#FDF0F0", borderColor: "#E8AAAA",
      example: { bg: "#FDF0F0", labelColor: "#9E3A38", label: "Example trace",
        lines: [
          { label: "Thought", color: "#2E5090", bg: "#EDF2FA", text: "I need to find unemployment data for France in 2019." },
          { label: "Action", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("France unemployment 2019")' },
          { label: "Observation", color: "#2D7D46", bg: "#EDF7F0", text: "[No relevant results. Top result: general EU economic governance, score: 0.31]" },
          { label: "Answer", color: "#9E3A38", bg: "#FDF0F0", text: '"According to the literature, France\'s unemployment rate in 2019 was approximately 8.5%..." \u2190 <strong>Fabricated.</strong> The corpus contains no unemployment statistics. The agent drew from training data while appearing to cite the corpus.' }
        ]
      },
      safeguard: "<strong>Minimum evidence threshold.</strong> If no search result scores above 0.5, the agent should acknowledge the gap instead of synthesizing. Add a check: if all retrieval scores are below threshold, return \"The corpus does not contain information on this topic.\""
    },
    {
      name: "Format Drift", brief: "The model stops following the Thought/Action structure",
      icon: "\uD83C\uDF00", color: "#8B6914", bgColor: "#FDF8EC", borderColor: "#E8D49A",
      example: { bg: "#FDF8EC", labelColor: "#8B6914", label: "Example trace (step 4 of 6)",
        lines: [
          { label: "Thought", color: "#2E5090", bg: "#EDF2FA", text: "I've found some relevant material. Let me search for more." },
          { label: "Action", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("democratic backsliding causes")' },
          { label: "Observation", color: "#2D7D46", bg: "#EDF7F0", text: "[Results about institutional erosion, executive power, etc.]" },
          { label: "???", color: "#8B6914", bg: "#FDF8EC", text: '"Based on what I\'ve found so far, it seems like democratic backsliding is primarily caused by..." \u2190 <strong>Format broken.</strong> The model started writing a conversational answer instead of using Thought/Action format. The parser cannot extract a tool call or final answer.' }
        ]
      },
      safeguard: "<strong>Format enforcement.</strong> When the parser fails, inject a message reminding the model of the exact format. Larger models drift less frequently. Keeping conversations shorter (fewer steps) also helps."
    },
    {
      name: "Redundant Loops", brief: "The agent repeats the same actions without making progress",
      icon: "\uD83D\uDD04", color: "#6D28D9", bgColor: "#F3EEFF", borderColor: "#C9B5F5",
      example: { bg: "#F3EEFF", labelColor: "#6D28D9", label: "Example trace (steps 3-5)",
        lines: [
          { label: "Action 3", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("populism causes")' },
          { label: "Action 4", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("causes of populism")' },
          { label: "Action 5", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("what causes populism")' },
          { label: "Result", color: "#6D28D9", bg: "#F3EEFF", text: '\u2190 <strong>Three nearly identical queries.</strong> The agent used 3 of its 6 steps retrieving the same passages with slightly different wording, wasting tokens and budget.' }
        ]
      },
      safeguard: "<strong>Step budget awareness.</strong> After step N/2, inject a message: \"You have used 3 of 6 steps. Summarize what you have found so far and plan your remaining steps carefully.\" This forces the agent to take stock and diversify."
    },
    {
      name: "Cascading Errors", brief: "An early mistake propagates through the entire chain",
      icon: "\u26A1", color: "#2E5090", bgColor: "#EDF2FA", borderColor: "#B8CCE8",
      example: { bg: "#EDF2FA", labelColor: "#2E5090", label: "Example trace",
        lines: [
          { label: "Action 1", color: "#8B6914", bg: "#FDF8EC", text: 'search_literature("impact of trade agreements") \u2190 Wrong query for a question about sanctions' },
          { label: "Observe", color: "#2D7D46", bg: "#EDF7F0", text: "[Returns passages about free trade agreements, not sanctions]" },
          { label: "Action 2", color: "#8B6914", bg: "#FDF8EC", text: "extract_findings([passage about trade agreements])" },
          { label: "Answer", color: "#9E3A38", bg: "#FDF0F0", text: '"The literature suggests that international trade agreements are the primary mechanism..." \u2190 <strong>Each step is locally correct</strong> (extraction is faithful to the passage), <strong>but the chain is globally wrong</strong> because the first search was off-target.' }
        ]
      },
      safeguard: "<strong>Provenance verification.</strong> After the agent finishes, check whether each claim in the answer connects to an observation that actually addresses the original question. This catches cases where the chain drifted away from the research question."
    }
  ];

  var activeIdx = null;

  function render() {
    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive reference</div>';
    html += '<div class="widget-title">Agent Failure Modes</div>';
    html += '<p class="widget-intro">Agents fail in ways that are harder to detect than single-call errors. Click each card to see a concrete example and the safeguard that addresses it.</p>';
    html += '<div class="fm__cards">';

    for (var i = 0; i < modes.length; i++) {
      var m = modes[i];
      var isActive = activeIdx === i;
      var cls = isActive ? ' fm__card--active' : '';
      var bs = isActive ? 'border-color:' + m.borderColor + ';' : '';

      html += '<div class="fm__card' + cls + '" style="' + bs + '">';
      html += '<div class="fm__card-header" data-idx="' + i + '">';
      html += '<div class="fm__card-icon" style="background:' + m.bgColor + ';color:' + m.color + ';">' + m.icon + '</div>';
      html += '<div class="fm__card-label"><div class="fm__card-name">' + m.name + '</div><div class="fm__card-brief">' + m.brief + '</div></div>';
      html += '<div class="fm__card-chevron">\u25B6</div></div>';

      html += '<div class="fm__card-detail">';
      var ex = m.example;
      html += '<div class="fm__example" style="background:' + ex.bg + ';">';
      html += '<div class="fm__example-label" style="color:' + ex.labelColor + ';">' + ex.label + '</div>';
      for (var j = 0; j < ex.lines.length; j++) {
        var l = ex.lines[j];
        html += '<div class="fm__trace-line"><span class="fm__trace-label" style="color:' + l.color + ';background:' + l.bg + ';">' + l.label + '</span><span>' + l.text + '</span></div>';
      }
      html += '</div>';
      html += '<div class="fm__safeguard"><div class="fm__safeguard-label">Safeguard</div>' + m.safeguard + '</div>';
      html += '</div></div>';
    }

    html += '</div></div>';
    root.innerHTML = html;

    root.querySelectorAll('.fm__card-header').forEach(function (hdr) {
      hdr.addEventListener('click', function () {
        var idx = parseInt(hdr.getAttribute('data-idx'), 10);
        activeIdx = activeIdx === idx ? null : idx;
        render();
      });
    });
  }
  render();
})();
</script>
