.rl__step { position: relative; margin-bottom: 0.85rem; animation: rlStepIn 0.35s ease-out; }
@keyframes rlStepIn { from { opacity: 0; transform: translateX(-8px); } to { opacity: 1; transform: translateX(0); } }

.rl__step-dot { position: absolute; left: -1.65rem; top: 0.55rem; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; z-index: 1; }
