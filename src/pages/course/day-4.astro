  var steps = [
    {
      name: "Chunk", brief: "Split documents into retrievable pieces",
      inputLabel: "Full article (~8,000 words)",
      input: '<div class="step__io-content--prose trunc">The governance of artificial intelligence presents challenges that differ from prior technology regulation in several respects. Cihon et al. (2020) argue that AI systems are "general-purpose" in ways that make sector-specific regulation difficult, as the same underlying model can be deployed across healthcare, finance, and criminal justice...</div><div style="margin-top:0.4rem;font-size:0.75rem;color:var(--text-muted,#6B7280);font-style:italic;">+ 7,500 more words across 20 pages</div>',
      outputLabel: "16 overlapping chunks (~500 words each)",
      output: '<div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-bottom:0.4rem;"><span style="display:inline-block;font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:500;padding:0.15rem 0.45rem;border-radius:3px;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);color:var(--text-sec,#3D4455);">Chunk 1</span><span style="display:inline-block;font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:500;padding:0.15rem 0.45rem;border-radius:3px;background:var(--accent-light,#E8EEF6);border:1px solid var(--accent,#2D8ABF);color:var(--accent,#2D8ABF);">Chunk 2</span><span style="display:inline-block;font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:500;padding:0.15rem 0.45rem;border-radius:3px;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);color:var(--text-sec,#3D4455);">Chunk 3</span><span style="display:inline-block;font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:500;padding:0.15rem 0.45rem;border-radius:3px;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);color:var(--text-sec,#3D4455);">...</span><span style="display:inline-block;font-family:var(--font-mono,monospace);font-size:0.68rem;font-weight:500;padding:0.15rem 0.45rem;border-radius:3px;background:var(--surface-alt,#F5F5F0);border:1px solid var(--border,#E2E6EE);color:var(--text-sec,#3D4455);">Chunk 16</span></div><div class="step__io-content--prose" style="font-size:0.78rem;color:var(--text-sec,#3D4455);margin-top:0.35rem;"><strong style="color:var(--accent,#2D8ABF);">Chunk 2:</strong> "...AI systems are \u201Cgeneral-purpose\u201D in ways that make sector-specific regulation difficult, as the same underlying model can be deployed across healthcare, finance, and criminal justice. Existing regulatory frameworks, designed around specific applications, struggle to address a technology whose risks depend heavily on context of deployment (Marchetti 2022). Furthermore, the rapid pace..."</div>',
      choices: '<strong>Chunk size:</strong> 200-500 words is typical. Smaller chunks are more precise; larger chunks preserve more context.<br><br><strong>Overlap:</strong> 50-100 words shared between neighbours prevents information at chunk boundaries from being lost.',
      failure: 'If chunks are too large, retrieval returns a mix of relevant and irrelevant text. If too small, individual chunks lack enough context. A claim split across two chunks may not be found by either one.'
    },
    {
      name: "Embed", brief: "Convert each chunk into a dense vector",
      inputLabel: "Text chunk (natural language)",
      input: '<div class="step__io-content--prose" style="font-size:0.78rem;">AI systems are "general-purpose" in ways that make sector-specific regulation difficult, as the same underlying model can be deployed across healthcare, finance, and criminal justice...</div>',
      outputLabel: "384-dimensional vector",
      output: '<div class="vec-preview">[0.023, -0.118, 0.045, 0.201, -0.067, 0.154, -0.032, 0.089, ... ]</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);margin-top:0.35rem;">384 numbers encoding the semantic meaning of this chunk. Similar chunks will have similar vectors (high cosine similarity).</div>',
      choices: '<strong>Embedding model:</strong> all-MiniLM-L6-v2 (fast, 384d) vs. larger models like e5-large (more accurate, 1024d, slower). The embedding model determines what "similarity" means.<br><br><strong>Normalisation:</strong> vectors are typically L2-normalised so inner product equals cosine similarity.',
      failure: 'If the embedding model does not capture domain-specific meaning well, semantically relevant chunks may not have similar vectors. A passage about "executive aggrandisement" may not be close to a query about "democratic backsliding" even though they are topically related.'
    },
    {
      name: "Index", brief: "Store vectors so you can search them",
      inputLabel: "All chunk vectors (n \u00d7 384 matrix)",
      input: '<div style="font-family:var(--font-mono,monospace);font-size:0.75rem;color:var(--text-sec,#3D4455);line-height:1.5;">Chunk 1: [0.012, -0.087, 0.134, ...]<br>Chunk 2: [0.023, -0.118, 0.045, ...]<br>Chunk 3: [-0.056, 0.091, 0.022, ...]<br><span style="color:var(--text-muted,#6B7280);">... 13 more chunks ...</span><br>Chunk 16: [0.078, -0.043, 0.112, ...]</div>',
      outputLabel: "Searchable vector store",
      output: '<div style="font-family:var(--font-mono,monospace);font-size:0.75rem;color:var(--text-sec,#3D4455);line-height:1.5;"><span style="color:var(--accent,#2D8ABF);font-weight:600;">FAISS Index</span><br>Vectors: 16<br>Dimensions: 384<br>Time per query: &lt;1ms</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);margin-top:0.35rem;">The index stores all vectors and lets you quickly find the ones most similar to a new query vector. For research-scale corpora (hundreds to thousands of documents), this is essentially instant.</div>',
      choices: '<strong>Metadata:</strong> attach article title, author, year, and topic to each chunk. This lets you filter retrieval (e.g., "only search articles about democracy") rather than searching the entire corpus blindly.<br><br><strong>At research scale</strong> (up to a few thousand documents), the simplest index type works fine. You do not need to worry about approximate search methods until you reach millions of chunks.',
      failure: 'Indexing itself rarely fails. The real risk is not storing enough metadata: without article-level tags, you cannot restrict retrieval to specific subsets of the corpus, and a query about one party\u2019s immigration policy might retrieve passages from a different party that uses similar language.'
    },
    {
      name: "Retrieve", brief: "Find the most relevant chunks for a query",
      inputLabel: "Research question",
      input: '<div class="step__io-content--prose" style="font-size:0.82rem;font-weight:500;color:var(--text,#1A1D27);">"How do states approach the governance and regulation of AI?"</div><div style="font-size:0.75rem;color:var(--text-muted,#6B7280);margin-top:0.3rem;">Embedded with the same model, then compared against all vectors in the index.</div>',
      outputLabel: "Top-k chunks ranked by similarity",
      output: '<div style="font-size:0.78rem;line-height:1.6;">' +
        '<div style="margin-bottom:0.4rem;"><span style="font-family:var(--font-mono,monospace);font-weight:600;color:var(--accent,#2D8ABF);">1.</span> <span style="color:var(--text-sec,#3D4455);">AI Governance, Chunk 2</span> <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:#4C6D60;font-weight:600;">0.87</span><span class="score-bar" style="width:87%;background:#7A9A8C;"></span></div>' +
        '<div style="margin-bottom:0.4rem;"><span style="font-family:var(--font-mono,monospace);font-weight:600;color:var(--accent,#2D8ABF);">2.</span> <span style="color:var(--text-sec,#3D4455);">AI Governance, Chunk 5</span> <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:#4C6D60;font-weight:600;">0.81</span><span class="score-bar" style="width:81%;background:#7A9A8C;"></span></div>' +
        '<div style="margin-bottom:0.4rem;"><span style="font-family:var(--font-mono,monospace);font-weight:600;color:var(--accent,#2D8ABF);">3.</span> <span style="color:var(--text-sec,#3D4455);">State Capacity, Chunk 8</span> <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:#8B6914;font-weight:600;">0.63</span><span class="score-bar" style="width:63%;background:#8B6914;"></span></div>' +
        '<div style="margin-bottom:0.4rem;"><span style="font-family:var(--font-mono,monospace);font-weight:600;color:var(--accent,#2D8ABF);">4.</span> <span style="color:var(--text-sec,#3D4455);">Sanctions, Chunk 3</span> <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:#9E3A38;font-weight:600;">0.41</span><span class="score-bar" style="width:41%;background:#9E3A38;"></span></div>' +
        '<div><span style="font-family:var(--font-mono,monospace);font-weight:600;color:var(--accent,#2D8ABF);">5.</span> <span style="color:var(--text-sec,#3D4455);">Corruption, Chunk 12</span> <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:#9E3A38;font-weight:600;">0.38</span><span class="score-bar" style="width:38%;background:#9E3A38;"></span></div></div>',
      choices: '<strong>k (number of results):</strong> too few misses relevant information; too many dilutes context with irrelevant passages. k=3 to 10 is typical.<br><br><strong>Score threshold:</strong> results below a similarity threshold (e.g., 0.5) are probably irrelevant. Consider filtering them out before generation.',
      failure: 'If the query uses different vocabulary from the source, relevant chunks may score low. "How do governments regulate AI?" and "state approaches to algorithmic governance" are the same question but may retrieve different chunks. Try multiple query phrasings.'
    },
    {
      name: "Generate", brief: "Answer the question using only retrieved passages",
      inputLabel: "Prompt: question + top-k passages",
      input: '<div style="font-size:0.78rem;line-height:1.55;"><span style="color:var(--accent,#2D8ABF);font-weight:600;font-family:var(--font-mono,monospace);font-size:0.7rem;">SYSTEM:</span> <span style="color:var(--text-sec,#3D4455);">Answer using ONLY the passages below. Cite each claim.</span><br><br><span style="color:var(--accent,#2D8ABF);font-weight:600;font-family:var(--font-mono,monospace);font-size:0.7rem;">PASSAGES:</span> <span style="color:var(--text-muted,#6B7280);">[1] AI Governance, Chunk 2... [2] AI Governance, Chunk 5... [3] State Capacity, Chunk 8...</span><br><br><span style="color:var(--accent,#2D8ABF);font-weight:600;font-family:var(--font-mono,monospace);font-size:0.7rem;">QUESTION:</span> <span style="color:var(--text-sec,#3D4455);">How do states approach AI governance?</span></div>',
      outputLabel: "Grounded answer with citations",
      output: '<div class="step__io-content--prose" style="font-size:0.82rem;color:var(--text-sec,#3D4455);line-height:1.65;">"States face distinct challenges in governing AI because the technology is general-purpose and resists sector-specific regulation [1]. Existing frameworks struggle because AI risks depend on deployment context [1]. Democratic states face a particular tension between protecting citizens\u2019 rights through regulation and maintaining competitiveness through innovation [2]."</div>',
      choices: '<strong>Prompt design:</strong> explicitly instruct "only use the provided passages" and specify a citation format. Without this, the model freely mixes retrieved content with training data.<br><br><strong>Model scale:</strong> larger models synthesize across passages more faithfully. Smaller models tend to copy verbatim or introduce errors.',
      failure: 'Even with explicit instructions, models sometimes draw on training data instead of the provided context. The result looks grounded but contains claims not in the retrieved text. This is why the provenance check from Section 1 matters here too.'
    }
  ];

  var activeStep = null;

  function render() {
    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive visualisation</div>';
    html += '<div class="widget-title">The RAG Pipeline, Step by Step</div>';
    html += '<p class="widget-intro">Click each step to see what happens to the data, what design choices you face, and what goes wrong when the step fails.</p>';
    html += '<div class="pipeline">';
    for (var i = 0; i < steps.length; i++) {
      var s = steps[i];
      var cls = activeStep === i ? ' step--active' : '';
      html += '<div class="step' + cls + '">';
      html += '<div class="step__header" data-idx="' + i + '"><div class="step__number">' + (i+1) + '</div><div class="step__label"><div class="step__name">' + s.name + '</div><div class="step__brief">' + s.brief + '</div></div><div class="step__chevron">\u25B6</div></div>';
      html += '<div class="step__detail">';
      html += '<div class="step__transform"><div class="step__io"><div class="step__io-label">Input: ' + s.inputLabel + '</div><div class="step__io-content">' + s.input + '</div></div><div class="step__arrow-col">\u2192</div><div class="step__io"><div class="step__io-label">Output: ' + s.outputLabel + '</div><div class="step__io-content">' + s.output + '</div></div></div>';
