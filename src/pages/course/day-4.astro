        { label: "Cited finding", labelCls: "ff__item-label--error", cls: "ff__item--hallucinated",
          text: '<strong>Cited finding:</strong> <span class="hl-error">A 2023 OECD survey found that 78% of member states had adopted national AI strategies, though implementation varied widely across governance systems.</span><br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: OECD (2023)</span>' }
      ],
      explanation: '<strong>The third item is fabricated.</strong> The passage never mentions the OECD, the 78% figure, or national AI strategies. The model generated a plausible-sounding claim with a realistic citation, but none of it appears in the source text. Without checking against the source, you would have no reason to doubt it.'
    },
    {
      id: "omission", label: "Omission",
      statusText: "A key claim from the passage is missing from the extraction.",
      sourceHighlights: sourceText.replace(
        'Several scholars have noted that democratic states face a particular tension: the desire to regulate AI to protect citizens\u2019 rights must be balanced against the competitive pressure to foster innovation (Roberts et al. 2021, Ding 2018).',
        '<span class="hl-missing">Several scholars have noted that democratic states face a particular tension: the desire to regulate AI to protect citizens\u2019 rights must be balanced against the competitive pressure to foster innovation (Roberts et al. 2021, Ding 2018).</span>'
      ),
      items: [
        { label: "Claim", labelCls: "ff__item-label--ok", cls: "ff__item--ok",
          text: '<strong>Claim:</strong> AI governance differs from prior technology regulation because AI systems are general-purpose.<br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: Cihon et al. (2020)</span>' },
        { label: "Cited finding", labelCls: "ff__item-label--ok", cls: "ff__item--ok",
          text: '<strong>Cited finding:</strong> Existing regulatory frameworks struggle with AI because its risks depend on deployment context.<br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: Marchetti (2022)</span>' },
        { label: "Missing", labelCls: "ff__item-label--warning", cls: "",
          text: '<em style="color:#8B6914;">The passage\u2019s argument about democratic states balancing rights protection against innovation pressure (Roberts et al. 2021, Ding 2018) was not extracted. This is highlighted in yellow in the source text.</em>' }
      ],
      explanation: '<strong>The democratic tension argument is missing.</strong> The model silently dropped the most nuanced political argument while keeping the straightforward definitional claims. Omissions systematically bias your dataset toward whatever the model finds easiest to extract.'
    },
    {
      id: "distortion", label: "Distortion",
      statusText: "An extracted claim subtly changes the meaning of the source.",
      sourceHighlights: sourceText.replace(
        'the desire to regulate AI to protect citizens\u2019 rights must be balanced against the competitive pressure to foster innovation (Roberts et al. 2021, Ding 2018)',
        '<span class="hl-distorted">the desire to regulate AI to protect citizens\u2019 rights must be balanced against the competitive pressure to foster innovation (Roberts et al. 2021, Ding 2018)</span>'
      ),
      items: [
        { label: "Claim", labelCls: "ff__item-label--ok", cls: "ff__item--ok",
          text: '<strong>Claim:</strong> AI governance differs from prior technology regulation because AI systems are general-purpose.<br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: Cihon et al. (2020)</span>' },
        { label: "Cited finding", labelCls: "ff__item-label--ok", cls: "ff__item--ok",
          text: '<strong>Cited finding:</strong> Existing regulatory frameworks struggle with AI because its risks depend on deployment context.<br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: Marchetti (2022)</span>' },
        { label: "Claim (distorted)", labelCls: "ff__item-label--distorted", cls: "ff__item--distorted",
          text: '<strong>Claim:</strong> Democratic states <span class="hl-distort">prioritise innovation over regulation</span> when it comes to AI governance.<br><span style="font-size:0.78rem;color:var(--text-muted,#6B7280);">Source: Roberts et al. (2021), Ding (2018)</span>' }
      ],
      explanation: '<strong>The third claim changes the meaning.</strong> The passage describes a <em>tension</em> that must be \u201Cbalanced\u201D; the extraction converts this into a claim that states \u201Cprioritise innovation over regulation.\u201D Same citation, same topic, shifted meaning. In a dataset, this would systematically bias toward more one-sided characterisations of the literature.'
    }
  ];

  var activeMode = 0;

  function render() {
    var m = modes[activeMode];
    var tabsHtml = '';
    for (var t = 0; t < modes.length; t++) {
      var actCls = t === activeMode ? ' ff__tab--active ff__tab--' + modes[t].id : '';
      tabsHtml += '<button class="ff__tab' + actCls + '" data-idx="' + t + '">' + modes[t].label + '</button>';
    }
    var itemsHtml = '';
    for (var i = 0; i < m.items.length; i++) {
      var item = m.items[i];
      itemsHtml += '<div class="ff__item ' + item.cls + '"><div class="ff__item-label ' + item.labelCls + '">' + item.label + '</div>' + item.text + '</div>';
    }
    var dotColors = { faithful: '#4C6D60', hallucination: '#B83230', omission: '#8B6914', distortion: '#6D28D9' };

    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive visualisation</div>';
    html += '<div class="widget-title">The Three Failure Modes of Extraction</div>';
    html += '<p class="widget-intro">Click each tab to see the same passage with a faithful extraction and then each failure mode. Errors are highlighted so you can compare against the source.</p>';
    html += '<div class="ff__tabs">' + tabsHtml + '</div>';
    html += '<div class="ff__panel ff__panel--' + m.id + '">';
    html += '<div class="ff__status ff__status--' + m.id + '"><span class="ff__status-dot" style="background:' + dotColors[m.id] + ';"></span>' + m.statusText + '</div>';
    html += '<div class="ff__columns wfade">';
    html += '<div class="ff__col ff__col--source"><div class="ff__col-label">Source passage</div><div class="ff__source-text">' + m.sourceHighlights + '</div></div>';
    html += '<div class="ff__col"><div class="ff__col-label">Model extraction</div>' + itemsHtml + '</div>';
    html += '</div>';
    html += '<div class="ff__explanation">' + m.explanation + '</div>';
    html += '</div></div>';

    root.innerHTML = html;
    root.querySelectorAll('.ff__tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        activeMode = parseInt(tab.getAttribute('data-idx'), 10);
        render();
      });
    });
  }
  render();
})();
</script>

