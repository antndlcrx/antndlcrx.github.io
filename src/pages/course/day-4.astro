<!-- 3. CHUNKING STRATEGY VISUALISER                                     -->
<!-- =================================================================== -->
<script is:inline>
(function () {
  var root = document.getElementById("chunking-visualiser-root");
  if (!root) return;

  var sentences = [
    "The governance of artificial intelligence presents challenges that differ from prior technology regulation in several respects.",
    "Cihon et al. (2020) argue that AI systems are \u201Cgeneral-purpose\u201D in ways that make sector-specific regulation difficult, as the same underlying model can be deployed across healthcare, finance, and criminal justice.",
    "Existing regulatory frameworks, designed around specific applications, struggle to address a technology whose risks depend heavily on context of deployment (Marchetti 2022).",
    "Furthermore, the rapid pace of AI development means that regulatory processes often lag behind the technology they aim to govern.",
    "Several scholars have noted that democratic states face a particular tension: the desire to regulate AI to protect citizens\u2019 rights must be balanced against the competitive pressure to foster innovation (Roberts et al. 2021, Ding 2018).",
    "Authoritarian regimes, by contrast, face fewer domestic constraints but must navigate international norms and the reputational costs of deploying AI for surveillance (Feldstein 2019).",
    "The result is a fragmented global landscape in which regulatory approaches vary widely across political systems, with limited convergence on standards or enforcement mechanisms.",
    "This fragmentation poses particular challenges for AI systems that operate across borders, as compliance with one jurisdiction\u2019s requirements may conflict with another\u2019s."
  ];

  var query = "How do democratic states balance AI regulation with innovation?";

  var strategies = [
    {
      tabLabel: "Small (~2 sent.)", chunkSize: "~40 words", numChunks: 4, overlap: "None",
      chunks: [
        { sentIdx: [0,1], label: "1", colorCls: "1", retrieval: "partial", score: "0.58" },
        { sentIdx: [2,3], label: "2", colorCls: "2", retrieval: "partial", score: "0.52" },
        { sentIdx: [4,5], label: "3", colorCls: "3", retrieval: "yes", score: "0.84" },
        { sentIdx: [6,7], label: "4", colorCls: "4", retrieval: "no", score: "0.31" }
      ],
      analysis: { labelCls: "cv__analysis-label--problem", label: "Problem: boundary splits context",
        text: '<strong>Chunk 3 is retrieved</strong> and contains the key claim about democratic states (sentence 5). But sentence 4 ("regulatory processes lag behind the technology") is in Chunk 2, separated from the democratic tension argument it sets up. The model sees the conclusion without the buildup.' }
    },
    {
      tabLabel: "Medium + overlap", chunkSize: "~80 words", numChunks: 3, overlap: "1 sentence",
      chunks: [
        { sentIdx: [0,1,2], label: "1", colorCls: "1", retrieval: "partial", score: "0.55" },
        { sentIdx: [2,3,4,5], label: "2", colorCls: "2", retrieval: "yes", score: "0.86", overlapIdx: [2] },
        { sentIdx: [5,6,7], label: "3", colorCls: "3", retrieval: "no", score: "0.34", overlapIdx: [5] }
      ],
      analysis: { labelCls: "cv__analysis-label--good", label: "This works well",
        text: '<strong>Chunk 2 captures the full argument.</strong> It includes the regulatory lag (sentence 4) and the democratic tension (sentence 5), preserving the logical connection. The overlap means sentence 3 appears in both Chunks 1 and 2, so context is not lost at the boundary.' }
    },
    {
      tabLabel: "Large (full para.)", chunkSize: "~160 words", numChunks: 1, overlap: "N/A",
      chunks: [
        { sentIdx: [0,1,2,3,4,5,6,7], label: "1", colorCls: "1", retrieval: "yes", score: "0.71" }
      ],
      analysis: { labelCls: "cv__analysis-label--tradeoff", label: "Trade-off: context preserved, relevance diluted",
        text: '<strong>The whole passage is one chunk.</strong> No information is lost, but the similarity score (0.71) is lower than the medium strategy (0.86) because the chunk is diluted with irrelevant sentences. In a real corpus, this chunk competes against others, and the diluted score may push it below more focused results from other articles.' }
    }
  ];

  var activeStrategy = 1;

  function render() {
    var s = strategies[activeStrategy];
    var overlapSentences = {};
    for (var ci = 0; ci < s.chunks.length; ci++) {
      if (s.chunks[ci].overlapIdx) {
        for (var oi = 0; oi < s.chunks[ci].overlapIdx.length; oi++) overlapSentences[s.chunks[ci].overlapIdx[oi]] = true;
      }
    }

    var tabsHtml = '';
    for (var t = 0; t < strategies.length; t++) {
      var actCls = t === activeStrategy ? ' cv__tab--active' : '';
      tabsHtml += '<button class="cv__tab' + actCls + '" data-idx="' + t + '">' + strategies[t].tabLabel + '</button>';
    }

    var textHtml = '';
    for (var ci = 0; ci < s.chunks.length; ci++) {
      var chunk = s.chunks[ci];
      if (ci > 0) textHtml += '<span class="chunk-boundary"></span> ';
      textHtml += '<span class="chunk-label chunk-label--' + chunk.colorCls + '">Chunk ' + chunk.label + '</span>';
      var badgeCls = chunk.retrieval === "yes" ? "retrieval-badge--yes" : chunk.retrieval === "partial" ? "retrieval-badge--partial" : "retrieval-badge--no";
      var badgeText = chunk.retrieval === "yes" ? "\u2713 Retrieved (" + chunk.score + ")" : chunk.retrieval === "partial" ? "~ Borderline (" + chunk.score + ")" : "\u2717 Not retrieved (" + chunk.score + ")";
      textHtml += '<span class="retrieval-badge ' + badgeCls + '">' + badgeText + '</span> ';
      textHtml += '<span class="chunk chunk--' + chunk.colorCls + '">';
      for (var j = 0; j < chunk.sentIdx.length; j++) {
        var sIdx = chunk.sentIdx[j];
        var isOverlap = overlapSentences[sIdx] && ci > 0 && chunk.overlapIdx && chunk.overlapIdx.indexOf(sIdx) >= 0;
        if (isOverlap) {
          textHtml += '<span class="overlap-marker">overlap</span><span class="chunk chunk--overlap">' + sentences[sIdx] + '</span> ';
        } else {
          textHtml += sentences[sIdx] + ' ';
        }
      }
      textHtml += '</span>';
    }

    var html = '<div class="widget-wrap">';
    html += '<div class="widget-eyebrow">Interactive visualisation</div>';
    html += '<div class="widget-title">How Chunking Affects Retrieval</div>';
    html += '<p class="widget-intro">The same passage, split three different ways. Watch how chunk boundaries determine what the retriever can find.</p>';
    html += '<div class="cv__query"><span class="cv__query-label">Query</span><span class="cv__query-text">"' + query + '"</span></div>';
    html += '<div class="cv__tabs">' + tabsHtml + '</div>';
    html += '<div class="cv__panel">';
    html += '<div class="cv__strategy-bar"><div class="cv__strategy-stat">Chunk size: <strong>' + s.chunkSize + '</strong></div><div class="cv__strategy-stat">Chunks: <strong>' + s.numChunks + '</strong></div><div class="cv__strategy-stat">Overlap: <strong>' + s.overlap + '</strong></div></div>';
    html += '<div class="cv__text-area wfade">' + textHtml + '</div>';
    html += '<div class="cv__analysis wfade"><div class="cv__analysis-label ' + s.analysis.labelCls + '">' + s.analysis.label + '</div>' + s.analysis.text + '</div>';
    html += '</div>';
    html += '<div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:0.75rem;font-size:0.72rem;color:var(--text-muted,#6B7280);">';
    html += '<span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#FEF0C7;border-bottom:2.5px solid #D97706;vertical-align:middle;margin-right:3px;"></span> Overlap (shared between adjacent chunks)</span>';
    html += '<span><span style="display:inline-block;width:0;height:10px;border-left:2px dashed var(--text-muted,#6B7280);vertical-align:middle;margin-right:5px;opacity:0.4;"></span> Chunk boundary</span>';
    html += '</div></div>';

    root.innerHTML = html;
    root.querySelectorAll('.cv__tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        activeStrategy = parseInt(tab.getAttribute('data-idx'), 10);
        render();
      });
    });
  }
  render();
})();
</script>

