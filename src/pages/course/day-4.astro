      html += '</div></div>';
    }
    html += '</div></div>';
    root.innerHTML = html;

    root.querySelectorAll('.step__header').forEach(function (hdr) {
      hdr.addEventListener('click', function () {
        var idx = parseInt(hdr.getAttribute('data-idx'), 10);
        activeStep = activeStep === idx ? null : idx;
        render();
      });
    });
  }
  render();
})();
</script>

