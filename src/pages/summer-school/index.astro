---
import Base from '../../layouts/Base.astro';
import ApplicationsStatus from '../../components/ApplicationsStatus.astro';
---

<Base
  title="Summer School"
  description="Oxford LLMs Summer School 2026 — a five-day intensive on LLMs for social science. 13–17 July, Nuffield College, Oxford."
>

  <!-- ── Status strip ───────────────────────────────────────── -->
  <ApplicationsStatus />

  <!-- ── Hero: date as typography ───────────────────────────── -->
  <header class="hero-event">
    <div class="hero-rule-top"></div>
    <div class="hero-event-inner">

      <div class="event-date">
        <div class="ed-kicker">Summer School 2026</div>
        <div class="ed-range">13&ndash;17</div>
        <div class="ed-month">July 2026</div>
        <div class="ed-where">
          <span>Nuffield College</span>
          <span style="opacity:.4; margin:0 6px;">·</span>
          <span>Oxford</span>
        </div>
      </div>

      <div class="event-content">
        <h1 class="h-title">
          A five-day intensive for early-career social scientists
          working with language models.
        </h1>
        <p class="lede-v3" style="margin-bottom:28px;">
          Mornings: technical lectures from ML practitioners and invited researchers.
          Afternoons: hands-on labs and a week-long collaborative research project.
          Tuition is free for all admitted participants.
        </p>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a class="btn-primary" href="/summer-school/2026/#apply">
            Application status <span class="arrow">→</span>
          </a>
          <a class="btn-ghost" href="/summer-school/2026/">2026 details <span class="arrow">→</span></a>
        </div>
      </div>

    </div>
  </header>

  <!-- ── Stats ──────────────────────────────────────────────── -->
  <section style="padding: clamp(48px,6vw,80px) 0 clamp(40px,5vw,64px);">
    <div class="shell">
      <div class="stats-v3 reveal">
        <div class="stat-v3">
          <span class="stat-n">4th</span>
          <span class="stat-l">Year running</span>
        </div>
        <div class="stat-v3">
          <span class="stat-n">30</span>
          <span class="stat-l">Places</span>
        </div>
        <div class="stat-v3">
          <span class="stat-n">5</span>
          <span class="stat-l">Days</span>
        </div>
        <div class="stat-v3">
          <span class="stat-n">£0</span>
          <span class="stat-l">Tuition fee</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── § 01 Past cohorts ──────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="past">
    <span class="section-number">§ 01 · Past cohorts</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Three years in</div>
          <h2 class="h-section">A participant-to-co-author pipeline.</h2>
        </div>
        <p class="lede-v3">
          The school is designed around a participant-to-co-author pipeline.
          Collaborative projects begun during the week continue beyond it: in 2025, a team of
          participants and speakers submitted a joint paper for peer review.
        </p>
      </div>

      <div class="cohort-timeline reveal">

        <a class="cohort-entry" href="/summer-school/2025/">
          <div class="ce-content">
            <span class="ce-year">2025</span>
            <span class="ce-edition">Third edition · September 2025</span>
            <h3 class="ce-title">30 researchers. A prediction competition. One paper submitted.</h3>
            <p class="ce-desc">
              Lectures on LLM fundamentals, evaluation, fine-tuning, AI agents, and AI safety.
              A Kaggle-style prediction competition ran alongside the research project.
              A team of participants and speakers continued the work after September and submitted
              it for peer review.
            </p>
            <span class="btn-link-v3">Read the 2025 report <span class="arrow">→</span></span>
          </div>
          <div class="ce-photo">
            <img src="/img/posts/report_2025/group_photo_2025.jpg"
                 alt="Oxford LLMs 2025 cohort at Nuffield College" />
          </div>
        </a>

        <a class="cohort-entry" href="/summer-school/2024/">
          <div class="ce-content">
            <span class="ce-year">2024</span>
            <span class="ce-edition">Second edition · September 2024</span>
            <h3 class="ce-title">30 participants from ~200 applications.</h3>
            <p class="ce-desc">
              Applied tutorials on RAG, observability, and agent-based systems.
              A cross-discipline line-up of NLP engineers, social scientists, and
              practitioners from Qdrant, Ori Cloud, Arize, and Google.
            </p>
            <span class="btn-link-v3">Read the 2024 report <span class="arrow">→</span></span>
          </div>
          <div class="ce-photo">
            <img src="/img/posts/report_2024/group_llms_2024.jpg"
                 alt="Oxford LLMs 2024 cohort at Nuffield College" />
          </div>
        </a>

        <a class="cohort-entry" href="/summer-school/2023/">
          <div class="ce-content">
            <span class="ce-year">2023</span>
            <span class="ce-edition">Inaugural edition · September 2023</span>
            <h3 class="ce-title">The first Oxford LLMs workshop.</h3>
            <p class="ce-desc">
              Convened by Elena Voita and Ilya Boytsov for a cohort of ~30 early-career
              researchers exploring transformers, text-as-data methods, and the emerging
              landscape of large language models.
            </p>
            <span class="btn-link-v3">Read the 2023 report <span class="arrow">→</span></span>
          </div>
          <div class="ce-photo">
            <img src="/img/posts/report_2023/group_llms_2023.jpg"
                 alt="Oxford LLMs 2023 inaugural cohort at Nuffield College" />
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ── § 02 Materials ────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker section-tinted-v3" id="materials"
           style="padding-bottom: clamp(56px, 7vw, 88px);">
    <span class="section-number">§ 02 · Materials</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Open access</div>
          <h2 class="h-section">Slides and notebooks from past editions.</h2>
        </div>
        <p class="lede-v3">
          All lecture slides and coding materials are published openly after each edition.
          Datasets and model checkpoints from collaborative research projects are on Hugging Face.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 20px;"
           class="reveal-stagger">

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:10px">2023 · Inaugural</div>
          <h3 class="h-sub" style="margin-bottom:14px">Slides &amp; notebooks</h3>
          <a class="btn-link-v3" href="https://github.com/antndlcrx/oxford-llms-workshop"
             target="_blank" rel="noopener" style="display:flex; align-items:center; gap:7px;">
            <img src="/img/icons/github-mark.svg" alt="" style="width:15px; height:15px; opacity:0.75; flex-shrink:0;">
            GitHub repository <span class="arrow">→</span>
          </a>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:10px">2024 · Second edition</div>
          <h3 class="h-sub" style="margin-bottom:14px">Slides, notebooks &amp; datasets</h3>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <a class="btn-link-v3" href="https://github.com/antndlcrx/oxford-llms-workshop"
               target="_blank" rel="noopener" style="display:flex; align-items:center; gap:7px;">
              <img src="/img/icons/github-mark.svg" alt="" style="width:15px; height:15px; opacity:0.75; flex-shrink:0;">
              GitHub repository <span class="arrow">→</span>
            </a>
            <a class="btn-link-v3" href="https://huggingface.co/oxford-llms"
               target="_blank" rel="noopener" style="display:flex; align-items:center; gap:7px;">
              <img src="/img/icons/hf-logo.svg" alt="" style="width:15px; height:15px; flex-shrink:0;">
              Hugging Face <span class="arrow">→</span>
            </a>
          </div>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:10px">2025 · Third edition</div>
          <h3 class="h-sub" style="margin-bottom:14px">Slides, notebooks &amp; datasets</h3>
          <p class="copy" style="margin:0; font-size:13px; color:var(--text-muted);">
            Materials are being uploaded and will appear here shortly.
          </p>
        </article>

      </div>
    </div>
  </section>

</Base>
