---
import Base from '../../layouts/Base.astro';
import SpeakerModal from '../../components/SpeakerModal.astro';
---

<Base
  title="Oxford LLMs 2025"
  description="Oxford LLMs 2025 — third annual workshop on large language models for social science. Nuffield College, September 2025."
>

  <!-- ── Breadcrumb strip ───────────────────────────────────── -->
  <aside class="status-strip" aria-label="Page breadcrumb">
    <div class="status-strip-inner">
      <a href="/summer-school/" style="color:inherit; text-decoration:none;">Summer School</a>
      <span class="sep"></span>
      <span>2025 — Third edition</span>
    </div>
  </aside>

  <!-- ── Report hero ────────────────────────────────────────── -->
  <div class="report-hero">
    <div class="rh-inner">
      <div>
        <p class="rh-kicker">Third edition · September 2025</p>
        <span class="rh-year">2025</span>
        <p class="rh-title">Nuffield College, Oxford — five-day intensive on LLMs for social science.</p>
        <div class="rh-stats">
          <div class="rh-stat"><span class="rh-n">30</span><span class="rh-l">Participants</span></div>
          <div class="rh-stat"><span class="rh-n">~150</span><span class="rh-l">Applications</span></div>
          <div class="rh-stat"><span class="rh-n">5</span><span class="rh-l">Days</span></div>
          <div class="rh-stat"><span class="rh-n">1</span><span class="rh-l">Paper in review</span></div>
        </div>
      </div>
      <div class="rh-photo">
        <img src="/img/posts/report_2025/group_photo_2025.jpg" alt="Oxford LLMs 2025 cohort at Nuffield College" />
      </div>
    </div>
  </div>

  <!-- ── § 01 About ─────────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="about">
    <span class="section-number">§ 01 · About</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Third edition</div>
          <h2 class="h-section">From workshop to submitted paper.</h2>
        </div>
        <p class="lede-v3">
          Nuffield College hosted the third Oxford workshop on LLMs for Social Science in late September
          2025, supported by the Oxford Van Houten Fund and Nuffield College.
        </p>
      </div>
      <div class="reveal" style="max-width: 72ch;">
        <p class="copy" style="margin: 0 0 18px;">
          We received just under 150 applications and selected 30 participants drawn from politics,
          sociology, linguistics, economics, history, and law. The five-day programme paired morning
          lectures with afternoon hands-on labs and a week-long collaborative research competition.
        </p>
        <p class="copy" style="margin: 0 0 18px;">
          The lecture series covered LLM fundamentals, evaluation methods, fine-tuning, AI agents,
          and AI safety. Social science guest talks from Raymond Duch, Joan Timoneda, Kosuke Imai,
          Charles Rahal, and Brandon Stewart illustrated live applications at the intersection of NLP
          and the social sciences. The Kaggle-style prediction competition gave participants direct
          experience building systems that use LLMs to predict human survey responses across
          countries and contexts.
        </p>
        <p class="copy" style="margin: 0 0 18px;">
          A team of participants and speakers continued the project after September. They have since
          submitted the work for review at a peer-reviewed conference.
        </p>
        <p class="copy" style="margin: 0;">
          An opening pub evening and a guided walking tour of Oxford gave participants and speakers
          time together outside the lecture room, and many of the most productive conversations
          of the week happened along the way.
        </p>
      </div>
    </div>
  </section>

  <!-- ── § 02 Programme ────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker section-tinted-v3" id="programme">
    <span class="section-number">§ 02 · Programme</span>
