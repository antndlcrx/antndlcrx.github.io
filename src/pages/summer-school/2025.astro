            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title">Research</span></li>
            <li class="prog-slot"><span class="prog-time">10:30</span><span class="prog-title">Oxford walking tour — participants &amp; speakers</span></li>
            <li class="prog-slot"><span class="prog-time">14:15</span><span class="prog-title">Research</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title">Kosuke Imai — <a href="https://imai.fas.harvard.edu/research/GPI.html" target="_blank" rel="noopener">GenAI-Powered Inference</a></span></li>
          </ol>
