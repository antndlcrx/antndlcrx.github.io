---
import Base from '../../layouts/Base.astro';
import SpeakerModal from '../../components/SpeakerModal.astro';
---

<Base
  title="Oxford LLMs 2026 — Programme"
  description="Programme, support, and speakers for the Oxford LLMs Summer School 2026 — 13–17 July, Nuffield College, Oxford."
>

  <!-- ── Manuscript hero with TOC rail ──────────────────────── -->
  <section class="hero-manuscript">
    <div class="hero-ms-inner">

      <aside class="hero-ms-rail">
        <span class="rail-label">2026</span>
        <ol class="rail-toc">
          <li>
            <a href="#programme">
              <span class="t-num">01</span>
              <span class="t-name">Programme</span>
            </a>
          </li>
          <li>
            <a href="#speakers">
              <span class="t-num">02</span>
              <span class="t-name">Speakers</span>
            </a>
          </li>
          <li>
            <a href="#support">
              <span class="t-num">03</span>
              <span class="t-name">Arrangements</span>
            </a>
          </li>
          <li>
            <a href="#venue">
              <span class="t-num">04</span>
              <span class="t-name">Venue</span>
            </a>
          </li>
        </ol>
        <div class="rail-foot">
          <span>13–17 July</span>
          <span>Oxford</span>
        </div>
      </aside>

      <div class="hero-ms-content">
        <p class="eyebrow-v3">Summer School 2026</p>
        <h1 class="hero-title h-display" style="margin: 16px 0 24px;">
          Fourth edition.<br>Nuffield College,<br>Oxford.
        </h1>
        <p class="lede-v3">
          Programme details, confirmed topics, and costs and support for the 2026 school.
          Applications are closed; applicants have been notified and this year's cohort
          is confirmed. We look forward to welcoming participants to Nuffield College,
          13–17 July.
        </p>
      </div>

    </div>
  </section>

  <!-- ── § 01 Programme ─────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="programme">
    <span class="section-number">§ 01 · Programme</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">13–17 July 2026</div>
          <h2 class="h-section">The 2026 programme.</h2>
        </div>
        <p class="lede-v3">
          Five days at Nuffield College, 09:00–17:00 daily, combining technical depth with
          research application. The week is built around three components:
        </p>
      </div>

      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 20px;"
           class="reveal-stagger">

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Industry lectures &amp; seminars</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            Technical foundations from practitioners building language models in industry —
            efficient and continual learning, agents and evaluation, inference economics,
            and LLM data and RL environments.
          </p>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Collaborative research project</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            A Kaggle-style prediction competition on a real social science research problem.
            Teams work through afternoon lab sessions, with guidance available from
            industry participants.
          </p>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px">Social science guest talks</h3>
          <p class="copy" style="margin:0; font-size:14px;">
            Invited researchers present social science applications: opinion prediction,
            document classification, and text-as-data methods, connecting the technical
            sessions to real research problems.
          </p>
        </article>

      </div>

      <div class="section-head-v3 reveal" style="margin-top:48px;">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Day by day</div>
          <h2 class="h-section">The week at a glance.</h2>
        </div>
        <p class="lede-v3">
          Morning lectures and seminars, afternoon group research, closing guest talks.
          “Group research” is the participants' collaborative project work.
          Click a speaker to jump to their profile.
        </p>
      </div>

      <div class="prog-week reveal">

        <div class="prog-day">
          <div class="prog-day-head">
            <span class="prog-day-date">Mon · 13 Jul</span>
            <span class="prog-day-theme">Efficient LLMs</span>
          </div>
          <ol class="prog-slots">
            <li class="prog-slot prog-break"><span class="prog-time">09:00</span><span class="prog-title">Morning Coffee</span></li>
            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title"><a href="#sp-ilya-boytsov">Ilya Boytsov</a> — Efficient LLMs: Principles and Compression Techniques</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">10:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">11:00</span><span class="prog-title"><a href="#sp-margaret-roberts">Margaret Roberts</a> — Research Talk</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">12:30</span><span class="prog-title">Lunch</span></li>
            <li class="prog-slot"><span class="prog-time">14:00</span><span class="prog-title"><a href="#sp-tatiana-shavrina">Tatiana Shavrina</a> — LLM Agents and Evaluations</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">15:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title"><a href="#sp-roberto-maura-rivero">Roberto-Rafael Maura-Rivero</a> — Research Talk</span></li>
            <li class="prog-slot"><span class="prog-time">19:00</span><span class="prog-title">Welcome Social</span></li>
          </ol>
        </div>

        <div class="prog-day">
          <div class="prog-day-head">
            <span class="prog-day-date">Tue · 14 Jul</span>
            <span class="prog-day-theme">Continual Learning</span>
          </div>
          <ol class="prog-slots">
            <li class="prog-slot prog-break"><span class="prog-time">09:00</span><span class="prog-title">Morning Coffee</span></li>
            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title"><a href="#sp-sagi-shaier">Sagi Shaier</a> — Continual Learning: Why Models Forget, and What We Can Do About It</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">10:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">12:30</span><span class="prog-title">Lunch</span></li>
            <li class="prog-slot"><span class="prog-time">14:00</span><span class="prog-title">Group Research Project</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">15:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title"><a href="#sp-christopher-barrie">Christopher Barrie</a> — Guest Talk</span></li>
          </ol>
        </div>

        <div class="prog-day">
          <div class="prog-day-head">
            <span class="prog-day-date">Wed · 15 Jul</span>
            <span class="prog-day-theme">Research &amp; Oxford Tour</span>
          </div>
          <ol class="prog-slots">
            <li class="prog-slot prog-break"><span class="prog-time">09:00</span><span class="prog-title">Morning Coffee</span></li>
            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title">Group Research Project</span></li>
            <li class="prog-slot"><span class="prog-time">10:45</span><span class="prog-title">Oxford Walking Tour</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">12:30</span><span class="prog-title">Lunch</span></li>
            <li class="prog-slot"><span class="prog-time">14:00</span><span class="prog-title">Group Research Project</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">15:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title">Guest Talk <em>(to be confirmed)</em></span></li>
          </ol>
        </div>

        <div class="prog-day">
          <div class="prog-day-head">
            <span class="prog-day-date">Thu · 16 Jul</span>
            <span class="prog-day-theme">Language in LLMs</span>
          </div>
          <ol class="prog-slots">
            <li class="prog-slot prog-break"><span class="prog-time">09:00</span><span class="prog-title">Morning Coffee</span></li>
            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title"><a href="#sp-piotr-mazurek">Piotr Mazurek</a> — The Economics of LLM Inference</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">10:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">11:00</span><span class="prog-title"><a href="#sp-tatiana-lando">Tatiana Lando</a> — Language in LLMs: Is It Solved?</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">12:30</span><span class="prog-title">Lunch</span></li>
            <li class="prog-slot"><span class="prog-time">14:00</span><span class="prog-title">Group Research Project</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">15:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title"><a href="#sp-thomas-robinson">Thomas Robinson</a> — Research Talk</span></li>
          </ol>
        </div>

        <div class="prog-day">
          <div class="prog-day-head">
            <span class="prog-day-date">Fri · 17 Jul</span>
            <span class="prog-day-theme">Data, RL &amp; Presentations</span>
          </div>
          <ol class="prog-slots">
            <li class="prog-slot prog-break"><span class="prog-time">09:00</span><span class="prog-title">Morning Coffee</span></li>
            <li class="prog-slot"><span class="prog-time">09:15</span><span class="prog-title"><a href="#sp-sergei-skvortsov">Sergei Skvortsov</a> — From Days to Hours: Accelerating LLM-Driven Research with Cloud and Self-Hosted Models</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">10:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">11:00</span><span class="prog-title"><a href="#sp-ibragim-badertdinov">Ibragim Badertdinov</a> — LLM Data and RL Environments</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">12:30</span><span class="prog-title">Lunch</span></li>
            <li class="prog-slot"><span class="prog-time">14:00</span><span class="prog-title">Group Research Project Presentations</span></li>
            <li class="prog-slot prog-break"><span class="prog-time">15:45</span><span class="prog-title">Coffee Break</span></li>
            <li class="prog-slot"><span class="prog-time">16:00</span><span class="prog-title">Guest Talk <em>(to be confirmed)</em></span></li>
          </ol>
        </div>

      </div>

      <div class="reveal" style="margin-top:28px;">
        <p class="copy" style="color:var(--text-dim); max-width:64ch; margin:0;">
          The programme is close to final; a few sessions are still being confirmed
          (marked <em>to be confirmed</em> above). For a sense of how the week runs, see the
          <a href="/summer-school/2025/#programme">2025 programme</a>.
          Materials from past editions are on
          <a href="https://github.com/antndlcrx/oxford-llms-workshop" target="_blank" rel="noopener">GitHub</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ── § 02 Speakers ──────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker section-tinted-v3" id="speakers">
    <span class="section-number">§ 02 · Speakers</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Confirmed · more to follow</div>
          <h2 class="h-section">Speakers.</h2>
        </div>
      </div>

      <div class="speaker-grid speaker-grid--team reveal-stagger">

        <button id="sp-ibragim-badertdinov" class="speaker-chip" data-speaker="ibragim-badertdinov" data-name="Ibragim Badertdinov" data-role="Lead Engineer, Nebius" data-tag="Lecturer" data-img="/img/speakers/ibragim_badertdinov.jpeg">
          <div class="sc-portrait"><img src="/img/speakers/ibragim_badertdinov.jpeg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Ibragim Badertdinov</p><p class="sc-role">Lead Engineer, Nebius</p></div>
        </button>

        <button id="sp-christopher-barrie" class="speaker-chip" data-speaker="christopher-barrie" data-name="Christopher Barrie" data-role="Assistant Professor of Sociology, NYU" data-tag="Research Talk" data-img="/img/speakers/chris_bairre.png">
          <div class="sc-portrait"><img src="/img/speakers/chris_bairre.png" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Research Talk</span><p class="sc-name">Christopher Barrie</p><p class="sc-role">Assistant Professor of Sociology, NYU</p></div>
        </button>

        <button id="sp-ilya-boytsov" class="speaker-chip" data-speaker="ilya-boytsov-26" data-name="Ilya Boytsov" data-role="Sr. ML Engineer, Nebius" data-tag="Organiser · Lecturer" data-img="/img/speakers/ilya_boystov.jpg">
          <div class="sc-portrait"><img src="/img/speakers/ilya_boystov.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Organiser · Lecturer</span><p class="sc-name">Ilya Boytsov</p><p class="sc-role">Sr. ML Engineer, Nebius</p></div>
        </button>

        <button id="sp-tatiana-lando" class="speaker-chip" data-speaker="tatiana-lando" data-name="Tatiana Lando" data-role="Senior Research Scientist, Google DeepMind" data-tag="Lecturer" data-img="/img/speakers/tatiana_lando.jpg">
          <div class="sc-portrait"><img src="/img/speakers/tatiana_lando.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Tatiana Lando</p><p class="sc-role">Senior Research Scientist, Google DeepMind</p></div>
        </button>

        <button id="sp-roberto-maura-rivero" class="speaker-chip" data-speaker="roberto-maura-rivero" data-name="Roberto-Rafael Maura-Rivero" data-role="Research Engineer, Meta · Oxford" data-tag="Research Talk" data-img="/img/speakers/roberto_rafael_maura_rivero.jpg">
          <div class="sc-portrait"><img src="/img/speakers/roberto_rafael_maura_rivero.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Research Talk</span><p class="sc-name">Roberto-Rafael Maura-Rivero</p><p class="sc-role">Research Engineer, Meta · Oxford</p></div>
        </button>

        <button id="sp-piotr-mazurek" class="speaker-chip" data-speaker="piotr-mazurek" data-name="Piotr Mazurek" data-role="Member of Technical Staff, Liquid.AI" data-tag="Lecturer" data-img="/img/speakers/piotr_mazurek.jpg">
          <div class="sc-portrait"><img src="/img/speakers/piotr_mazurek.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Piotr Mazurek</p><p class="sc-role">Member of Technical Staff, Liquid.AI</p></div>
        </button>

        <button id="sp-margaret-roberts" class="speaker-chip" data-speaker="margaret-roberts" data-name="Margaret Roberts" data-role="Professor of Political Science, UC San Diego" data-tag="Research Talk" data-img="/img/speakers/margaret_roberts.jpg">
          <div class="sc-portrait"><img src="/img/speakers/margaret_roberts.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Research Talk</span><p class="sc-name">Margaret Roberts</p><p class="sc-role">Professor of Political Science, UC San Diego</p></div>
        </button>

        <button id="sp-thomas-robinson" class="speaker-chip" data-speaker="thomas-robinson" data-name="Thomas Robinson" data-role="Assistant Professor, LSE" data-tag="Research Talk" data-img="/img/speakers/thomas_robinson.jpg">
          <div class="sc-portrait"><img src="/img/speakers/thomas_robinson.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Research Talk</span><p class="sc-name">Thomas Robinson</p><p class="sc-role">Assistant Professor, LSE</p></div>
        </button>

        <button id="sp-sagi-shaier" class="speaker-chip" data-speaker="sagi-shaier" data-name="Sagi Shaier" data-role="Visiting Professor, JGU Mainz" data-tag="Lecturer" data-img="/img/speakers/sagi_shaier.jpeg">
          <div class="sc-portrait"><img src="/img/speakers/sagi_shaier.jpeg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Sagi Shaier</p><p class="sc-role">Visiting Professor, JGU Mainz</p></div>
        </button>

        <button id="sp-tatiana-shavrina" class="speaker-chip" data-speaker="tatiana-shavrina-26" data-name="Tatiana Shavrina" data-role="Research Scientist Manager, Meta" data-tag="Lecturer" data-img="/img/speakers/tatiana_shavrina.jpg">
          <div class="sc-portrait"><img src="/img/speakers/tatiana_shavrina.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Tatiana Shavrina</p><p class="sc-role">Research Scientist Manager, Meta</p></div>
        </button>

        <button id="sp-sergei-skvortsov" class="speaker-chip" data-speaker="sergei-skvortsov-26" data-name="Sergei Skvortsov" data-role="Lead MLE, Nebius" data-tag="Lecturer" data-img="/img/speakers/sergei_skvortsov.jpg">
          <div class="sc-portrait"><img src="/img/speakers/sergei_skvortsov.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Lecturer</span><p class="sc-name">Sergei Skvortsov</p><p class="sc-role">Lead MLE, Nebius</p></div>
