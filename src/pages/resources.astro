---
import Base from '../layouts/Base.astro';
---

<Base
  title="Resources"
  description="Open-source course materials, summer school archives, research code, and models from Oxford LLMs."
>

  <section class="section-v3" style="padding-top: clamp(72px, 8vw, 112px);">
    <div class="shell">

      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Open access</div>
          <h1 class="h-section">Everything we make is open.</h1>
        </div>
        <p class="lede-v3">
          Course materials, summer school archives, research code, and models.
          All openly licensed and freely available — no registration required.
        </p>
      </div>

      <!-- Primary resource cards -->
      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 20px;"
           class="reveal-stagger">

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:12px">Course</div>
          <h2 class="h-sub" style="margin-bottom:10px">LLMs for Social Science</h2>
          <p class="copy" style="font-size:14px; margin:0 0 18px;">
            Five modules from embeddings to agentic workflows. Built for
            early-career social scientists; all notebooks run in Google Colab.
          </p>
          <div style="display:flex; flex-direction:column; gap:8px; margin-top:auto;">
            <a class="btn-ghost" href="/course/" style="font-size:13px; padding:8px 16px;">
              Browse the course <span class="arrow">→</span>
            </a>
            <a class="btn-link-v3" href="https://github.com/antndlcrx/Intro-to-LLMs-DPIR"
               target="_blank" rel="noopener">
              GitHub repository <span class="arrow">→</span>
            </a>
          </div>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:12px">Summer School</div>
          <h2 class="h-sub" style="margin-bottom:10px">Workshop Archives</h2>
          <p class="copy" style="font-size:14px; margin:0 0 18px;">
            Lecture slides, Jupyter notebooks, and seminars from the 2023 and
            2024 summer schools. Covers transformers, evaluation, fine-tuning,
            and agents.
          </p>
          <div style="display:flex; flex-direction:column; gap:8px; margin-top:auto;">
            <a class="btn-ghost" href="/resources/summer-school/" style="font-size:13px; padding:8px 16px;">
              Browse materials <span class="arrow">→</span>
            </a>
            <a class="btn-link-v3" href="https://github.com/antndlcrx/oxford-llms-workshop"
               target="_blank" rel="noopener">
              GitHub repository <span class="arrow">→</span>
            </a>
          </div>
        </article>

        <article class="fb">
          <span class="rule-soft"></span>
          <div class="eyebrow-v3" style="margin-bottom:12px">Research</div>
          <h2 class="h-sub" style="margin-bottom:10px">Code &amp; Models</h2>
          <p class="copy" style="font-size:14px; margin:0 0 18px;">
            Replication code and pre-trained models from our research on
            synthetic data generation and model evaluation. Weights hosted on
            Hugging Face.
          </p>
          <div style="display:flex; flex-direction:column; gap:8px; margin-top:auto;">
            <a class="btn-ghost" href="https://github.com/Oxford-LLMs-Research/synthetic_sampling"
               target="_blank" rel="noopener" style="font-size:13px; padding:8px 16px;">
              Synthetic data <span class="arrow">→</span>
            </a>
            <a class="btn-link-v3" href="https://huggingface.co/oxford-llms"
               target="_blank" rel="noopener">
              Models on Hugging Face <span class="arrow">→</span>
            </a>
          </div>
        </article>

      </div>

      <!-- Secondary: Python intro -->
      <div class="reveal" style="margin-top:48px; padding-top:32px; border-top:1px solid var(--border-lt);">
        <div class="eyebrow-v3" style="margin-bottom:20px">Prerequisites</div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; max-width:720px;">

          <article class="fb" style="padding:20px 22px;">
            <h3 class="h-sub" style="font-size:16px; margin-bottom:8px">Python for Social Scientists</h3>
            <p class="copy" style="font-size:13.5px; margin:0 0 14px;">
              Introductory notebooks covering the Python and data-science basics
              required to follow the main course. No prior programming experience assumed.
            </p>
            <a class="btn-link-v3" href="https://github.com/antndlcrx/Intro-to-LLMs-DPIR/tree/main/preliminaries"
               target="_blank" rel="noopener">
              Open notebooks <span class="arrow">→</span>
            </a>
          </article>

          <article class="fb" style="padding:20px 22px;">
            <h3 class="h-sub" style="font-size:16px; margin-bottom:8px">Oxford LLMs on Hugging Face</h3>
            <p class="copy" style="font-size:13.5px; margin:0 0 14px;">
              All released models, datasets, and evaluation benchmarks in one
              place — ready to download and use in your own research.
            </p>
            <a class="btn-link-v3" href="https://huggingface.co/oxford-llms"
               target="_blank" rel="noopener">
              Browse the org <span class="arrow">→</span>
            </a>
          </article>

        </div>
      </div>

    </div>
  </section>

</Base>
