---
import Base from '../layouts/Base.astro';
import Partners from '../components/Partners.astro';
import SpeakerModal from '../components/SpeakerModal.astro';
---

<Base title="About" description="Oxford LLMs is an independent research lab focused on how social scientists can use language models.">

  <!-- ── Manuscript hero ─────────────────────────────────────── -->
  <section class="hero-manuscript">
    <div class="hero-ms-inner">

      <!-- Sidebar TOC rail -->
      <aside class="hero-ms-rail">
        <span class="rail-label">Contents</span>
        <ol class="rail-toc">
          <li>
            <a href="#mission">
              <span class="t-num">01</span>
              <span class="t-name">Mission</span>
            </a>
          </li>
          <li>
            <a href="#team">
              <span class="t-num">02</span>
              <span class="t-name">Team</span>
            </a>
          </li>
          <li>
            <a href="#partners">
              <span class="t-num">03</span>
              <span class="t-name">Partners</span>
            </a>
          </li>
        </ol>
        <div class="rail-foot">
          <span>Est. 2023</span>
          <span>Oxford</span>
        </div>
      </aside>

      <!-- Main content -->
      <div class="hero-ms-content">
        <p class="eyebrow-v3">About</p>
        <h1 class="hero-title h-display" style="margin: 16px 0 24px;">
          Research, teaching,<br>and community for<br>social scientists.
        </h1>
        <p class="lede-v3">
          Oxford LLMs is an independent research lab focused on how social scientists
          can use language models. Founded in 2023 at the University of Oxford.
        </p>
      </div>
    </div>
  </section>

  <!-- ── § 01 Mission ───────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="mission">
    <span class="section-number">§ 01 · Mission</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <h2 class="h-section">What we do</h2>
        <p class="copy" style="max-width:52ch;">
          Large language models are transforming social science research, but using them well
          requires specialised training that bridges machine learning and the social sciences.
          Oxford LLMs addresses this gap through three activities.
        </p>
      </div>

      <div class="principles reveal-stagger">
        <div class="principle">
          <span class="p-tag">01 — Research</span>
          <h3><a href="/research/">Methods for social science</a></h3>
          <p>
            We develop new methods for applying LLMs to social science problems,
            with a focus on synthetic data generation, opinion prediction, and model evaluation.
            Some projects are ongoing; others are completed and under peer review.
          </p>
        </div>

        <div class="principle">
          <span class="p-tag">02 — Teaching</span>
          <h3><a href="/course/">Open-source curricula</a></h3>
          <p>
            We develop and deliver open-source curricula on LLMs for social scientists,
            based at Oxford and taught at partner institutions by invitation.
            All course materials are freely available online.
          </p>
        </div>

        <div class="principle">
          <span class="p-tag">03 — Community</span>
          <h3><a href="/summer-school/">Annual summer school</a></h3>
          <p>
            Our annual summer school, now in its fourth year, brings together early-career
            researchers for an intensive week of lectures, coding, and collaborative research.
            Past participants have gone on to co-author research submitted for peer review.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── § 02 Team ──────────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="team">
    <span class="section-number">§ 02 · Team</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <h2 class="h-section">The team</h2>
        <p class="copy" style="max-width:52ch;">
          Oxford LLMs is led by a core team of researchers and ML practitioners.
        </p>
      </div>

      <div class="eyebrow-v3 reveal" style="margin-bottom: 16px;">Current</div>
      <div class="speaker-grid speaker-grid--team reveal-stagger" style="margin-bottom: 48px;">

        <button class="speaker-chip" data-speaker="maksim-zubok-about" data-name="Maksim Zubok" data-role="Politics DPhil, Nuffield College · LCDS Researcher, Oxford" data-tag="Co-founder" data-img="/img/speakers/maksim_zubok.png">
          <div class="sc-portrait"><img src="/img/speakers/maksim_zubok.png" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-founder</span><p class="sc-name">Maksim Zubok</p><p class="sc-role">Politics DPhil, Nuffield College · LCDS Researcher, Oxford</p></div>
        </button>

        <button class="speaker-chip" data-speaker="ilya-boytsov-about" data-name="Ilya Boytsov" data-role="ML Performance Engineering, Nebius" data-tag="Co-founder" data-img="/img/speakers/ilya_boystov.jpg">
          <div class="sc-portrait"><img src="/img/speakers/ilya_boystov.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-founder</span><p class="sc-name">Ilya Boytsov</p><p class="sc-role">ML Performance Engineering, Nebius</p></div>
        </button>

        <button class="speaker-chip" data-speaker="josh-berry" data-name="Joshua Berry" data-role="Politics DPhil, Nuffield College, Oxford" data-tag="Co-organiser · 2026" data-img="/img/speakers/josh_berry.jpg">
          <div class="sc-portrait"><img src="/img/speakers/josh_berry.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-organiser · 2026</span><p class="sc-name">Joshua Berry</p><p class="sc-role">Politics DPhil, Nuffield College, Oxford</p></div>
        </button>

        <button class="speaker-chip" data-speaker="elodie-chervin" data-name="Elodie Chervin" data-role="Economics DPhil, Nuffield College, Oxford" data-tag="Co-organiser · 2026" data-img="/img/speakers/elodie_chervin.jpeg">
          <div class="sc-portrait"><img src="/img/speakers/elodie_chervin.jpeg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-organiser · 2026</span><p class="sc-name">Elodie Chervin</p><p class="sc-role">Economics DPhil, Nuffield College, Oxford</p></div>
        </button>

      </div>

      <div class="eyebrow-v3 reveal" style="margin-bottom: 16px;">Past co-organisers</div>
      <div class="speaker-grid speaker-grid--team reveal-stagger">

        <button class="speaker-chip" data-speaker="rachel-bernhard-about" data-name="Rachel Bernhard" data-role="Associate Professor, Nuffield College, Oxford" data-tag="Co-organiser · 2025" data-img="/img/speakers/rachel_bernhard.jpg">
          <div class="sc-portrait"><img src="/img/speakers/rachel_bernhard.jpg" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-organiser · 2025</span><p class="sc-name">Rachel Bernhard</p><p class="sc-role">Associate Professor, Nuffield College, Oxford</p></div>
        </button>

        <button class="speaker-chip" data-speaker="humeyra-biricik-about" data-name="Humeyra Biricik" data-role="Politics DPhil, Pembroke College, Oxford" data-tag="Co-organiser · 2024" data-img="/img/speakers/humeyra_biricik.png">
          <div class="sc-portrait"><img src="/img/speakers/humeyra_biricik.png" alt="" /></div>
          <div class="sc-info"><span class="sc-tag">Co-organiser · 2024</span><p class="sc-name">Humeyra Biricik</p><p class="sc-role">Politics DPhil, Pembroke College, Oxford</p></div>
        </button>

      </div>
    </div>
  </section>

  <!-- ── Bio data (used by speaker modal) ───────────────────── -->
  <div hidden aria-hidden="true">

    <div id="bio-maksim-zubok-about">
      <p>Maksim Zubok is a doctoral candidate in Politics at Oxford University, <a href="https://www.nuffield.ox.ac.uk/people/profiles/maksim-zubok/" target="_blank" rel="noopener">Nuffield College</a>. His dissertation explores ways of harnessing LLMs for social science research, from classic data labelling to using models as condensed snapshots of the internet to study how people organise relationships between concepts and form beliefs about the world.</p>
      <p>He conceived and organised the inaugural school in 2023 and has led the programme through each edition since. He has also helped organise the <a href="https://sicss.io/2022/oxford/" target="_blank" rel="noopener">Oxford Summer Institute for Computational Social Science</a>.</p>
    </div>

    <div id="bio-ilya-boytsov-about">
      <p>Ilya is a member of the ML Performance Engineering team at Nebius, where he works on large-scale LLM inference systems and performance optimization. His interests include efficient transformer architectures, distributed inference infrastructure, and scalable serving of foundation models, with a particular focus on Mixture-of-Experts architectures.</p>
    </div>

    <div id="bio-josh-berry">
      <p>Josh's research combines insights from computational social science, behavioural economics, and networks to study political economy, regulatory enforcement, and judicial systems in advanced democratic countries. More broadly, he is interested in developing experimental, machine learning, and computational methodologies for social science research.</p>
    </div>

    <div id="bio-elodie-chervin">
      <p>Elodie Chervin is a DPhil candidate in Economics at Nuffield College, University of Oxford.</p>
    </div>

    <div id="bio-rachel-bernhard-about">
      <p>Rachel Bernhard is Associate Professor of Quantitative Political Science Research Methods at Nuffield College and the University of Oxford. Before joining Nuffield, she was an Assistant Professor at the University of California, Davis, and a Postdoctoral Prize Fellow in Politics at Nuffield. She holds a PhD from UC Berkeley.</p>
      <p>Her research focuses on appearance-based discrimination in politics — how candidate appearance shapes voter preferences and how parties select candidates. She is also a methodologist working on survey experiments and text-as-data approaches.</p>
    </div>

    <div id="bio-humeyra-biricik-about">
      <p>Humeyra Biricik is a doctoral candidate in Politics at Pembroke College, Oxford. Her research focuses on political speech, populism, and democratic backsliding in Turkey, Hungary, India, and Arabic-speaking Middle Eastern countries, using large language models and text analysis alongside econometric methods.</p>
      <p>She also coordinates a series of politics talks at Pembroke College on topics ranging from local British elections and the housing crisis to AI regulation and machine learning in political science.</p>
    </div>

  </div>

  <!-- ── § 03 Partners ──────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="partners">
    <span class="section-number">§ 03 · Partners</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <h2 class="h-section">Partners & supporters</h2>
        <p class="copy" style="max-width:52ch;">
          Oxford LLMs operates as an independent research lab. Our work has been supported
          by academic institutions and industry partners who share our commitment to open
          research and education.
        </p>
      </div>

      <div class="reveal">
        <Partners />
      </div>
    </div>
  </section>

  <SpeakerModal />

</Base>
