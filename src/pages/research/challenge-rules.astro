---
import Base from '../../layouts/Base.astro';

// Participant-facing rules for the AI Respondents Challenge. Source of truth for
// design decisions: the competition design docs; keep this page in sync with the
// HF dataset card (oxford-llms/ai-respondents-challenge).
---

<Base
  title="Challenge rules — AI Respondents Challenge"
  description="Rules, data, submission format, and scoring for the AI Respondents Challenge.">

  <!-- ── Hero ───────────────────────────────────────────────── -->
  <section class="section-v3" style="padding-top: clamp(72px, 10vw, 132px);">
    <div class="shell">
      <p class="eyebrow-v3">Research · Common-task challenge</p>
      <h1 class="h-display" style="margin: 14px 0 22px; max-width: 18ch;">
        Rules &amp; submission format.
      </h1>
      <p class="lede-v3" style="max-width: 62ch;">
        Real people answered the World Values Survey; we hid some of their answers. Your job:
        predict what each person said — with whatever method you like — and disclose what your
        approach relied on. This page is everything you need to submit.
      </p>
      <p class="copy" style="margin-top:18px; font-size:13.5px;">
        <a class="btn-link-v3" href="https://huggingface.co/datasets/oxford-llms/ai-respondents-challenge">
          Get the data &amp; starter notebook <span class="arrow">→</span></a>
        <a class="btn-link-v3" href="/research/challenge/#leaderboard" style="margin-left:22px;">
          Leaderboard <span class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ── § 01 The data ──────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker section-tinted-v3" id="data">
    <span class="section-number">§ 01 · The data</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">One dataset, four parts</div>
          <h2 class="h-section">What you get.</h2>
        </div>
        <p class="lede-v3">
          Everything lives in one Hugging Face dataset. Test respondents' answers to the target
          questions are hidden and never released — final scoring runs on our private copy.
        </p>
      </div>

      <div class="rules-grid reveal-stagger">
        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px"><code>train</code></h3>
          <p class="copy" style="margin:0; font-size:14px;">
            Labeled respondents (100 per seen country) with all their survey answers — for
            exploring the data and validating your pipeline before you spend test-set calls.
          </p>
        </article>
        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px"><code>test</code></h3>
          <p class="copy" style="margin:0; font-size:14px;">
            1,950 respondents — 30 per country across 65 countries, 15 of which never appear in
            train. These are the people you predict for, on every target question.
          </p>
        </article>
        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px"><code>targets</code></h3>
          <p class="copy" style="margin:0; font-size:14px;">
            The target questions with their answer options, in scale order. <strong>The
            <code>label</code> column is the answer space: your predictions must match one of a
            question's labels exactly.</strong> Additional hidden questions are released on Thursday.
          </p>
        </article>
        <article class="fb">
          <span class="rule-soft"></span>
          <h3 class="h-sub" style="margin-bottom:10px"><code>features</code></h3>
          <p class="copy" style="margin:0; font-size:14px;">
            The allowed feature pool: every respondent variable you may use, with question text
            and the code→text map for turning coded answers into words.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── § 02 Submission ────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="submission">
    <span class="section-number">§ 02 · Submission</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Three files</div>
          <h2 class="h-section">What you submit.</h2>
        </div>
        <p class="lede-v3">
          The starter notebook writes all three in the right format — extend it, or produce them
          however you like. Zip the folder and upload it.
        </p>
      </div>

      <div class="rules-files reveal">
        <div class="rules-file">
          <h3 class="h-sub"><code>predictions.csv</code></h3>
          <pre class="rules-pre">respondent_id, question_id, prediction</pre>
          <p class="copy" style="margin:0; font-size:14px;">
            One row per (test respondent, target question). <code>prediction</code> is the answer
            as a text label, exactly as it appears in <code>targets</code>. Anything else scores
            zero — and unanswered rows count against coverage, so predict everyone.
          </p>
        </div>
        <div class="rules-file">
          <h3 class="h-sub"><code>features.csv</code></h3>
          <pre class="rules-pre">question_id, feature_variable_code</pre>
          <p class="copy" style="margin:0; font-size:14px;">
            The respondent variables your method actually relied on, per target question. If you
            prompted with "given this person's age, religion, and income…", those three variables
            go here. This disclosure powers the shared research finding — fill it in properly.
          </p>
        </div>
        <div class="rules-file">
          <h3 class="h-sub"><code>method/</code></h3>
          <pre class="rules-pre">prompts.jsonl · method.md</pre>
          <p class="copy" style="margin:0; font-size:14px;">
            Your prompt template per question and a short note on your approach. Kept for
            reproducibility and to study which approaches worked.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── § 03 Scoring ───────────────────────────────────────── -->
  <section class="section-v3 section-v3--marker section-tinted-v3" id="scoring">
    <span class="section-number">§ 03 · Scoring</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Two boards, one skill score</div>
          <h2 class="h-section">How you're ranked.</h2>
        </div>
        <p class="lede-v3">
          Separate live boards for in-domain prediction (seen countries, held-out respondents)
          and out-of-domain prediction (countries your models never saw in train).
        </p>
      </div>

      <div class="reveal" style="max-width:72ch;">
        <p class="copy">
          <strong>Ranking uses normalized skill</strong> — how far your accuracy sits above the
          majority-class baseline, rescaled so a 10-point question and a yes/no question count
          fairly. Shown alongside it: <strong>alignment</strong> (how closely your predicted
          answer distribution matches the real one — standing in for a population takes both),
          F1-macro, and coverage.
        </p>
        <p class="copy">
          The week ends with two stress tests, released on Thursday for you to run and submit:
          the <strong>hidden target questions</strong> (scored privately) and a
          <strong>held-out survey finale</strong> — your pipeline pointed at surveys it has never
          seen. Results are revealed on Friday. The feature disclosures feed an offline
          selection-vs-modeling analysis previewed at the Friday wrap-up; it is not a live board,
          so prediction stays the game.
        </p>
      </div>
    </div>
  </section>

  <!-- ── § 04 Rules & schedule ──────────────────────────────── -->
  <section class="section-v3 section-v3--marker" id="rules"
           style="padding-bottom: clamp(56px, 7vw, 88px);">
    <span class="section-number">§ 04 · Rules</span>
    <div class="shell">
      <div class="section-head-v3 reveal">
        <div>
          <div class="eyebrow-v3" style="margin-bottom:14px">Fair play</div>
          <h2 class="h-section">The rules.</h2>
        </div>
        <p class="lede-v3">
          Short version: any method, full disclosure, don't game the truth.
        </p>
      </div>

      <div class="reveal" style="max-width:72ch;">
        <ul class="rules-list copy">
          <li><strong>Any method is allowed</strong> — prompt an LLM directly, have it pick
            features, ensemble, anything — <strong>provided you disclose it</strong> via
            <code>features.csv</code> and <code>method/</code>.</li>
          <li><strong>Respondent information must come from the allowed feature pool.</strong>
            Target questions are never usable as features.</li>
          <li><strong>No reverse-engineering test labels.</strong> Final scoring uses a private
            split; don't try to reconstruct hidden answers from external sources.</li>
          <li><strong>Models &amp; budget.</strong> Open models run on the shared Nebius
            allowance — a full pass over the test set costs a few dollars, so iterate freely but
            deliberately; the allowance covers the whole week including the finale. Closed
            frontier models only with your own API key.</li>
          <li><strong>Consent to research use.</strong> By submitting, you agree your predictions,
            declared features, prompts, and method notes may be used, with attribution, in
            academic work arising from the challenge.</li>
        </ul>

        <h3 class="h-sub" style="margin:34px 0 14px;">Schedule (afternoon lab sessions)</h3>
        <div class="lb-scroll">
          <table class="rules-table">
            <tbody>
              <tr><td class="rules-day">Mon 13 Jul</td><td>Launch — data walkthrough, teams form, starter kit and infrastructure check</td></tr>
              <tr><td class="rules-day">Tue–Wed</td><td>Team research work; the live leaderboard is open throughout</td></tr>
              <tr><td class="rules-day">Thu 16 Jul</td><td>Out-of-domain evaluation sets released (hidden questions + held-out surveys) — run your pipeline and submit</td></tr>
              <tr><td class="rules-day">Fri 17 Jul</td><td>Results reveal and team presentations</td></tr>
            </tbody>
          </table>
        </div>

        <p class="copy" style="margin-top:26px; font-size:13.5px; color:var(--text-muted);">
          The challenge continues after the school as an open rolling benchmark. Questions during
          the week: ask the organizers in the lab.
        </p>
      </div>
    </div>
  </section>

</Base>

<style>
  .rules-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
  }
  .rules-files { display: grid; gap: 18px; max-width: 72ch; }
  .rules-file {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 20px 22px;
  }
  .rules-file .h-sub { margin: 0 0 10px; }
  .rules-pre {
    margin: 0 0 12px; padding: 10px 14px; border-radius: 8px;
    background: color-mix(in srgb, var(--surface) 70%, var(--card));
    border: 1px solid var(--border);
    font-family: var(--font-mono); font-size: 12.5px; color: var(--text-sec);
    overflow-x: auto;
  }
  .rules-list { padding-left: 20px; display: grid; gap: 12px; }
  .rules-list li { line-height: 1.6; }

  .lb-scroll { overflow-x: auto; }
  .rules-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .rules-table td {
    padding: 11px 14px 11px 0; border-bottom: 1px solid var(--border);
    color: var(--text-sec); line-height: 1.5;
  }
  .rules-table tr:last-child td { border-bottom: none; }
  .rules-day {
    font-family: var(--font-mono); font-size: 12.5px; white-space: nowrap;
    color: var(--text); width: 110px;
  }

  @media (max-width: 760px) {
    .rules-grid { grid-template-columns: 1fr; }
  }
</style>
