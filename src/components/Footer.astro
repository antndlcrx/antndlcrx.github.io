---
import LogoMark from './LogoMark.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <LogoMark size={18} className="footer__logo" />
      <span class="footer__copy">&copy; {year} Oxford LLMs</span>
    </div>
    <ul class="footer__links">
      <li>
        <a
          href="https://github.com/Oxford-LLMs-Research"
          class="footer__link footer__link--icon"
          target="_blank"
          rel="noopener"
          aria-label="Oxford LLMs on GitHub"
        >
          <img src="/img/icons/github-mark.svg" alt="GitHub" class="footer__icon-image footer__icon-image--github" />
        </a>
      </li>
      <li>
        <a
          href="https://huggingface.co/oxford-llms"
          class="footer__link footer__link--icon"
          target="_blank"
          rel="noopener"
          aria-label="Oxford LLMs on Hugging Face"
        >
          <img src="/img/icons/hf-logo.svg" alt="Hugging Face" class="footer__icon-image footer__icon-image--hf" />
        </a>
      </li>
      <li>
        <a
          href="mailto:maksim.zubok@nuffield.ox.ac.uk"
          class="footer__link footer__link--icon"
          aria-label="Email Oxford LLMs"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect
              x="4"
              y="7"
              width="16"
              height="10"
              rx="2"
              ry="2"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
            />
            <path
              d="M5 8.5L12 13l7-4.5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </li>
    </ul>
  </div>
</footer>
