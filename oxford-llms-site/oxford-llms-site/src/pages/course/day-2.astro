        <path d="M 464 201 L 464 225 Q 464 240 449 240 L 127 240 Q 112 240 112 225 L 112 201" fill="none" style="stroke: var(--accent, #2D8ABF);" stroke-width="1.5" stroke-dasharray="6,3" marker-end="url(#arrow-rlhf)"/>
        <text x="288" y="258" text-anchor="middle" style="fill: var(--text-muted, #6B7280); font-family: var(--font-body);" font-size="8.5" font-style="italic">Iterate: generate new responses, score, update weights</text>

