        <!-- Connection lines from top models to bottom loop -->
        <line x1="365" y1="84" x2="112" y2="147" style="stroke: var(--text-muted, #6B7280);" stroke-width="1" stroke-dasharray="3,3" marker-end="url(#arrow-rlhf-muted)"/>
