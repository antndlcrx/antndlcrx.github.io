        <text x="355" y="118" style="fill: var(--text-sec, #3D4455);" font-size="11">table</text><rect x="395" y="107" width="45" height="10" rx="3" style="fill: var(--accent-hover, #3BA3D4);" opacity="0.5"/><text x="445" y="117" style="fill: var(--text-muted, #6B7280);" font-size="10">18%</text>
        <text x="355" y="136" style="fill: var(--text-sec, #3D4455);" font-size="11">floor</text><rect x="395" y="125" width="30" height="10" rx="3" style="fill: var(--accent-hover, #3BA3D4);" opacity="0.4"/><text x="430" y="135" style="fill: var(--text-muted, #6B7280);" font-size="10">12%</text>
        <!-- Label -->
        <text x="175" y="55" text-anchor="middle" style="fill: var(--text-muted, #6B7280);" font-size="10">Input sequence</text>
        <text x="422" y="55" text-anchor="middle" style="fill: var(--accent-dark, #1E5A8A);" font-size="10">Probability distribution</text>
