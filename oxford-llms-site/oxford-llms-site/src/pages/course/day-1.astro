        <rect x="189" y="70" width="45" height="30" rx="5" style="fill: var(--accent-bg, #EBF7FD); stroke: var(--accent, #2D8ABF);"/><text x="211" y="90" text-anchor="middle" style="fill: var(--blue-0, #1E3A5F);" font-size="11">on</text>
        <rect x="242" y="70" width="50" height="30" rx="5" style="fill: var(--accent-bg, #EBF7FD); stroke: var(--accent, #2D8ABF);"/><text x="267" y="90" text-anchor="middle" style="fill: var(--blue-0, #1E3A5F);" font-size="11">the</text>
