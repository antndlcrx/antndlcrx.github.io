      weights: [
        [0.38, 0.28, 0.10, 0.08, 0.10, 0.06],
        [0.32, 0.12, 0.10, 0.05, 0.11, 0.30],
        [0.05, 0.22, 0.13, 0.22, 0.28, 0.10],
        [0.03, 0.05, 0.10, 0.12, 0.50, 0.20],
        [0.04, 0.08, 0.10, 0.13, 0.18, 0.47],
        [0.05, 0.10, 0.08, 0.07, 0.50, 0.20]
      ],
      insights: [
        "\"I\" attends to itself and the verb \"sat\" — establishing the subject.",
        "\"sat\" attends to its subject \"I\" and the destination \"bank\" — connecting actor to location.",
        "\"by\" attends to the nearby nouns \"the\" and \"river\" — preposition links to its object.",
        "\"the\" attends strongly to \"river\" — the determiner knows which noun it modifies.",
        "\"river\" attends strongly to \"bank\" — the model links these semantically related words.",
        "\"bank\" attends strongly to \"river\" — context resolves this as a river bank, not a financial one."
      ]
    },
    {
      tokens: ["I", "went", "to", "the", "bank", "to", "deposit", "money"],
      weights: [
        [0.35, 0.30, 0.05, 0.05, 0.05, 0.04, 0.10, 0.06],
        [0.25, 0.12, 0.10, 0.05, 0.12, 0.06, 0.16, 0.14],
        [0.05, 0.12, 0.08, 0.12, 0.38, 0.05, 0.10, 0.10],
        [0.03, 0.05, 0.05, 0.10, 0.52, 0.05, 0.10, 0.10],
        [0.05, 0.08, 0.04, 0.05, 0.10, 0.05, 0.33, 0.30],
        [0.04, 0.06, 0.05, 0.04, 0.08, 0.05, 0.45, 0.23],
        [0.05, 0.10, 0.05, 0.04, 0.28, 0.05, 0.10, 0.33],
        [0.06, 0.08, 0.05, 0.04, 0.32, 0.05, 0.28, 0.12]
      ],
      insights: [
        "\"I\" attends to itself and \"went\" — the subject anchors to its verb.",
        "\"went\" spreads attention across purpose words: \"deposit\" and \"money.\"",
        "\"to\" attends strongly to \"bank\" — the preposition links to its destination.",
        "\"the\" attends strongly to \"bank\" — the determiner locks onto its noun.",
        "\"bank\" attends to \"deposit\" and \"money\" — context resolves this as a financial bank.",
        "\"to\" (second) attends strongly to \"deposit\" — this preposition links to the action.",
        "\"deposit\" attends to \"money\" and \"bank\" — the verb connects to its object and location.",
        "\"money\" attends to \"bank\" and \"deposit\" — the object connects to action and place."
      ]
    }
  ];

  var currentSentence = 0;
  var currentToken = -1;
  var maxBarHeight = 70;

  var explorer = document.getElementById("attn-explorer");
  if (!explorer) return;

  var tokensEl = document.getElementById("attn-tokens");
  var barsEl = document.getElementById("attn-bars");
  var insightEl = document.getElementById("attn-insight");
  var sentBtns = explorer.querySelectorAll(".attention-explorer__sentence-btn");

  function renderTokens() {
    var s = sentences[currentSentence];
    tokensEl.innerHTML = "";
    for (var i = 0; i < s.tokens.length; i++) {
      var btn = document.createElement("button");
      btn.className = "attention-explorer__token";
      btn.textContent = s.tokens[i];
      btn.setAttribute("data-idx", String(i));
      if (i === currentToken) {
        btn.classList.add("attention-explorer__token--active");
      }
      btn.addEventListener("click", (function(idx) {
        return function() { selectToken(idx); };
      })(i));
      tokensEl.appendChild(btn);
    }
  }

  function renderBars() {
    var s = sentences[currentSentence];
    barsEl.innerHTML = "";
    if (currentToken < 0) {
      insightEl.textContent = "Click any token above to explore its attention pattern.";
      return;
    }
    var w = s.weights[currentToken];
    for (var i = 0; i < w.length; i++) {
      var group = document.createElement("div");
      group.className = "attention-explorer__bar-group";

      var bar = document.createElement("div");
      bar.className = "attention-explorer__bar";
      bar.style.height = Math.max(2, w[i] * maxBarHeight) + "px";
      bar.style.opacity = String(0.3 + w[i] * 0.7);

      var label = document.createElement("span");
      label.className = "attention-explorer__bar-label";
      label.textContent = w[i].toFixed(2);

      var word = document.createElement("span");
      word.className = "attention-explorer__bar-word";
      word.textContent = s.tokens[i];

      group.appendChild(bar);
      group.appendChild(label);
      group.appendChild(word);
      barsEl.appendChild(group);
    }
    insightEl.textContent = s.insights[currentToken];
  }

  function selectToken(idx) {
    currentToken = idx;
    renderTokens();
    renderBars();
  }

  function selectSentence(idx) {
    currentSentence = idx;
    var s = sentences[currentSentence];
    var bankIdx = s.tokens.indexOf("bank");
    currentToken = bankIdx >= 0 ? bankIdx : 0;
    sentBtns.forEach(function(btn, i) {
      btn.classList.toggle("attention-explorer__sentence-btn--active", i === idx);
    });
    renderTokens();
    renderBars();
  }

  sentBtns.forEach(function(btn, i) {
    btn.addEventListener("click", function() { selectSentence(i); });
  });

  var s0 = sentences[0];
  currentToken = s0.tokens.indexOf("bank");
  renderTokens();
  renderBars();
})();
</script>

<script is:inline>
(function() {
  var svg = document.getElementById("cosine-svg");
  if (!svg) return;

  var handle = document.getElementById("cos-handle");
  var vecB   = document.getElementById("cos-vec-b");
  var labelB = document.getElementById("cos-label-b");
  var arc    = document.getElementById("cos-arc");
  var valTxt = document.getElementById("cos-value");
  var angTxt = document.getElementById("cos-angle");

  var ox = 240, oy = 200;
  var ax = 383, ay = 154;
  var bx = 326, by = 77;
  var radius = 150;
  var dragging = false;

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function update() {
    var dx = bx - ox, dy = by - oy;
    var len = Math.sqrt(dx * dx + dy * dy);
    if (len < 10) return;

    var nx = dx / len * radius;
    var ny = dy / len * radius;
    var ex = ox + nx, ey = oy + ny;

    vecB.setAttribute("x2", ex);
    vecB.setAttribute("y2", ey);
    labelB.setAttribute("x", ex + 5);
    labelB.setAttribute("y", ey - 3);
    handle.setAttribute("cx", ex);
    handle.setAttribute("cy", ey);
    bx = ex; by = ey;

    var adx = ax - ox, ady = ay - oy;
    var alen = Math.sqrt(adx * adx + ady * ady);
    var dot = (adx * nx + ady * ny) / (alen * radius);
    dot = clamp(dot, -1, 1);

    var angleA = Math.atan2(-(ay - oy), ax - ox);
    var angleB = Math.atan2(-ny, nx);
    var angleDeg = Math.acos(dot) * 180 / Math.PI;

    var arcR = 40;
    var sA = Math.min(angleA, angleB);
    var eA = Math.max(angleA, angleB);
    if (eA - sA > Math.PI) { var tmp = sA; sA = eA; eA = tmp + 2 * Math.PI; }
    var sx = ox + arcR * Math.cos(sA);
    var sy = oy - arcR * Math.sin(sA);
    var ex2 = ox + arcR * Math.cos(eA);
    var ey2 = oy - arcR * Math.sin(eA);
    var largeArc = (eA - sA) > Math.PI ? 1 : 0;
    arc.setAttribute("d", "M " + sx + "," + sy + " A " + arcR + "," + arcR + " 0 " + largeArc + ",0 " + ex2 + "," + ey2);

    valTxt.textContent = "cos \u03B8 = " + dot.toFixed(2);
    angTxt.textContent = "\u03B8 = " + Math.round(angleDeg) + "\u00B0";
  }

  function svgPoint(e) {
    var pt = svg.createSVGPoint();
    var touch = e.touches ? e.touches[0] : e;
    pt.x = touch.clientX;
    pt.y = touch.clientY;
    var ctm = svg.getScreenCTM().inverse();
    return pt.matrixTransform(ctm);
  }

  function onStart(e) {
    e.preventDefault();
    dragging = true;
    handle.style.cursor = "grabbing";
  }
  function onMove(e) {
    if (!dragging) return;
    e.preventDefault();
    var p = svgPoint(e);
    bx = p.x; by = p.y;
    update();
  }
  function onEnd() {
    dragging = false;
    handle.style.cursor = "grab";
  }

  handle.addEventListener("mousedown", onStart);
  handle.addEventListener("touchstart", onStart, {passive: false});
  document.addEventListener("mousemove", onMove);
  document.addEventListener("touchmove", onMove, {passive: false});
  document.addEventListener("mouseup", onEnd);
  document.addEventListener("touchend", onEnd);

  update();
})();
</script>

