      for (var j = 0; j < k; j++) {
        if (Math.abs(labels[k].x - labels[j].x) < 45 && Math.abs(labels[k].y - labels[j].y) < 11) {
          labels[k].y = labels[k].y > labels[j].y ? labels[j].y + 12 : labels[j].y - 12;
        }
      }
    }

    for (var m = 0; m < labels.length; m++) {
      var lb = labels[m];
      s += '<text x="' + lb.x + '" y="' + lb.y + '" text-anchor="' + lb.a + '" style="fill: var(--text-sec, #3D4455);" font-size="9">' + lb.t + '</text>';
    }
    svg.innerHTML = s;
  }

  function render() {
    if (panel === 0) drawBars("g", "\u2190 male", "female \u2192");
    else if (panel === 1) drawBars("a", "\u2190 young", "old \u2192");
    else drawScatter();
    insight.textContent = insights[panel];
  }

  var btns = explorer.querySelectorAll(".attention-explorer__sentence-btn");
  btns.forEach(function(btn, i) {
    btn.addEventListener("click", function() {
      btns.forEach(function(b, j) {
        b.classList.toggle("attention-explorer__sentence-btn--active", j === i);
      });
      panel = i;
      render();
    });
  });

  render();
})();
</script>
