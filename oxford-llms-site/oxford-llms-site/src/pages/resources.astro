---
import Base from '../layouts/Base.astro';
---

<Base title="Resources" description="Open-source materials, code, and datasets from Oxford LLMs.">
  <div class="container container--content">

    <div class="page-header">
      <p class="section-label">Resources</p>
      <h1 class="page-header__title">Materials & Resources</h1>
      <p class="page-header__desc">
        Lecture slides, workshop materials, code, and practical guides from across
        the Oxford LLMs programme. All openly available.
      </p>
    </div>

    <div class="grid-3 mt-4">
      <a href="/resources/summer-school/" class="card card--accent-1 card--pillar">
        <span class="tag">Summer School</span>
        <h3 class="card__title" style="margin-top: var(--sp-3);">Summer School Materials</h3>
        <p class="card__text">
          Curated list of lecture slides, Jupyter notebooks, and code samples from the 2023 and 2024
          summer schools.
        </p>
        <span class="card__link">Browse materials →</span>
      </a>

      <a href="https://github.com/Oxford-LLMs-Research/llms-social-science-course" class="card card--accent-3 card--pillar" target="_blank" rel="noopener">
        <span class="tag">Course</span>
        <h3 class="card__title" style="margin-top: var(--sp-3);">Course Materials</h3>
        <p class="card__text">
          Teaching materials for the Oxford / Paris / Florence courses.
          Structured curriculum from fundamentals to deployment.
        </p>
        <span class="card__link">View on GitHub →</span>
      </a>

      <a href="https://github.com/Oxford-LLMs-Research/synthetic_sampling" class="card card--accent-5 card--pillar" target="_blank" rel="noopener">
        <span class="tag">Research</span>
        <h3 class="card__title" style="margin-top: var(--sp-3);">Synthetic Sampling</h3>
        <p class="card__text">
          Research code for synthetic sampling methods.
          LLM-based opinion prediction and benchmarking experiments.
        </p>
        <span class="card__link">View on GitHub →</span>
      </a>
    </div>

    <div class="prose mt-8">
      <h2>Datasets & Models</h2>
      <p>
        Pre-trained models and processed datasets from our collaborative research projects
        are available on the
        <a href="https://huggingface.co/oxford-llms" target="_blank" rel="noopener">Oxford LLMs HuggingFace profile</a>.
      </p>

      <h2>Videos</h2>
      <p>
        <!-- Phase 2: Lecture videos expected ~Apr 3 -->
        <em>Lecture recordings from September 2025 are being edited and will be published here in April.</em>
      </p>
    </div>

  </div>
</Base>

<style>
  .card--pillar {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .card--pillar:hover {
    border-color: var(--accent-soft);
    transform: translateY(-2px);
  }
  .card--pillar .card__text { flex: 1; }
</style>
