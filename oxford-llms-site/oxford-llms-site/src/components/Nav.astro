---
import LogoMark from './LogoMark.astro';

/* Navigation — used in Base layout */
const currentPath = Astro.url.pathname;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/research/', label: 'Research' },
  { href: '/summer-school/', label: 'Summer School' },
  { href: '/course/', label: 'Course' },
  { href: '/resources/', label: 'Resources' },
];
---

<nav class="nav" aria-label="Main navigation">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      <LogoMark size={24} />
      <span>Oxford LLMs</span>
    </a>

    <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false">
      <svg viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>

    <ul class="nav__links" id="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'nav__link',
              { 'nav__link--active': currentPath.startsWith(link.href) }
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/apply/" class="nav__link nav__link--cta">Apply</a>
      </li>
      <li class="nav__theme">
        <button
          id="theme-button"
          type="button"
          class="nav__theme-button"
          aria-haspopup="listbox"
          aria-expanded="false"
        >
          <span class="sr-only">Color theme</span>
          <span id="theme-button-label" class="nav__theme-button-label">Blue Lagoon</span>
          <svg class="nav__theme-chevron" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div
          id="theme-menu"
          class="nav__theme-menu"
          role="listbox"
          aria-label="Color theme"
        >
          <button
            class="nav__theme-option"
            type="button"
            role="option"
            data-theme-value="blue"
            aria-selected="true"
          >
            <span class="nav__theme-swatch nav__theme-swatch--blue" aria-hidden="true"></span>
            <span>Blue Lagoon</span>
          </button>
          <button
            class="nav__theme-option"
            type="button"
            role="option"
            data-theme-value="purple"
          >
            <span class="nav__theme-swatch nav__theme-swatch--purple" aria-hidden="true"></span>
            <span>Fusion</span>
          </button>
          <button
            class="nav__theme-option"
            type="button"
            role="option"
            data-theme-value="red"
          >
            <span class="nav__theme-swatch nav__theme-swatch--red" aria-hidden="true"></span>
            <span>Ember</span>
          </button>
          <button
            class="nav__theme-option"
            type="button"
            role="option"
            data-theme-value="green"
          >
            <span class="nav__theme-swatch nav__theme-swatch--green" aria-hidden="true"></span>
            <span>Canopy</span>
          </button>
          <button
            class="nav__theme-option"
            type="button"
            role="option"
            data-theme-value="mono"
          >
            <span class="nav__theme-swatch nav__theme-swatch--mono" aria-hidden="true"></span>
            <span>Graphite</span>
          </button>
        </div>
      </li>
    </ul>
  </div>
</nav>

<script>
  // Simple mobile menu toggle — no framework needed
  const toggle = document.querySelector('.nav__toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('nav__links--open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }

  // Theme selection — maps to CSS data-theme on <html>
  const themeButton = document.getElementById('theme-button');
  const themeButtonLabel = document.getElementById('theme-button-label');
  const themeMenu = document.getElementById('theme-menu');
  const root = document.documentElement;
  const THEME_KEY = 'oxford-llms-theme';

  function applyTheme(value) {
    if (!value) return;
    root.dataset.theme = value === 'blue' ? '' : value;
    if (value === 'blue') {
      delete root.dataset.theme;
    }
  }

  function setActiveTheme(value) {
    const options = themeMenu?.querySelectorAll('.nav__theme-option');
    options?.forEach((option) => {
      const isActive = option.getAttribute('data-theme-value') === value;
      option.setAttribute('aria-selected', String(isActive));
      option.classList.toggle('nav__theme-option--active', isActive);
    });

    const activeOption = themeMenu?.querySelector('.nav__theme-option--active span:nth-child(2)');
    if (activeOption && themeButtonLabel) {
      themeButtonLabel.textContent = activeOption.textContent || '';
    }
  }

  if (themeButton && themeMenu) {
    // Initialise from localStorage
    const stored = window.localStorage.getItem(THEME_KEY);
    const initial = stored || 'blue';
    applyTheme(initial);
    setActiveTheme(initial);

    themeButton.addEventListener('click', () => {
      const isOpen = themeMenu.classList.toggle('nav__theme-menu--open');
      themeButton.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        const active = themeMenu.querySelector('.nav__theme-option--active') as HTMLButtonElement | null;
        active?.focus();
      }
    });

    themeMenu.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const option = target?.closest('.nav__theme-option') as HTMLButtonElement | null;
      if (!option) return;

      const value = option.getAttribute('data-theme-value');
      if (!value) return;

      window.localStorage.setItem(THEME_KEY, value);
      applyTheme(value);
      setActiveTheme(value);

      themeMenu.classList.remove('nav__theme-menu--open');
      themeButton.setAttribute('aria-expanded', 'false');
      themeButton.focus();
    });

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('.nav__theme')) return;
      if (!themeMenu.classList.contains('nav__theme-menu--open')) return;
      themeMenu.classList.remove('nav__theme-menu--open');
      themeButton.setAttribute('aria-expanded', 'false');
    });
  }
</script>
